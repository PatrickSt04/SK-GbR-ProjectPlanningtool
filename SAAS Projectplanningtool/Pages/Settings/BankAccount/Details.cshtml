@page
@model SAAS_Projectplanningtool.Pages.Settings.BankAccount.DetailsModel

@{
    ViewData["Title"] = Model.BankAccount.AccountName;
    bool isLocked = Model.BankAccount.DeleteFlag;
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1>
                <i class="bi bi-bank me-2"></i>@Model.BankAccount.AccountName
                @if (isLocked)
                {
                    <span class="badge badge-locked badge-inline">
                        <i class="bi bi-lock-fill"></i> Gesperrt
                    </span>
                }
                else
                {
                    <span class="badge badge-aktiv badge-inline">
                        <i class="bi bi-check-circle-fill"></i> Aktiv
                    </span>
                }
            </h1>
            <div class="project-meta">
                <span class="creator-info">
                    <i class="bi bi-person me-1"></i>
                    Erstellt von: <strong>@(Model.BankAccount.CreatedByEmployee?.EmployeeDisplayName ?? "Unbekannt")</strong>
                </span>
                @if (Model.BankAccount.CreatedTimestamp.HasValue)
                {
                    <span class="creation-date">
                        <i class="bi bi-calendar3 me-1"></i>
                        @Model.BankAccount.CreatedTimestamp.Value.ToString("dd.MM.yyyy HH:mm")
                    </span>
                }
            </div>
        </div>
        <div class="header-actions">
            <a asp-page="./Edit" asp-route-id="@Model.BankAccount.BankAccountId" class="btn btn-outline-light">
                <i class="bi bi-pencil me-1"></i>Bearbeiten
            </a>
            <a asp-page="./Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück
            </a>
            @if (!isLocked)
            {
                <form method="post" asp-page-handler="SetDeleteFlag" asp-route-id="@Model.BankAccount.BankAccountId">
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Bankkonto wirklich sperren?');">
                        <i class="bi bi-lock-fill me-1"></i>Sperren
                    </button>
                </form>
            }
            else
            {
                <form method="post" asp-page-handler="UndoDeleteFlag" asp-route-id="@Model.BankAccount.BankAccountId">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-unlock-fill me-1"></i>Entsperren
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-md-9">
        <div class="card">
            <div class="cm-colorbar"></div>
            <div class="card-header">
                <h5><i class="bi bi-bank me-2"></i>Kontodaten</h5>
            </div>
            <div class="card-body">
                <div class="cm-info-grid">
                    <div class="cm-info-item">
                        <label><i class="bi bi-tag"></i> Kontobezeichnung</label>
                        <span>@Model.BankAccount.AccountName</span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-credit-card"></i> IBAN</label>
                        <span class="cm-text-mono">@Model.BankAccount.IBAN</span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-upc-scan"></i> BIC</label>
                        <span>@(Model.BankAccount.BIC ?? "–")</span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-building"></i> Kreditinstitut</label>
                        <span>@(Model.BankAccount.BankName ?? "–")</span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-person"></i> Kontoinhaber</label>
                        <span>@(Model.BankAccount.AccountHolder ?? "–")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-3">
        <div class="cm-sidebar">
            <div class="card">
                <div class="card-header">
                    <h5>Letzte Änderung</h5>
                </div>
                <div class="card-body">
                    <div class="cm-detail-list">
                        <div>
                            <div class="cm-detail-label">Bearbeiter</div>
                            <div>@(Model.BankAccount.LatestModifier?.EmployeeDisplayName ?? "–")</div>
                        </div>
                        <div>
                            <div class="cm-detail-label">Zeitpunkt</div>
                            <div>@(Model.BankAccount.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</div>
                        </div>
                        <div>
                            <div class="cm-detail-label">Beschreibung</div>
                            <div class="cm-text-muted">@(Model.BankAccount.LatestModificationText ?? "–")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
