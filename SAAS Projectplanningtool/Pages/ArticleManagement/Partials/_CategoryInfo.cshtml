@model SAAS_Projectplanningtool.Pages.ArticleManagement.ArticleCategoryDetailsModel

<div class="card">
    <div class="cm-colorbar"></div>
    <div class="card-header">
        <h5><i class="bi bi-tag me-2"></i>Details</h5>
    </div>
    <div class="card-body">
        <div class="cm-info-grid">
            <div class="cm-info-item">
                <label><i class="bi bi-tag"></i> Kategoriename</label>
                <span>@Model.Category.CategoryName</span>
            </div>
            <div class="cm-info-item">
                <label><i class="bi bi-box-seam"></i> Aktive Artikel</label>
                <span>@Model.Category.Articles.Count(a => !a.DeleteFlag)</span>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Category.Description))
        {
            <div class="cm-description-section">
                <label><i class="bi bi-text-left"></i> Beschreibung</label>
                <p class="cm-description-text">@Model.Category.Description</p>
            </div>
        }
    </div>
</div>
