@model SAAS_Projectplanningtool.Pages.ArticleManagement.ArticleCategoryIndexModel

<div class="card">
    <div class="cm-colorbar"></div>
    <div class="card-header">
        <h5>Kategorien</h5>
        <div class="card-actions">
            <a asp-page="ArticleCategoryCreate" class="btn btn-primary btn-sm">
                Neue Kategorie
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="cm-toolbar-wrap">
            <div class="cm-toolbar">
                <div class="cm-search-wrap">
                    <input type="text" id="searchInput" class="cm-input cm-search"
                           placeholder="Kategorie suchen…" oninput="filterTable()">
                </div>
                <select id="statusFilter" class="cm-input cm-select w-auto" onchange="filterTable()">
                    <option value="aktiv">Aktive</option>
                    <option value="">Alle</option>
                    <option value="gesperrt">Gesperrte</option>
                </select>
            </div>
        </div>

        <table class="cm-table" id="categoryTable">
            <thead>
                <tr>
                    <th>Kategoriename</th>
                    <th>Beschreibung</th>
                    <th>Artikel</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model.Categories)
                {
                    <tr data-name="@cat.CategoryName.ToLower()"
                        data-status="@(cat.DeleteFlag ? "gesperrt" : "aktiv")">
                        <td>
                            <a class="td-link" asp-page="ArticleCategoryDetails" asp-route-id="@cat.ArticleCategoryId">
                                @cat.CategoryName
                            </a>
                        </td>
                        <td class="cm-text-muted">
                            @(string.IsNullOrEmpty(cat.Description) ? "–" : cat.Description)
                        </td>
                        <td class="cm-text-muted">
                            @cat.Articles.Count(a => !a.DeleteFlag) aktiv
                        </td>
                        <td>
                            @if (cat.DeleteFlag)
                            {
                                <span class="badge badge-locked badge-inline-sm">
                                    Gesperrt
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-aktiv badge-inline-sm">
                                    Aktiv
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Categories.Any())
        {
            <div class="empty-state">
                <p>Noch keine Kategorien vorhanden.</p>
            </div>
        }

        <div class="cm-card-footer">
            <span id="rowCount">@Model.Categories.Count</span> Einträge
        </div>
    </div>
</div>
