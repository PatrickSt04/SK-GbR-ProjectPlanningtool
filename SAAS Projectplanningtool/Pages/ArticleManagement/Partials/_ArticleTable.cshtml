@model SAAS_Projectplanningtool.Pages.ArticleManagement.IndexModel

<div class="card">
    <div class="cm-colorbar"></div>
    <div class="card-header">
        <h5><i class="bi bi-box-seam me-2"></i>Artikel</h5>
        <div class="card-actions">
            <a asp-page="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Neuer Artikel
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="cm-toolbar-wrap">
            <div class="cm-toolbar">
                <div class="cm-search-wrap">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchInput" class="cm-input cm-search"
                           placeholder="Artikelnummer oder Name suchen…" oninput="filterTable()">
                </div>
                <select id="categoryFilter" class="cm-input cm-select w-auto" onchange="filterTable()">
                    <option value="">Alle Kategorien</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.ArticleCategoryId">@cat.CategoryName</option>
                    }
                </select>
                <select id="statusFilter" class="cm-input cm-select w-auto" onchange="filterTable()">
                    <option value="aktiv">Aktive</option>
                    <option value="">Alle</option>
                    <option value="gesperrt">Gesperrte</option>
                </select>
            </div>
        </div>

        <table class="cm-table" id="articleTable">
            <thead>
                <tr>
                    <th>Artikelnummer</th>
                    <th>Artikelname</th>
                    <th>Kategorie</th>
                    <th>Einheit</th>
                    <th class="text-end">Preis</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Articles)
                {
                    <tr data-search="@item.ArticleNumber.ToLower() @item.ArticleName.ToLower()"
                        data-category="@item.ArticleCategoryId"
                        data-status="@(item.DeleteFlag ? "gesperrt" : "aktiv")">
                        <td class="cm-text-mono">
                            @item.ArticleNumber
                        </td>
                        <td>
                            <a class="td-link" asp-page="Details" asp-route-id="@item.ArticleId">
                                @item.ArticleName
                            </a>
                        </td>
                        <td>
                            @if (item.ArticleCategory != null)
                            {
                                <span class="badge">
                                    <i class="bi bi-tag-fill"></i> @item.ArticleCategory.CategoryName
                                </span>
                            }
                            else
                            {
                                <span class="cm-text-placeholder">–</span>
                            }
                        </td>
                        <td>
                            @if (item.Unit != null)
                            {
                                <span class="badge">@item.Unit.ShortName</span>
                            }
                            else
                            {
                                <span class="cm-text-placeholder">–</span>
                            }
                        </td>
                        <td class="text-end fw-bold">
                            @item.CurrentPrice.ToString("N2") €
                        </td>
                        <td>
                            @if (item.DeleteFlag)
                            {
                                <span class="badge badge-locked badge-inline-sm">
                                    <i class="bi bi-lock-fill"></i> Gesperrt
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-aktiv badge-inline-sm">
                                    <i class="bi bi-check-circle-fill"></i> Aktiv
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Articles.Any())
        {
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <p>Noch keine Artikel vorhanden.</p>
            </div>
        }

        <div class="cm-card-footer">
            <span id="rowCount">@Model.Articles.Count</span> Einträge
        </div>
    </div>
</div>
