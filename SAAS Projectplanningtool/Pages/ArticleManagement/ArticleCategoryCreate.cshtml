@page
@model SAAS_Projectplanningtool.Pages.ArticleManagement.ArticleCategoryCreateModel

@{
    ViewData["Title"] = "Neue Artikelkategorie";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-plus-circle me-2"></i>Neue Artikelkategorie</h1>
            <p class="header-subtitle">Legen Sie eine neue Kategorie für Ihre Artikel an</p>
        </div>
        <div class="header-actions">
            <a asp-page="ArticleCategoryIndex" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger cm-validation-summary"></div>
        <input type="hidden" asp-for="Category.ArticleCategoryId" />
        <input type="hidden" asp-for="Category.CompanyId" />

        <div class="card">
            <div class="cm-colorbar"></div>
            <div class="card-header">
                <h5><i class="bi bi-tag me-2"></i>Kategoriedaten</h5>
            </div>
            <div class="card-body">
                <div class="cm-form-group">
                    <label asp-for="Category.CategoryName">Kategoriename *</label>
                    <input asp-for="Category.CategoryName" class="cm-input" placeholder="z.B. Elektronik, Rohstoffe…" />
                    <span asp-validation-for="Category.CategoryName" class="text-danger"></span>
                </div>
                <div class="cm-form-group">
                    <label asp-for="Category.Description">Beschreibung</label>
                    <textarea asp-for="Category.Description" class="cm-input" rows="3"
                              placeholder="Optionale Beschreibung der Kategorie…"></textarea>
                </div>
            </div>
        </div>

        <div class="cm-form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Anlegen
            </button>
            <a asp-page="ArticleCategoryIndex" class="btn btn-outline-secondary">Abbrechen</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

