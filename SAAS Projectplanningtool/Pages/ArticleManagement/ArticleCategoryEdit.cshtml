@page
@model SAAS_Projectplanningtool.Pages.ArticleManagement.ArticleCategoryEditModel

@{
    ViewData["Title"] = "Kategorie bearbeiten";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-pencil-square me-2"></i>Kategorie bearbeiten</h1>
            <p class="header-subtitle">@Model.Category.CategoryName</p>
        </div>
        <div class="header-actions">
            <a asp-page="ArticleCategoryDetails" asp-route-id="@Model.Category.ArticleCategoryId"
               class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger cm-validation-summary"></div>
        <input type="hidden" asp-for="Category.ArticleCategoryId" />
        <input type="hidden" asp-for="Category.CompanyId" />
        <input type="hidden" asp-for="Category.CreatedById" />
        <input type="hidden" asp-for="Category.CreatedTimestamp" />

        <div class="card">
            <div class="cm-colorbar"></div>
            <div class="card-header">
                <h5><i class="bi bi-pencil-square me-2"></i>Kategoriedaten bearbeiten</h5>
            </div>
            <div class="card-body">
                <div class="cm-form-group">
                    <label asp-for="Category.CategoryName">Kategoriename *</label>
                    <input asp-for="Category.CategoryName" class="cm-input" />
                    <span asp-validation-for="Category.CategoryName" class="text-danger"></span>
                </div>
                <div class="cm-form-group">
                    <label asp-for="Category.Description">Beschreibung</label>
                    <textarea asp-for="Category.Description" class="cm-input" rows="3"></textarea>
                </div>
            </div>
        </div>

        <div class="cm-form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Speichern
            </button>
            <a asp-page="ArticleCategoryDetails" asp-route-id="@Model.Category.ArticleCategoryId"
               class="btn btn-outline-secondary">Abbrechen</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
