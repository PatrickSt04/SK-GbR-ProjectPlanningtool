@page
@model SAAS_Projectplanningtool.Pages.ArticleManagement.CreateModel

@{
    ViewData["Title"] = "Neuer Artikel";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-plus-circle me-2"></i>Neuer Artikel</h1>
            <p class="header-subtitle">Legen Sie einen neuen Artikel an</p>
        </div>
        <div class="header-actions">
            <a asp-page="Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger cm-validation-summary"></div>
        <input type="hidden" asp-for="Article.ArticleId" />
        <input type="hidden" asp-for="Article.CompanyId" />

        <div class="card">
            <div class="cm-colorbar"></div>
            <div class="card-header">
                <h5><i class="bi bi-box-seam me-2"></i>Artikeldaten</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="cm-form-group">
                            <label asp-for="Article.ArticleNumber">Artikelnummer *</label>
                            <input asp-for="Article.ArticleNumber" class="cm-input" placeholder="z.B. ART-0001" />
                            <span asp-validation-for="Article.ArticleNumber" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="cm-form-group">
                            <label asp-for="Article.ArticleName">Artikelname *</label>
                            <input asp-for="Article.ArticleName" class="cm-input" placeholder="Bezeichnung des Artikels" />
                            <span asp-validation-for="Article.ArticleName" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="cm-form-group">
                            <label asp-for="Article.ArticleCategoryId">Kategorie</label>
                            <select asp-for="Article.ArticleCategoryId" class="cm-input cm-select"
                                    asp-items="Model.CategorySelectList">
                                <option value="">– Keine Kategorie –</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cm-form-group">
                            <label asp-for="Article.UnitId">Einheit *</label>
                            <select asp-for="Article.UnitId" class="cm-input cm-select"
                                    asp-items="Model.UnitSelectList">
                                <option value="">– Einheit wählen –</option>
                            </select>
                            <span asp-validation-for="Article.UnitId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cm-form-group">
                            <label asp-for="Price">Preis (€) *</label>
                            <input asp-for="Price" class="cm-input" type="number"
                                   step="0.01" min="0" placeholder="0.00" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="cm-form-group">
                    <label asp-for="Article.Description">Beschreibung</label>
                    <textarea asp-for="Article.Description" class="cm-input" rows="3"
                              placeholder="Optionale Artikelbeschreibung…"></textarea>
                </div>
            </div>
        </div>

        <div class="cm-form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Anlegen
            </button>
            <a asp-page="Index" class="btn btn-outline-secondary">Abbrechen</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
