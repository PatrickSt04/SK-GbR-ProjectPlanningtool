@page
@model SAAS_Projectplanningtool.Pages.ArticleManagement.CreateModel
@{
    ViewData["Title"] = "Neuer Artikel";
}

@await Html.PartialAsync("_ArticleStyles")

<div style="max-width:680px;">
    <div class="cm-header">
        <div>
            <h1>Neuer Artikel</h1>
            <div class="cm-meta">Legen Sie einen neuen Artikel an</div>
        </div>
        <a asp-page="Index" class="btn-cm btn-cm-ghost">
            <i class="bi bi-arrow-left"></i> Zurück
        </a>
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="cm-validation-error"></div>
        <input type="hidden" asp-for="Article.ArticleId" />
        <input type="hidden" asp-for="Article.CompanyId" />

        <div class="cm-card">
            <div class="cm-card-title">Artikeldaten</div>
            <div style="display:grid; grid-template-columns:1fr 2fr; gap:14px;">
                <div class="cm-form-group">
                    <label asp-for="Article.ArticleNumber">Artikelnummer *</label>
                    <input asp-for="Article.ArticleNumber" class="cm-input"
                           placeholder="z.B. ART-0001" style="font-family:monospace;" />
                    <span asp-validation-for="Article.ArticleNumber" style="color:var(--danger); font-size:.78rem;"></span>
                </div>
                <div class="cm-form-group">
                    <label asp-for="Article.ArticleName">Artikelname *</label>
                    <input asp-for="Article.ArticleName" class="cm-input" placeholder="Bezeichnung des Artikels" />
                    <span asp-validation-for="Article.ArticleName" style="color:var(--danger); font-size:.78rem;"></span>
                </div>
            </div>
            <div style="display:grid; grid-template-columns:2fr 1fr; gap:14px;">
                <div class="cm-form-group">
                    <label asp-for="Article.ArticleCategoryId">Kategorie</label>
                    <select asp-for="Article.ArticleCategoryId" class="cm-input cm-select"
                            asp-items="Model.CategorySelectList">
                        <option value="">– Keine Kategorie –</option>
                    </select>
                </div>
                <div class="cm-form-group">
                    <label asp-for="Article.Price">Preis (€) *</label>
                    <input asp-for="Article.Price" class="cm-input" type="number"
                           step="0.01" min="0" placeholder="0.00" />
                    <span asp-validation-for="Article.Price" style="color:var(--danger); font-size:.78rem;"></span>
                </div>
            </div>
            <div class="cm-form-group">
                <label asp-for="Article.Description">Beschreibung</label>
                <textarea asp-for="Article.Description" class="cm-input" rows="3"
                          style="resize:vertical;" placeholder="Optionale Artikelbeschreibung…"></textarea>
            </div>
        </div>

        <div style="display:flex; gap:10px; justify-content:flex-end;">
            <a asp-page="Index" class="btn-cm btn-cm-ghost">Abbrechen</a>
            <button type="submit" class="btn-cm btn-cm-primary">
                <i class="bi bi-check-lg"></i> Anlegen
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
