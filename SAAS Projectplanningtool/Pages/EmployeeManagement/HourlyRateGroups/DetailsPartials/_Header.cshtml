@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.DetailsModel

@{
    bool isLocked = Model.HourlyRateGroup.DeleteFlag == true;
}

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1>
                <i class="bi bi-clock-history me-2"></i>@Model.HourlyRateGroup.HourlyRateGroupName
                @if (isLocked)
                {
                    <span class="badge-type badge-locked badge-inline">
                        <i class="bi bi-lock-fill"></i> Gesperrt
                    </span>
                }
                else
                {
                    <span class="badge-type badge-aktiv badge-inline">
                        <i class="bi bi-check-circle-fill"></i> Aktiv
                    </span>
                }
            </h1>
            <div class="project-meta">
                <span class="creator-info">
                    <i class="bi bi-person me-1"></i>
                    Erstellt von: <strong>@(Model.HourlyRateGroup.CreatedByEmployee?.EmployeeDisplayName ?? "SK Tools")</strong>
                </span>
                <span class="creation-date">
                    <i class="bi bi-calendar3 me-1"></i>
                    @(Model.HourlyRateGroup.CreatedTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "Datum unbekannt")
                </span>
            </div>
        </div>
        <div class="header-actions">
            <a asp-page="./Edit" asp-route-id="@Model.HourlyRateGroup.HourlyRateGroupId" class="btn btn-outline-light">
                <i class="bi bi-pencil me-1"></i>Bearbeiten
            </a>
            <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück
            </a>
        </div>
    </div>
</div>
