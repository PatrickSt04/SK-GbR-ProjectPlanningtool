@page
@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.IndexModel

@{
    ViewData["Title"] = "Stundensatzgruppen";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-clock-history me-2"></i>Stundensatzgruppen</h1>
            <p class="header-subtitle">Alle Stundensatzgruppen Ihres Unternehmens</p>
        </div>
        <div class="header-actions">
            <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-light">
                <i class="bi bi-people me-1"></i>Mitarbeiter
            </a>
            <a asp-page="Create" class="btn btn-light">
                <i class="bi bi-plus-lg me-1"></i>Neue Gruppe
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="cm-colorbar-rate"></div>

    <table class="cm-table" id="rateGroupTable">
        <thead>
            <tr>
                <th>Gruppenname</th>
                <th class="text-end">Stundensatz</th>
                <th>Status</th>
                <th>Zuletzt geändert</th>
                <th class="cm-col-actions"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.HourlyRateGroup)
            {
                <tr>
                    <td>
                        <a class="td-link" asp-page="./Details" asp-route-id="@item.HourlyRateGroupId">
                            @item.HourlyRateGroupName
                        </a>
                    </td>
                    <td class="text-end">
                        <span class="cm-text-rate">@item.HourlyRate.ToString("0.00") €</span>
                    </td>
                    <td>
                        @if (item.DeleteFlag)
                        {
                            <span class="badge-type badge-locked"><i class="bi bi-lock-fill"></i> Gesperrt</span>
                        }
                        else
                        {
                            <span class="cm-text-status-active">
                                <i class="bi bi-check-circle-fill"></i> Aktiv
                            </span>
                        }
                    </td>
                    <td class="cm-text-date">
                        @(item.LatestModificationTimestamp?.ToString("dd.MM.yyyy") ?? "–")
                    </td>
                    <td>
                        <a asp-page="./Details" asp-route-id="@item.HourlyRateGroupId"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.HourlyRateGroup.Any())
    {
        <div class="empty-state">
            <i class="bi bi-clock"></i>
            <p>Noch keine Stundensatzgruppen vorhanden.</p>
        </div>
    }

    <div class="cm-card-footer">
        @Model.HourlyRateGroup.Count Gruppen
    </div>
</div>
