@page
@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.IndexModel

@{
    ViewData["Title"] = "Stundensatzgruppen";
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>Stundensatzgruppen</h1>
        <div class="cm-meta">Alle Stundensatzgruppen Ihres Unternehmens</div>
    </div>
    <div style="display:flex; gap:8px;">
        <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
            <i class="bi bi-people"></i> Mitarbeiter
        </a>
        <a asp-page="Create" class="btn-cm btn-cm-purple">
            <i class="bi bi-plus-lg"></i> Neue Gruppe
        </a>
    </div>
</div>

<div class="cm-card" style="padding:0; overflow:hidden;">
    <div class="cm-colorbar-rate"></div>

    <table class="cm-table" id="rateGroupTable">
        <thead>
            <tr>
                <th>Gruppenname</th>
                <th style="text-align:right;">Stundensatz</th>
                <th>Status</th>
                <th>Zuletzt geändert</th>
                <th style="width:80px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.HourlyRateGroup)
            {
                <tr>
                    <td>
                        <a class="td-link" asp-page="./Details" asp-route-id="@item.HourlyRateGroupId">
                            @item.HourlyRateGroupName
                        </a>
                    </td>
                    <td style="text-align:right;">
                        <span style="font-weight:700; color:var(--purple);">@item.HourlyRate.ToString("0.00") €</span>
                    </td>
                    <td>
                        @if (item.DeleteFlag)
                        {
                            <span class="badge-type badge-locked"><i class="bi bi-lock-fill"></i> Gesperrt</span>
                        }
                        else
                        {
                            <span style="color:var(--success); font-size:.8rem; font-weight:600;">
                                <i class="bi bi-check-circle-fill"></i> Aktiv
                            </span>
                        }
                    </td>
                    <td style="font-size:.82rem; color:var(--text-muted);">
                        @(item.LatestModificationTimestamp?.ToString("dd.MM.yyyy") ?? "–")
                    </td>
                    <td>
                        <a asp-page="./Details" asp-route-id="@item.HourlyRateGroupId"
                           class="btn-cm btn-cm-ghost btn-cm-sm">
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.HourlyRateGroup.Any())
    {
        <div class="cm-empty">
            <div class="cm-empty-icon"><i class="bi bi-clock"></i></div>
            Noch keine Stundensatzgruppen vorhanden.
        </div>
    }

    <div style="padding:10px 24px; border-top:1px solid var(--border); font-size:.78rem; color:var(--text-muted);">
        @Model.HourlyRateGroup.Count Gruppen
    </div>
</div>
