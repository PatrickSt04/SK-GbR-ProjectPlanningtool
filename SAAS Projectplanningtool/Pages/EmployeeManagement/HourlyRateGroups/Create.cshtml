@page
@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.CreateModel

@{
    ViewData["Title"] = "Stundensatzgruppe anlegen";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-clock-history me-2"></i>Stundensatzgruppe anlegen</h1>
            <p class="header-subtitle">Neue Gruppe mit Stundensatz erstellen</p>
        </div>
        <div class="header-actions">
            <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück zur Übersicht
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container-sm">
    <div class="card">
        <div class="cm-colorbar-rate"></div>
        <div class="card-header">
            <h5><i class="bi bi-clock-history me-2"></i>Gruppendaten</h5>
        </div>
        <div class="card-body">

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger cm-validation-summary"></div>

                <div class="cm-form-group">
                    <label asp-for="HourlyRateGroup.HourlyRateGroupName">Name der Stundensatzgruppe</label>
                    <input asp-for="HourlyRateGroup.HourlyRateGroupName" class="cm-input" placeholder="z. B. Senior, Junior, Extern…" />
                    <span asp-validation-for="HourlyRateGroup.HourlyRateGroupName" class="text-danger"></span>
                </div>

                <div class="cm-form-group">
                    <label asp-for="HourlyRateGroup.HourlyRate">Stundensatz in €</label>
                    <input asp-for="HourlyRateGroup.HourlyRate" class="cm-input" placeholder="0,00" type="number" step="0.01" min="0" />
                    <span asp-validation-for="HourlyRateGroup.HourlyRate" class="text-danger"></span>
                </div>

                <div class="cm-form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Gruppe anlegen
                    </button>
                    <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-secondary">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
