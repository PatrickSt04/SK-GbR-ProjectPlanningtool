@page
@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.EditModel

@{
    ViewData["Title"] = "Stundensatzgruppe bearbeiten";
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>Stundensatzgruppe bearbeiten</h1>
        <div class="cm-meta">Gruppenname und Stundensatz aktualisieren</div>
    </div>
    <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
        <i class="bi bi-arrow-left"></i> Zurück zur Übersicht
    </a>
</div>

<div style="max-width:480px;">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div class="cm-colorbar-rate"></div>
        <div style="padding:24px;">
            <div class="cm-card-title"><i class="bi bi-pencil-square"></i> &nbsp;Gruppendaten bearbeiten</div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>
                <input type="hidden" asp-for="HourlyRateGroup.HourlyRateGroupId" />

                <div class="cm-form-group">
                    <label asp-for="HourlyRateGroup.HourlyRateGroupName">Name der Stundensatzgruppe</label>
                    <input asp-for="HourlyRateGroup.HourlyRateGroupName" class="cm-input" />
                    <span asp-validation-for="HourlyRateGroup.HourlyRateGroupName" class="text-danger"></span>
                </div>

                <div class="cm-form-group">
                    <label asp-for="HourlyRateGroup.HourlyRate">Stundensatz in €</label>
                    <input asp-for="HourlyRateGroup.HourlyRate" class="cm-input" type="number" step="0.01" min="0" />
                    <span asp-validation-for="HourlyRateGroup.HourlyRate" class="text-danger"></span>
                </div>

                <div style="display:flex; gap:10px; margin-top:24px;">
                    <button type="submit" class="btn-cm btn-cm-purple">
                        <i class="bi bi-check-lg"></i> Speichern
                    </button>
                    <a asp-page="./Details" asp-route-id="@Model.HourlyRateGroup.HourlyRateGroupId" class="btn-cm btn-cm-ghost">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
