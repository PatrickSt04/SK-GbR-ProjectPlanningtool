@page
@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.DeleteModel

@{
    ViewData["Title"] = "Stundensatzgruppe löschen";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-trash3 me-2"></i>Stundensatzgruppe löschen</h1>
            <p class="header-subtitle">Dieser Vorgang kann nicht rückgängig gemacht werden</p>
        </div>
        <div class="header-actions">
            <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Abbrechen
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container">
    <div class="cm-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>Achtung:</strong> Die Stundensatzgruppe <strong>@Model.HourlyRateGroup.HourlyRateGroupName</strong> wird dauerhaft gelöscht. Bitte bestätigen Sie diesen Vorgang.
        </div>
    </div>

    <div class="card">
        <div class="cm-colorbar cm-colorbar-danger"></div>
        <div class="card-header">
            <h5>Datensatz-Details</h5>
        </div>
        <div class="card-body">
            <div class="cm-info-grid cm-mb-lg">
                <div class="cm-info-item">
                    <label>Gruppenname</label>
                    <span>@Model.HourlyRateGroup.HourlyRateGroupName</span>
                </div>
                <div class="cm-info-item">
                    <label>Stundensatz</label>
                    <span class="rate-chip">@Model.HourlyRateGroup.HourlyRate.ToString("0.00") €/Std.</span>
                </div>
                <div class="cm-info-item">
                    <label>Letzter Änderer</label>
                    <span class="cm-text-muted">@(Model.HourlyRateGroup.LatestModifier?.EmployeeDisplayName ?? "–")</span>
                </div>
                <div class="cm-info-item">
                    <label>Letzte Änderung</label>
                    <span class="cm-text-muted">@(Model.HourlyRateGroup.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</span>
                </div>
            </div>

            <form method="post" class="cm-form-actions">
                <input type="hidden" asp-for="HourlyRateGroup.HourlyRateGroupId" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash3-fill me-1"></i>Endgültig löschen
                </button>
                <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-secondary">Abbrechen</a>
            </form>
        </div>
    </div>
</div>
