@page
@model SAAS_Projectplanningtool.Pages.EmployeeManagement.HourlyRateGroups.DeleteModel

@{
    ViewData["Title"] = "Stundensatzgruppe löschen";
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>Stundensatzgruppe löschen</h1>
        <div class="cm-meta">Dieser Vorgang kann nicht rückgängig gemacht werden</div>
    </div>
    <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
        <i class="bi bi-arrow-left"></i> Abbrechen
    </a>
</div>

<div style="max-width:520px;">
    <div class="cm-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>Achtung:</strong> Die Stundensatzgruppe <strong>@Model.HourlyRateGroup.HourlyRateGroupName</strong> wird dauerhaft gelöscht. Bitte bestätigen Sie diesen Vorgang.
        </div>
    </div>

    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div class="cm-colorbar" style="background:linear-gradient(90deg,var(--danger),#f87171);"></div>
        <div style="padding:24px;">
            <div class="cm-card-title">Datensatz-Details</div>
            <div class="cm-info-grid" style="margin-bottom:24px;">
                <div class="cm-info-item">
                    <label>Gruppenname</label>
                    <span>@Model.HourlyRateGroup.HourlyRateGroupName</span>
                </div>
                <div class="cm-info-item">
                    <label>Stundensatz</label>
                    <span class="rate-chip">@Model.HourlyRateGroup.HourlyRate.ToString("0.00") €/Std.</span>
                </div>
                <div class="cm-info-item">
                    <label>Letzter Änderer</label>
                    <span style="color:var(--text-muted);">@(Model.HourlyRateGroup.LatestModifier?.EmployeeDisplayName ?? "–")</span>
                </div>
                <div class="cm-info-item">
                    <label>Letzte Änderung</label>
                    <span style="color:var(--text-muted);">@(Model.HourlyRateGroup.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</span>
                </div>
            </div>

            <form method="post" style="display:flex; gap:10px;">
                <input type="hidden" asp-for="HourlyRateGroup.HourlyRateGroupId" />
                <button type="submit" class="btn-cm btn-cm-danger">
                    <i class="bi bi-trash3-fill"></i> Endgültig löschen
                </button>
                <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">Abbrechen</a>
            </form>
        </div>
    </div>
</div>
