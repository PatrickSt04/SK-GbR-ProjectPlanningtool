@page
@model IndexModel

@{
    ViewData["Title"] = "Mitarbeiterverwaltung";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-people-fill me-2"></i>Mitarbeiterverwaltung</h1>
            <p class="header-subtitle">Mitarbeiter & Stundensatzgruppen Ihres Unternehmens</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-md-8">
        @await Html.PartialAsync("IndexPartials/_EmployeeTable")
    </div>
    <div class ="col-12 col-md-4">
        @await Html.PartialAsync("IndexPartials/_HourlyRateGroupTable")
    </div>
</div>

<script>
    function filterEmployees() {
        const q      = document.getElementById('empSearch').value.toLowerCase();
        const status = document.getElementById('empStatusFilter').value;
        const rows   = document.querySelectorAll('#employeeTable tbody tr');
        let visible  = 0;
        rows.forEach(r => {
            const name   = r.dataset.name  || '';
            const email  = r.dataset.email || '';
            const rStat  = r.dataset.status || '';
            const show   =
                (!q      || name.includes(q) || email.includes(q)) &&
                (!status || rStat === status);
            r.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('empCount').textContent = visible;
    }
    filterEmployees();
</script>
