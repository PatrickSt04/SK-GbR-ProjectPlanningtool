@page
@model CreateModel

@{
    ViewData["Title"] = "Mitarbeiter anlegen";
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>Mitarbeiter anlegen</h1>
        <div class="cm-meta">Neuen Mitarbeiter zum Unternehmen hinzufügen</div>
    </div>
    <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
        <i class="bi bi-arrow-left"></i> Zurück zur Übersicht
    </a>
</div>

<div style="max-width:520px;">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div class="cm-colorbar"></div>
        <div style="padding:24px;">
            <div class="cm-card-title"><i class="bi bi-person-plus"></i> &nbsp;Mitarbeiterdaten</div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>

                <div class="cm-form-group">
                    <label asp-for="Employee.EmployeeDisplayName">Anzeigename</label>
                    <input asp-for="Employee.EmployeeDisplayName" class="cm-input" placeholder="Vor- und Nachname" />
                    <span asp-validation-for="Employee.EmployeeDisplayName" class="text-danger"></span>
                </div>

                <div class="cm-form-group">
                    <label asp-for="Email">E-Mail-Adresse</label>
                    <input asp-for="Email" class="cm-input" type="email" placeholder="mitarbeiter@firma.de" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                @* Formular-Feld *@
                <div class="cm-form-group">
                    <label>Telefonnummer</label>
                    <div class="phone-wrap-outer">
                        <div class="phone-wrap" id="phoneWrap">
                            <button type="button" class="phone-flag-btn" id="flagBtn" onclick="toggleDropdown()">
                                <span id="flagEmoji">🇩🇪</span>
                                <span id="dialCode">+49</span>
                                <span class="arrow">▼</span>
                            </button>
                            <input class="phone-number-input" id="phoneNumber" type="tel"
                                   placeholder="170 1234567" oninput="updatePhone()" autocomplete="tel-national">
                        </div>
                        @* Dieses hidden input wird an den Server gesendet *@
                        <input type="hidden" asp-for="PhoneNumber" id="fullPhone" />
                        <div class="phone-dropdown" id="dropdown">
                            <div class="phone-search">
                                <input type="text" placeholder="Land suchen…" id="phoneSearch" oninput="filterCountries()">
                            </div>
                            <div id="countryList"></div>
                        </div>
                    </div>
                </div>

                <div class="cm-form-group">
                    <label asp-for="Employee.HourlyRateGroupId">Stundensatzgruppe</label>
                    <select asp-for="Employee.HourlyRateGroupId" class="cm-input cm-select" asp-items="Model.HourlyRateGroups"></select>
                    <span asp-validation-for="Employee.HourlyRateGroupId" class="text-danger"></span>
                </div>

                <div class="cm-form-group">
                    <label asp-for="IdentityRoleId">Rolle</label>
                    <select asp-for="IdentityRoleId" class="cm-input cm-select" asp-items="Model.IdentityRoles"></select>
                </div>

                <div style="display:flex; gap:10px; margin-top:24px;">
                    <button type="submit" class="btn-cm btn-cm-primary">
                        <i class="bi bi-check-lg"></i> Mitarbeiter anlegen
                    </button>
                    <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script>
    const COUNTRIES = [
        {code:'DE',name:'Deutschland',dial:'+49',flag:'🇩🇪'},
        {code:'AT',name:'Österreich', dial:'+43',flag:'🇦🇹'},
        {code:'CH',name:'Schweiz',    dial:'+41',flag:'🇨🇭'},
        {code:'LU',name:'Luxemburg',  dial:'+352',flag:'🇱🇺'},
        {code:'GB',name:'Großbritannien',dial:'+44',flag:'🇬🇧'},
        {code:'US',name:'USA',        dial:'+1', flag:'🇺🇸'},
        {code:'FR',name:'Frankreich', dial:'+33',flag:'🇫🇷'},
        {code:'IT',name:'Italien',    dial:'+39',flag:'🇮🇹'},
        {code:'ES',name:'Spanien',    dial:'+34',flag:'🇪🇸'},
        {code:'NL',name:'Niederlande',dial:'+31',flag:'🇳🇱'},
        {code:'PL',name:'Polen',      dial:'+48',flag:'🇵🇱'},
        {code:'TR',name:'Türkei',     dial:'+90',flag:'🇹🇷'},
    ];
    let selectedCountry = COUNTRIES[0];
    let filteredCountries = [...COUNTRIES];

    function renderCountryList() {
        document.getElementById('countryList').innerHTML = filteredCountries.map(c =>
            `<div class="phone-opt${c.code===selectedCountry.code?' selected':''}" onclick="selectCountry('${c.code}')">
                <span>${c.flag}</span><span>${c.name}</span>
                <span class="dial">${c.dial}</span>
            </div>`
        ).join('');
    }
    function filterCountries() {
        const q = document.getElementById('phoneSearch').value.toLowerCase();
        filteredCountries = COUNTRIES.filter(c => c.name.toLowerCase().includes(q) || c.dial.includes(q));
        renderCountryList();
    }
    function selectCountry(code) {
        selectedCountry = COUNTRIES.find(c => c.code === code);
        document.getElementById('flagEmoji').textContent = selectedCountry.flag;
        document.getElementById('dialCode').textContent = selectedCountry.dial;
        closeDropdown();
        updatePhone();
        document.getElementById('phoneNumber').focus();
    }
    function toggleDropdown() {
        const dd = document.getElementById('dropdown');
        if (dd.classList.contains('open')) { closeDropdown(); }
        else {
            filteredCountries = [...COUNTRIES];
            renderCountryList();
            dd.classList.add('open');
            document.getElementById('phoneSearch').value = '';
            setTimeout(() => document.getElementById('phoneSearch').focus(), 50);
        }
    }
    function closeDropdown() { document.getElementById('dropdown').classList.remove('open'); }
    function updatePhone() {
        const num = document.getElementById('phoneNumber').value.trim();
        document.getElementById('fullPhone').value = num ? selectedCountry.dial + ' ' + num : '';
    }
    document.addEventListener('click', e => {
        if (!document.getElementById('phoneWrap').contains(e.target) &&
            !document.getElementById('dropdown').contains(e.target)) closeDropdown();
    });
    renderCountryList();
</script>
