@model SAAS_Projectplanningtool.Pages.EmployeeManagement.Employees.DetailsModel

@{
    bool isLocked = Model.Employee.DeleteFlag == true;
}

<div class="cm-sidebar">

    <div class="card">
        <div class="card-header">
            <h5>Status & Aktionen</h5>
        </div>
        <div class="card-body">
            @if (!isLocked)
            {
                <form method="post" asp-page-handler="SetDeleteFlag" asp-route-id="@Model.Employee.EmployeeId">
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-lock-fill me-1"></i>Mitarbeiter sperren
                    </button>
                </form>
            }
            else
            {
                <form method="post" asp-page-handler="UndoDeleteFlag" asp-route-id="@Model.Employee.EmployeeId">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Entsperren
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5>Letzte Änderung</h5>
        </div>
        <div class="card-body">
            <div class="cm-detail-list">
                <div>
                    <div class="cm-detail-label">Änderer</div>
                    <div>@(Model.Employee.LatestModifier?.EmployeeDisplayName ?? "–")</div>
                </div>
                <div>
                    <div class="cm-detail-label">Zeitpunkt</div>
                    <div>@(Model.Employee.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</div>
                </div>
                <div>
                    <div class="cm-detail-label">Änderungstext</div>
                    <div class="cm-text-muted">@(Model.Employee.LatestModificationText ?? "–")</div>
                </div>
            </div>
        </div>
    </div>

</div>
