@page
@model EditModel

@{
    ViewData["Title"] = "Mitarbeiter bearbeiten";
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>Mitarbeiter bearbeiten</h1>
        <div class="cm-meta">Stammdaten aktualisieren</div>
    </div>
    <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
        <i class="bi bi-arrow-left"></i> Zurück zur Übersicht
    </a>
</div>

<div style="max-width:520px;">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div class="cm-colorbar"></div>
        <div style="padding:24px;">
            <div class="cm-card-title"><i class="bi bi-pencil-square"></i> &nbsp;Mitarbeiterdaten bearbeiten</div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>
                <input type="hidden" asp-for="Employee.EmployeeId" />
                <input type="hidden" asp-for="Employee.IdentityUserId" />
                <input type="hidden" asp-for="Employee.CompanyId" />

                <div class="cm-form-group">
                    <label asp-for="Employee.EmployeeDisplayName">Anzeigename</label>
                    <input asp-for="Employee.EmployeeDisplayName" class="cm-input" />
                    <span asp-validation-for="Employee.EmployeeDisplayName" class="text-danger"></span>
                </div>

                <div class="cm-form-group">
                    <label asp-for="Employee.HourlyRateGroupId">Stundensatzgruppe</label>
                    <select asp-for="Employee.HourlyRateGroupId" class="cm-input cm-select" asp-items="Model.HourlyRateGroups"></select>
                    <span asp-validation-for="Employee.HourlyRateGroupId" class="text-danger"></span>
                </div>

                <div class="cm-form-group">
                    <label asp-for="SelectedRole">Rolle</label>
                    <select asp-for="SelectedRole" class="cm-input cm-select"
                            asp-items="@(ViewData["IdentityRoleId"] as SelectList)">
                        <option value="">-- Keine Rolle --</option>
                    </select>
                </div>

                <div style="display:flex; gap:10px; margin-top:24px;">
                    <button type="submit" class="btn-cm btn-cm-primary">
                        <i class="bi bi-check-lg"></i> Speichern
                    </button>
                    <a asp-page="./Details" asp-route-id="@Model.Employee.EmployeeId" class="btn-cm btn-cm-ghost">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
