@page
@model DeleteModel

@{
    ViewData["Title"] = "Mitarbeiter löschen";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-trash3 me-2"></i>Mitarbeiter löschen</h1>
            <p class="header-subtitle">Dieser Vorgang kann nicht rückgängig gemacht werden</p>
        </div>
        <div class="header-actions">
            <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Abbrechen
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container-lg">
    <div class="cm-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>Achtung:</strong> Der Mitarbeiter <strong>@Model.Employee.EmployeeDisplayName</strong> wird dauerhaft aus dem System gelöscht. Bitte bestätigen Sie diesen Vorgang.
        </div>
    </div>

    <div class="card">
        <div class="cm-colorbar cm-colorbar-danger"></div>
        <div class="card-header">
            <h5>Datensatz-Details</h5>
        </div>
        <div class="card-body">
            <div class="cm-info-grid cm-mb-lg">
                <div class="cm-info-item">
                    <label>Anzeigename</label>
                    <span>@Model.Employee.EmployeeDisplayName</span>
                </div>
                <div class="cm-info-item">
                    <label>E-Mail</label>
                    <span class="cm-text-muted">@(Model.Employee.IdentityUser?.Email ?? "–")</span>
                </div>
                <div class="cm-info-item">
                    <label>Rolle(n)</label>
                    <span>
                        @if (Model.EmployeeRoles.Any())
                        {
                            foreach (var role in Model.EmployeeRoles)
                            {
                                <span class="badge-type badge-role me-1">@role</span>
                            }
                        }
                        else
                        {
                            <span class="cm-text-muted">Keine Rolle</span>
                        }
                    </span>
                </div>
                <div class="cm-info-item">
                    <label>Stundensatzgruppe</label>
                    <span>@(Model.Employee.HourlyRateGroup?.HourlyRateGroupName ?? "–")</span>
                </div>
            </div>

            <form method="post" class="cm-form-actions">
                <input type="hidden" asp-for="Employee.EmployeeId" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash3-fill me-1"></i>Endgültig löschen
                </button>
                <a asp-page="/EmployeeManagement/Index" class="btn btn-outline-secondary">Abbrechen</a>
            </form>
        </div>
    </div>
</div>
