@page
@model DeleteModel

@{
    ViewData["Title"] = "Mitarbeiter löschen";
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>Mitarbeiter löschen</h1>
        <div class="cm-meta">Dieser Vorgang kann nicht rückgängig gemacht werden</div>
    </div>
    <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
        <i class="bi bi-arrow-left"></i> Abbrechen
    </a>
</div>

<div style="max-width:560px;">
    <div class="cm-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>Achtung:</strong> Der Mitarbeiter <strong>@Model.Employee.EmployeeDisplayName</strong> wird dauerhaft aus dem System gelöscht. Bitte bestätigen Sie diesen Vorgang.
        </div>
    </div>

    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div class="cm-colorbar" style="background:linear-gradient(90deg,var(--danger),#f87171);"></div>
        <div style="padding:24px;">
            <div class="cm-card-title">Datensatz-Details</div>
            <div class="cm-info-grid" style="margin-bottom:24px;">
                <div class="cm-info-item">
                    <label>Anzeigename</label>
                    <span>@Model.Employee.EmployeeDisplayName</span>
                </div>
                <div class="cm-info-item">
                    <label>E-Mail</label>
                    <span style="color:var(--text-muted);">@(Model.Employee.IdentityUser?.Email ?? "–")</span>
                </div>
                <div class="cm-info-item">
                    <label>Rolle(n)</label>
                    <span>
                        @if (Model.EmployeeRoles.Any())
                        {
                            foreach (var role in Model.EmployeeRoles)
                            {
                                <span class="badge-type badge-role" style="margin-right:4px;">@role</span>
                            }
                        }
                        else
                        {
                            <span style="color:var(--text-muted);">Keine Rolle</span>
                        }
                    </span>
                </div>
                <div class="cm-info-item">
                    <label>Stundensatzgruppe</label>
                    <span>@(Model.Employee.HourlyRateGroup?.HourlyRateGroupName ?? "–")</span>
                </div>
            </div>

            <form method="post" style="display:flex; gap:10px;">
                <input type="hidden" asp-for="Employee.EmployeeId" />
                <button type="submit" class="btn-cm btn-cm-danger">
                    <i class="bi bi-trash3-fill"></i> Endgültig löschen
                </button>
                <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">Abbrechen</a>
            </form>
        </div>
    </div>
</div>
