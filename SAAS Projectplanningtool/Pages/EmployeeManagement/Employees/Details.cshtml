@page
@model DetailsModel

@{
    ViewData["Title"] = Model.Employee.EmployeeDisplayName;
    bool isLocked = Model.Employee.DeleteFlag == true;
}

@await Html.PartialAsync("../_EmployeeStyles")

<div class="cm-header">
    <div>
        <h1>
            @Model.Employee.EmployeeDisplayName
            @if (isLocked)
            {
                <span class="badge-type badge-locked" style="font-size:.75rem; vertical-align:middle; margin-left:10px;">
                    <i class="bi bi-lock-fill"></i> Gesperrt
                </span>
            }
            else
            {
                <span class="badge-type badge-aktiv" style="font-size:.75rem; vertical-align:middle; margin-left:10px;">
                    <i class="bi bi-check-circle-fill"></i> Aktiv
                </span>
            }
        </h1>
        <div class="cm-meta">Mitarbeiterdetails</div>
    </div>
    <div style="display:flex; gap:8px;">
        <a asp-page="./Edit" asp-route-id="@Model.Employee.EmployeeId" class="btn-cm btn-cm-ghost">
            <i class="bi bi-pencil"></i> Bearbeiten
        </a>
        <a asp-page="/EmployeeManagement/Index" class="btn-cm btn-cm-ghost">
            <i class="bi bi-arrow-left"></i> Zurück
        </a>
    </div>
</div>

<div class="cm-meta-row">
    <span><i class="bi bi-person"></i> Erstellt von: <strong>@(Model.Employee.CreatedByEmployee?.EmployeeDisplayName ?? "SK Tools")</strong></span>
    <span><i class="bi bi-calendar3"></i> @(Model.Employee.CreatedTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "Datum unbekannt")</span>
</div>

<div class="em-detail-grid">

    <div>
        <div class="cm-card" style="padding:0; overflow:hidden;">
            <div class="cm-colorbar"></div>
            <div style="padding:20px 24px;">
                <div class="cm-card-title">Stammdaten</div>
                <div class="cm-info-grid">
                    <div class="cm-info-item">
                        <label><i class="bi bi-person"></i> Anzeigename</label>
                        <span>@Model.Employee.EmployeeDisplayName</span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-envelope"></i> E-Mail-Adresse</label>
                        <span>@(Model.Employee.IdentityUser?.Email ?? "–")</span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-clock"></i> Stundensatzgruppe</label>
                        <span>
                            @if (Model.Employee.HourlyRateGroup != null)
                            {
                                <span class="rate-chip">@Model.Employee.HourlyRateGroup.HourlyRateGroupName</span>
                            }
                            else
                            {

                                <span style="opacity:.4;">–</span>
                            }
                        </span>
                    </div>
                    <div class="cm-info-item">
                        <label><i class="bi bi-currency-euro"></i> Stundensatz</label>
                        <span style="font-weight:700; color:var(--purple);">
                            @(Model.Employee.HourlyRateGroup != null ? Model.Employee.HourlyRateGroup.HourlyRate.ToString("0.00") + " €" : "–")
                        </span>
                    </div>
                </div>
            </div>
            @*Hier werden die Freigegebenen Projekte angezeigt, falls der User ein Viewer ist *@
            @if (Model.EmployeeIsViewer)
            {
                <style>
                    /* ── Viewer Shared Projects ── */
                    .vsp-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                        gap: 16px;
                        padding: 20px 24px;
                    }

                    .vsp-card {
                        background: var(--surface);
                        border: 1.5px solid var(--border);
                        border-radius: var(--radius);
                        overflow: hidden;
                        transition: box-shadow .15s, transform .15s;
                        display: flex;
                        flex-direction: column;
                    }

                        .vsp-card:hover {
                            box-shadow: var(--shadow-md);
                            transform: translateY(-2px);
                        }

                    .vsp-card-top {
                        height: 5px;
                        flex-shrink: 0;
                    }

                    .vsp-card-body {
                        padding: 16px 18px;
                        flex: 1;
                        display: flex;
                        flex-direction: column;
                        gap: 10px;
                    }

                    .vsp-card-header {
                        display: flex;
                        align-items: flex-start;
                        justify-content: space-between;
                        gap: 8px;
                    }

                    .vsp-project-name {
                        font-size: .95rem;
                        font-weight: 700;
                        color: var(--primary);
                        line-height: 1.3;
                    }

                    .vsp-state-badge {
                        display: inline-flex;
                        align-items: center;
                        gap: 5px;
                        font-size: .68rem;
                        font-weight: 700;
                        padding: 3px 9px;
                        border-radius: 20px;
                        white-space: nowrap;
                        flex-shrink: 0;
                    }

                    .vsp-meta-row {
                        display: flex;
                        flex-direction: column;
                        gap: 6px;
                    }

                    .vsp-meta-item {
                        display: flex;
                        align-items: center;
                        gap: 8px;
                        font-size: .8rem;
                        color: var(--text-muted);
                    }

                        .vsp-meta-item i {
                            width: 14px;
                            text-align: center;
                            flex-shrink: 0;
                        }

                        .vsp-meta-item span {
                            color: var(--text);
                            font-weight: 500;
                        }

                    .vsp-card-footer {
                        padding: 10px 18px;
                        border-top: 1px solid var(--border);
                        background: var(--surface-2);
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                    }

                    .vsp-date-range {
                        font-size: .75rem;
                        color: var(--text-muted);
                        display: flex;
                        align-items: center;
                        gap: 5px;
                    }

                        .vsp-date-range .sep {
                            opacity: .4;
                            font-size: .65rem;
                        }

                    .vsp-archived-banner {
                        background: var(--warning-bg);
                        color: var(--warning);
                        font-size: .7rem;
                        font-weight: 700;
                        padding: 3px 10px;
                        text-align: center;
                        letter-spacing: .04em;
                    }

                    .vsp-empty {
                        padding: 40px 24px;
                        text-align: center;
                        color: var(--text-muted);
                    }

                    .vsp-empty-icon {
                        font-size: 2.2rem;
                        opacity: .25;
                        margin-bottom: 10px;
                    }

                    .vsp-section-header {
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        padding: 14px 24px 0;
                    }

                    .vsp-count-chip {
                        background: var(--accent-light);
                        color: var(--accent);
                        font-size: .7rem;
                        font-weight: 700;
                        padding: 2px 9px;
                        border-radius: 20px;
                    }
                </style>

                <div class="vsp-section-header">
                    <div class="cm-card-title" style="margin:0;">
                        <i class="bi bi-folder-symlink"></i>&nbsp; Freigegebene Projekte
                    </div>
                    @if (Model.ViewerSharedProjects != null && Model.ViewerSharedProjects.Any())
                    {
                        <span class="vsp-count-chip">@Model.ViewerSharedProjects.Count() Projekte</span>
                    }
                </div>

                @if (Model.ViewerSharedProjects != null && Model.ViewerSharedProjects.Any())
                {
                    <div class="vsp-grid">
                        @foreach (var project in Model.ViewerSharedProjects)
                        {
                            var stateColor = project.State?.Color ?? "#94a3b8";
                            var isArchived = project.IsArchived == true;
                            var hasDateRange = project.StartDate != null && project.EndDate != null;
                            var hasPerson = project.ResponsiblePerson != null;
                            var hasAddress = !string.IsNullOrWhiteSpace(project.City);

                            // Hellere Hintergrundfarbe für das State-Badge (20% Opacity)
                            var badgeBg = stateColor + "28";

                            <div class="vsp-card">
                                @* {{!-- farbiger Top-Balken in der echten State-Farbe --}} *@
                                <div class="vsp-card-top" style="background:@stateColor;"></div>

                                @if (isArchived)
                                {
                                    <div class="vsp-archived-banner">
                                        <i class="bi bi-archive-fill"></i> Archiviert
                                    </div>
                                }

                                <div class="vsp-card-body">

                                    @* {{!-- Projektname + State-Badge --}} *@
                                    <div class="vsp-card-header">
                                        <div class="vsp-project-name">@project.ProjectName</div>
                                        @if (project.State != null)
                                        {
                                            <span class="vsp-state-badge"
                                                  style="background:@badgeBg; color:@stateColor;">
                                                <i class="bi bi-circle-fill" style="font-size:.45rem;"></i>
                                                @project.State.StateName
                                            </span>
                                        }
                                    </div>

                                    @* {{!-- Metadaten --}} *@
                                    <div class="vsp-meta-row">
                                        @if (project.Customer != null)
                                        {
                                            <div class="vsp-meta-item">
                                                <i class="bi bi-building"></i>
                                                <span>@project.Customer.CustomerName</span>
                                            </div>
                                        }
                                        @if (hasPerson)
                                        {
                                            <div class="vsp-meta-item">
                                                <i class="bi bi-person-circle"></i>
                                                <span>@project.ResponsiblePerson!.EmployeeDisplayName</span>
                                            </div>
                                        }
                                        @if (hasAddress)
                                        {
                                            <div class="vsp-meta-item">
                                                <i class="bi bi-geo-alt"></i>
                                                <span>@project.City@(!string.IsNullOrWhiteSpace(project.Country) ? ", " + project.Country : "")</span>
                                            </div>
                                        }
                                    </div>

                                </div>

                                @* {{!-- Footer: Zeitraum + Details-Link --}} *@
                                <div class="vsp-card-footer">
                                    <div class="vsp-date-range">
                                        <i class="bi bi-calendar3" style="font-size:.75rem;"></i>
                                        @if (hasDateRange)
                                        {
                                            @project.StartDate!.Value.ToString("dd.MM.yyyy")
                                            <span class="sep">→</span>
                                            @project.EndDate!.Value.ToString("dd.MM.yyyy")
                                        }
                                        else
                                        {
                                            <span style="opacity:.45;">Kein Zeitraum</span>
                                        }
                                    </div>
                                    <a asp-page="/Projects/Details" asp-route-id="@project.ProjectId"
                                       class="btn-cm btn-cm-ghost btn-cm-sm">
                                        <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="vsp-empty">
                        <div class="vsp-empty-icon"><i class="bi bi-folder-x"></i></div>
                        <div style="font-weight:600; margin-bottom:4px;">Keine freigegebenen Projekte</div>
                        <div style="font-size:.8rem;">Es wurden noch keine Projekte für Sie freigegeben.</div>
                    </div>
                }
            }

        </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:16px;">

        <div class="cm-card">
            <div class="cm-card-title">Status & Aktionen</div>
            @if (!isLocked)
            {
                <form method="post" asp-page-handler="SetDeleteFlag" asp-route-id="@Model.Employee.EmployeeId">
                    <button type="submit" class="btn-cm btn-cm-danger" style="width:100%; justify-content:center;">
                        <i class="bi bi-lock-fill"></i> Mitarbeiter sperren
                    </button>
                </form>
            }
            else
            {
                <form method="post" asp-page-handler="UndoDeleteFlag" asp-route-id="@Model.Employee.EmployeeId">
                    <button type="submit" class="btn-cm btn-cm-success" style="width:100%; justify-content:center;">
                        <i class="bi bi-arrow-counterclockwise"></i> Entsperren
                    </button>
                </form>
            }
        </div>

        <div class="cm-card">
            <div class="cm-card-title">Letzte Änderung</div>
            <div style="display:flex; flex-direction:column; gap:10px; font-size:.85rem;">
                <div>
                    <div style="font-size:.72rem; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.05em; margin-bottom:2px;">Änderer</div>
                    <div>@(Model.Employee.LatestModifier?.EmployeeDisplayName ?? "–")</div>
                </div>
                <div>
                    <div style="font-size:.72rem; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.05em; margin-bottom:2px;">Zeitpunkt</div>
                    <div>@(Model.Employee.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</div>
                </div>
                <div>
                    <div style="font-size:.72rem; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.05em; margin-bottom:2px;">Änderungstext</div>
                    <div style="color:var(--text-muted);">@(Model.Employee.LatestModificationText ?? "–")</div>
                </div>
            </div>
        </div>
    </div>
</div>
