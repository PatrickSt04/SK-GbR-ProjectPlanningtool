@model SAAS_Projectplanningtool.Pages.EmployeeManagement.IndexModel

<div class="card">
    <div class="card-header">
        <h2><i class="bi bi-people-fill me-2"></i>Mitarbeiter</h2>
        <div class="card-actions">
            <a asp-page="./Employees/Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Anlegen
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="cm-toolbar-wrap">
            <div class="cm-toolbar">
                <div class="cm-search-wrap">
                    <i class="bi bi-search"></i>
                    <input type="text" id="empSearch" class="cm-input cm-search"
                           placeholder="Name oder E-Mail suchen…" oninput="filterEmployees()">
                </div>
                <select id="empStatusFilter" class="cm-input cm-select w-auto" onchange="filterEmployees()">
                    <option value="aktiv">Aktive</option>
                    <option value="">Alle</option>
                    <option value="gesperrt">Gesperrte</option>
                </select>
            </div>
        </div>

        <table class="cm-table" id="employeeTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>E-Mail</th>
                    <th>Stundensatzgruppe</th>
                    <th>Rolle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Employee)
                {
                    var isLocked = item.DeleteFlag;
                    <tr data-name="@item.EmployeeDisplayName.ToLower()"
                        data-email="@(item.IdentityUser?.Email?.ToLower() ?? "")"
                        data-status="@(isLocked ? "gesperrt" : "aktiv")">
                        <td>
                            <a class="td-link" asp-page="./Employees/Details" asp-route-id="@item.EmployeeId">
                                @item.EmployeeDisplayName
                            </a>
                            @if (isLocked)
                            {
                                <span class="badge badge-locked badge-inline-sm">
                                    Gesperrt
                                </span>
                            }
                        </td>
                        <td class="cm-text-email">
                            @if (item.IdentityUser != null)
                            {
                                <i class="bi bi-envelope me-1"></i>
                                @item.IdentityUser.Email
                            }
                            else
                            {
                                <span class="cm-text-placeholder">–</span>
                            }
                        </td>
                        <td>
                            @if (item.HourlyRateGroup != null)
                            {
                                <span class="badge">
                                    @item.HourlyRateGroup.HourlyRateGroupName
                                </span>
                            }
                            else
                            {
                                <span class="cm-text-placeholder-sm">–</span>
                            }
                        </td>
                        <td>
                            @if (item.IdentityUser != null && Model.EmployeeRoles.TryGetValue(item.IdentityUser.Id, out var roles))
                            {
                                foreach (var role in roles)
                                {
                                    <span class="badge">
                                        @role
                                    </span>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Employee.Any())
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <p>Noch keine Mitarbeiter vorhanden.</p>
            </div>
        }

        <div class="cm-card-footer">
            <span id="empCount">@Model.Employee.Count</span> Mitarbeiter
        </div>
    </div>
</div>
