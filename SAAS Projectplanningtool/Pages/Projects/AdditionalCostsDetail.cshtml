@page
@using System.Globalization
@model SAAS_Projectplanningtool.Pages.Projects.AdditionalCostsDetailModel

@{
    ViewData["Title"] = "Zusätzliche Kosten - " + Model.Project?.ProjectName;
    <link rel="stylesheet" href="~/css/Budgetplanning.css" />
}

<div class="main-container">
    <div class="page-header">
        <h1>
            <a asp-page="/Projects/BudgetPlanning" asp-route-id="@Model.Project?.ProjectId" class="edit-btn">
                <i class="fas fa-arrow-left"></i>
            </a>
            <span>Zusätzliche Kosten</span>
        </h1>
        <div class="subtitle" style="margin-top: 0.25rem; color: var(--text-secondary); font-size: 0.95rem;">
            @Model.Project?.ProjectName
        </div>
    </div>

    <!-- Zusammenfassung -->
    <div class="budget-overview" style="margin-bottom: 2rem;">
        <div class="budget-card" style="border-top: 4px solid var(--info-color);">
            <div class="budget-card-header">
                <div class="budget-card-title">Gesamtkosten</div>
                <div class="budget-card-icon" style="background: var(--info-color);">
                    <i class="fas fa-receipt"></i>
                </div>
            </div>
            <div class="budget-card-value">@Model.TotalCosts.ToString("C2", new CultureInfo("de-DE"))</div>
            <div class="budget-card-subtitle">@Model.CostEntries.Count Positionen erfasst</div>
        </div>
    </div>

    <!-- Detaillierte Tabelle -->
    <div class="modern-table">
        <div class="card">
            <div class="card-header" style="background: #f0f7fc; border-bottom: 2px solid var(--info-color); color: #2c5f7c;">
                <h5 class="mb-0">
                    <i class="fas fa-receipt me-2"></i>
                    Alle zusätzlichen Kosten
                    <span class="badge bg-light text-dark ms-2">@Model.CostEntries.Count</span>
                </h5>
            </div>
            <div class="card-body p-0">
                @if (Model.CostEntries.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background: #f0f4fa; color: #2c3e6b;"> @* TODO CSS *@
                                <tr>
                                    <th style="background: #f8f9fa !important; color: #495057 !important; font-weight: 600; font-size: 0.85rem; padding: 0.75rem; width: 35%;">Bezeichnung</th>
                                    <th style="background: #f8f9fa !important; color: #495057 !important; font-weight: 600; font-size: 0.85rem; padding: 0.75rem; width: 20%;">Betrag</th>
                                    <th style="background: #f8f9fa !important; color: #495057 !important; font-weight: 600; font-size: 0.85rem; padding: 0.75rem; width: 15%;">Erstellt am</th>
                                    <th style="background: #f8f9fa !important; color: #495057 !important; font-weight: 600; font-size: 0.85rem; padding: 0.75rem; width: 15%;">Erstellt von</th>
                                    <th style="background: #f8f9fa !important; color: #495057 !important; font-weight: 600; font-size: 0.85rem; padding: 0.75rem; width: 15%;">Letzte Änderung</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cost in Model.CostEntries)
                                {
                                    <tr>
                                        <td>
                                            <i class="fas fa-tag me-2" style="color: var(--info-color);"></i>
                                            <strong>@cost.CostName</strong>
                                        </td>
                                        <td>
                                            <span style="font-weight: 700; color: var(--info-color);">
                                                @cost.Amount.ToString("C2", new CultureInfo("de-DE"))
                                            </span>
                                        </td>
                                        <td>
                                            @(cost.CreatedTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(cost.CreatedBy))
                                            {
                                                <span class="badge" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                                    @cost.CreatedBy
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (cost.ModifiedTimestamp.HasValue)
                                            {
                                                <small>
                                                    @cost.ModifiedTimestamp?.ToString("dd.MM.yyyy HH:mm")
                                                    <br />
                                                    <span class="text-muted">von @(cost.ModifiedBy ?? "Unbekannt")</span>
                                                </small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot style="background: var(--light-bg); font-weight: 700;">
                                <tr>
                                    <td class="text-end">Gesamt:</td>
                                    <td style="color: var(--info-color);">@Model.TotalCosts.ToString("C2", new CultureInfo("de-DE"))</td>
                                    <td colspan="3"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-receipt fa-3x mb-3" style="color: var(--text-secondary); opacity: 0.4;"></i>
                        <p class="text-muted">Keine zusätzlichen Kosten für dieses Projekt erfasst.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>