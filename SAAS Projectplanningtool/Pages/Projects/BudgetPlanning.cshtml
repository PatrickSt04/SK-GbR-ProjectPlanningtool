<!-- Modal: Zusätzliche Projektkosten -->
<div class="modal fade" id="addProjectCostsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveProjectCosts">
                <input type="hidden" name="projectId" value="@Model.Project.ProjectId" />
                <div class="modal-header" style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);">
                    <h5 class="modal-title">
                        <i class="fas fa-receipt me-2"></i>
                        Zusätzliche Projektkosten verwalten
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Erfassen Sie hier projektbezogene Kosten, die nicht über Zeitbuchungen abgedeckt werden (z.B. Material, Lizenzen, Reisekosten).
                    </p>
                    <div class="mb-4">
                        <h6 class="text-primary mb-3"><i class="fas fa-list me-2"></i>Erfasste Kosten</h6>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%); color: white;">
                                    <tr>
                                        <th style="width: 45%;">Bezeichnung</th>
                                        <th style="width: 25%;">Kosten (€)</th>
                                        <th style="width: 20%;">Erstellt am</th>
                                        <th style="width: 10%;">Aktion</th>
                                    </tr>
                                </thead>
                                <tbody id="projectCostsTableBody">
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">
                                            <i class="fas fa-info-circle me-2"></i>Keine Kosten vorhanden
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot style="background: var(--light-bg);">
                                    <tr>
                                        <th class="text-end">Gesamtsumme:</th>
                                        <th id="totalProjectCost" colspan="3">0.00 €</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-12">
                            <h6 class="text-primary mb-3"><i class="fas fa-plus-circle me-2"></i>Neue Kosten hinzufügen</h6>
                        </div>
                        <div class="col-md-6">
                            <label for="newCostName" class="form-label">Bezeichnung</label>
                            <input type="text" class="form-control" id="newCostName" placeholder="z.B. Materialkosten">
                        </div>
                        <div class="col-md-4">
                            <label for="newCostAmount" class="form-label">Kosten (€)</label>
                            <input type="number" class="form-control" id="newCostAmount" step="0.01" min="0" placeholder="0.00">
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="modern-btn success w-100" id="addCostBtn">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <div id="hiddenCostsContainer"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Abbrechen
                    </button>
                    <button type="submit" class="modern-btn info">
                        <i class="fas fa-save me-1"></i>Kosten speichern
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>



@functions {
    private void RenderSections(IEnumerable<ProjectSection> sections, int level)
    {
        if (sections == null || !sections.Any()) return;

        foreach (var ps in sections)
        {
            bool hasChildren = (ps.SubSections != null && ps.SubSections.Any()) ||
                               (ps.ProjectTasks != null && ps.ProjectTasks.Any());

            <tr class="section-row">
                <td>
                    @if (hasChildren)
                    {
                        <span class="toggle-icon" onclick="toggleRow('row-@ps.ProjectSectionId', this)" style="margin-left:@(level * 20)px;">
                            <i class="fas fa-plus"></i>
                        </span>
                    }
                    else
                    {
                        <span style="display:inline-block; margin-left:@((level * 20) + 32)px;"></span>
                    }
                    <strong>@ps.ProjectSectionName</strong>
                </td>
                @{
                    var allTasks = GetAllTasks(ps);
                    DateOnly? sectionStart = allTasks.Any() ? allTasks.Min(t => t.StartDate) : null;
                    DateOnly? sectionEnd = allTasks.Any() ? allTasks.Max(t => t.EndDate) : null;
                    int? sectionDuration = (sectionStart.HasValue && sectionEnd.HasValue)
                    ? (sectionEnd.Value.DayNumber - sectionStart.Value.DayNumber + 1) : null;
                }
                <td><i class="fas fa-calendar-alt me-1 text-muted"></i>@(sectionStart?.ToString("dd.MM.yyyy") ?? "Nicht verfügbar")</td>
                <td><i class="fas fa-calendar-check me-1 text-muted"></i>@(sectionEnd?.ToString("dd.MM.yyyy") ?? "Nicht verfügbar")</td>
                <td><i class="fas fa-clock me-1 text-muted"></i>@(sectionDuration?.ToString() ?? "Nicht verfügbar")</td>
                <td>
                    <div class="status-badge" style="background-color:@ps.State?.Color;">
                        @(ps.State?.StateName ?? "Kein Status")
                    </div>
                </td>
            </tr>

            if (hasChildren)
            {
                <tr id="row-@ps.ProjectSectionId" style="display:none">
                    <td colspan="5">
                        <div class="nested-content">
                            @if (ps.ProjectTasks != null && ps.ProjectTasks.Any())
                            {
                                <div class="task-table">
                                    <table class="table table-sm mb-0">
                                        <thead>
                                            <tr>
                                                <th><i class="fas fa-tasks me-1"></i>Aufgabe</th>
                                                <th><i class="fas fa-calendar-alt me-1"></i>Start</th>
                                                <th><i class="fas fa-calendar-check me-1"></i>Ende</th>
                                                <th><i class="fas fa-clock me-1"></i>Dauer</th>
                                                <th><i class="fas fa-clock me-1"></i>AT</th>
                                                <th><i class="fas fa-clock me-1"></i>AS</th>
                                                <th><i class="fas fa-tasks me-1"></i>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var task in ps.ProjectTasks)
                                            {
                                                int? dauer = null;
                                                if (task.StartDate.HasValue && task.EndDate.HasValue)
                                                {
                                                    var start = task.StartDate.Value.ToDateTime(TimeOnly.MinValue);
                                                    var end = task.EndDate.Value.ToDateTime(TimeOnly.MinValue);
                                                    dauer = (end - start).Days + 1;
                                                }
                                                <tr>
                                                    <td><strong>@task.ProjectTaskName</strong></td>
                                                    <td>@task.StartDate?.ToString("dd.MM.yyyy")</td>
                                                    <td>@task.EndDate?.ToString("dd.MM.yyyy")</td>
                                                    <td>@(dauer.HasValue ? dauer.ToString() : "N/A") d</td>
                                                    <td>@task.DurationInDays AT</td>
                                                    <td>@task.DurationInHours Std.</td>
                                                    <td>
                                                        @if (task.State != null)
                                                        {
                                                            <div class="status-badge" style="background-color: @task.State.Color;">@task.State.StateName</div>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted"><em>Kein Status</em></span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted py-3">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <em>Keine Aufgaben vorhanden</em>
                                </div>
                            }

                            @if (ps.SubSections != null && ps.SubSections.Any())
                            {
                                <div class="mt-3">
                                    <div class="modern-table">
                                        <table class="table">
                                            <tbody>
                                                @{
                                                    RenderSections(ps.SubSections, level + 1);
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
    }

    private List<ProjectTask> GetAllTasks(ProjectSection section)
    {
        var tasks = new List<ProjectTask>();
        if (section.ProjectTasks != null) tasks.AddRange(section.ProjectTasks);
        if (section.SubSections != null)
            foreach (var sub in section.SubSections)
                tasks.AddRange(GetAllTasks(sub));
        return tasks;
    }
}

<script>
    // ====== CONFIGURATION ======
    const PROJECT_ID = '@Model.Project.ProjectId';

    // ====== BUDGET STATISTIKEN ======
    document.addEventListener('DOMContentLoaded', loadBudgetStatistics);
    document.addEventListener('DOMContentLoaded', loadProjectCosts);
    document.addEventListener('DOMContentLoaded', initializeBudgetPlanning);

    async function loadBudgetStatistics() {
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=BudgetStatistics&projectId=${PROJECT_ID}`);
            const statistics = await response.json();
            updateDashboard(statistics);
        } catch (error) {
            console.error('Fehler beim Laden der Budget-Statistiken:', error);
        }
    }

    function updateDashboard(stats) {
        if (!stats) return;
        const el = id => document.getElementById(id);
        if (el('projectName')) el('projectName').textContent = stats.projectName;
        updateBudgetCards(stats);
        updateTaskStatistics(stats);
        updateTopSections(stats.topCostSections);

        const recalculationBtn = el('recalculationBtn');
        if (recalculationBtn) {
            recalculationBtn.style.display = stats.recalculationNeeded ? 'block' : 'none';
        }
    }

    function updateBudgetCards(stats) {
        const cards = document.querySelectorAll('.budget-card-value');
        if (cards.length >= 3) {
            cards[1].textContent = '€' + stats.usedBudget.toLocaleString('de-DE', { minimumFractionDigits: 2 });
            cards[2].textContent = '€' + stats.remainingBudget.toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }

        const statusBadge = document.getElementById('project_budget_state');
        if (statusBadge) {
            const statusMap = {
                0: { text: "Unbekannt", cls: "on-track", icon: "fa-check-circle" },
                1: { text: "Ausreichend", cls: "on-track", icon: "fa-check-circle" },
                2: { text: "Warnung", cls: "warning", icon: "fa-exclamation-triangle" },
                3: { text: "Kritisch", cls: "critical", icon: "fa-times-circle" },
                4: { text: "Überschritten", cls: "exceeded", icon: "fa-ban" }
            };
            const status = statusMap[stats.budgetStatus] || statusMap[0];
            statusBadge.className = `status-badge ${status.cls}`;
            statusBadge.innerHTML = `<i class="fas ${status.icon}"></i> ${status.text}`;
        }

        const progressBar = document.querySelector('.budget-progress-bar.success');
        const progressText = document.querySelector('.budget-progress-text');
        if (progressBar && progressText) {
            progressBar.style.width = stats.utilizationPercentage + '%';
            progressText.textContent = stats.utilizationPercentage.toFixed(2) + '%';
        }

        const timeEntryCostsValue = document.getElementById('timeEntryCostsValue');
        const timeEntryCostsSubtitle = document.getElementById('timeEntryCostsSubtitle');
        const timeEntryCostsProgressBar = document.getElementById('timeEntryCostsProgressBar');
        if (timeEntryCostsValue) {
            timeEntryCostsValue.textContent = '€' + (stats.usedBudgetFromTimeEntries || 0).toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }
        if (timeEntryCostsSubtitle) timeEntryCostsSubtitle.textContent = 'Aus Zeitbuchungen';
        if (timeEntryCostsProgressBar && stats.initialBudget > 0) {
            const pct = ((stats.usedBudgetFromTimeEntries || 0) / stats.initialBudget) * 100;
            timeEntryCostsProgressBar.style.width = pct.toFixed(2) + '%';
        }

        loadTimeTrackingBreakdown();

        const additionalCostsValue = document.getElementById('additionalCostsValue');
        const additionalCostsSubtitle = document.getElementById('additionalCostsSubtitle');
        const additionalCostsProgressBar = document.getElementById('additionalCostsProgressBar');
        if (additionalCostsValue) {
            additionalCostsValue.textContent = '€' + stats.additionalCosts.toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }
        if (additionalCostsSubtitle && stats.additionalCostBreakdown) {
            const count = stats.additionalCostBreakdown.itemCount;
            additionalCostsSubtitle.textContent = count > 0 ? `${count} Position${count !== 1 ? 'en' : ''} erfasst` : 'Material & Sonstiges';
        }
        if (additionalCostsProgressBar && stats.initialBudget > 0) {
            const pct = (stats.additionalCosts / stats.initialBudget) * 100;
            additionalCostsProgressBar.style.width = pct.toFixed(2) + '%';
        }
    }

    async function loadTimeTrackingBreakdown() {
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=TimeTrackingBreakdown&projectId=${PROJECT_ID}`);
            if (!response.ok) return;
            const breakdown = await response.json();
            renderTimeTrackingBreakdown(breakdown);
        } catch (err) {
            console.error('Fehler beim Laden der Zeitbuchungsaufschlüsselung:', err);
        }
    }

    function renderTimeTrackingBreakdown(breakdown) {
        const container = document.getElementById('timeEntryBreakdownList');
        const itemsContainer = document.getElementById('timeEntryBreakdownItems');
        if (!container || !itemsContainer) return;
        if (!breakdown || breakdown.length === 0) { container.style.display = 'none'; return; }
        const totalCosts = breakdown.reduce((sum, b) => sum + b.totalCosts, 0);
        itemsContainer.innerHTML = breakdown.map(item => {
            const pct = totalCosts > 0 ? (item.totalCosts / totalCosts) * 100 : 0;
            return `<div style="margin-bottom:0.6rem;">
                <div style="display:flex;justify-content:space-between;align-items:center;font-size:0.8rem;margin-bottom:0.2rem;">
                    <span style="color:var(--text-primary);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:55%;" title="${item.hourlyRateGroupName}">${item.hourlyRateGroupName}</span>
                    <span style="color:#8e44ad;font-weight:600;white-space:nowrap;">€${item.totalCosts.toLocaleString('de-DE',{minimumFractionDigits:2})}</span>
                </div>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                    <div style="flex:1;height:4px;background:var(--border-color);border-radius:2px;overflow:hidden;">
                        <div style="height:100%;width:${pct.toFixed(1)}%;background:linear-gradient(135deg,#9b59b6 0%,#8e44ad 100%);border-radius:2px;"></div>
                    </div>
                    <span style="font-size:0.7rem;color:var(--text-secondary);white-space:nowrap;min-width:60px;text-align:right;">${item.totalWorkingHours.toLocaleString('de-DE',{minimumFractionDigits:1})} h</span>
                </div></div>`;
        }).join('');
        container.style.display = 'block';
    }

    function updateTaskStatistics(stats) {
        const el = (id) => document.getElementById(id);
        if (el('statTotalTasks')) el('statTotalTasks').textContent = stats.totalTasks ?? '-';
        if (el('statTasksWithDates')) el('statTasksWithDates').textContent = stats.tasksWithDates ?? '-';
        if (el('statTasksWithoutDates')) el('statTasksWithoutDates').textContent = stats.tasksWithoutDates ?? '-';
        if (el('statTimeEntryCosts')) {
            el('statTimeEntryCosts').textContent = '€' + (stats.usedBudgetFromTimeEntries || 0).toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }
    }

    function updateTopSections(topSections) {
        const container = document.getElementById('topSectionsList');
        if (!container) return;
        container.innerHTML = '';
        if (!topSections || topSections.length === 0) {
            container.innerHTML = '<div class="section-item">Keine Daten vorhanden</div>';
            return;
        }
        topSections.forEach(section => {
            container.innerHTML += `<div class="section-item"><div class="section-name">${section.sectionName}</div><div class="section-stats"><span class="section-tasks">${section.taskCount} Tasks</span></div></div>`;
        });
    }

    // ====== TOGGLE ======
    window.toggleRow = function(rowId, iconElem) {
        const row = document.getElementById(rowId);
        if (!row) return;
        const icon = iconElem.querySelector('i');
        if (row.style.display === "none" || row.style.display === "") {
            row.style.display = "table-row";
            icon.className = "fas fa-minus";
        } else {
            row.style.display = "none";
            icon.className = "fas fa-plus";
        }
    };

    // ====== PROJEKTKOSTEN MODAL ======
    let projectCosts = [];

    async function loadProjectCosts() {
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=ReadProjectCosts&projectId=${PROJECT_ID}`);
            if (!response.ok) return;
            const data = await response.json();
            displayProjectCosts(data);
        } catch (err) { console.error(err); }
    }

    function displayProjectCosts(costs) {
        const container = document.getElementById('projectCostsDisplay');
        if (!container) return;
        if (!costs || costs.length === 0) {
            container.innerHTML = `<div class="no-expenses"><i class="fas fa-info-circle me-2"></i><em>Keine zusätzlichen Projektkosten erfasst</em></div>`;
            return;
        }
        let totalCost = 0;
        let html = '';
        costs.forEach(cost => {
            totalCost += cost.additionalCostAmount;
            const createdDate = cost.createdTimestamp ? new Date(cost.createdTimestamp).toLocaleDateString('de-DE') : 'Unbekannt';
            html += `<div class="expense-item"><div class="expense-item-content"><span class="expense-name"><i class="fas fa-tag me-2"></i>${cost.additionalCostName}</span><span class="expense-meta"><i class="fas fa-calendar me-1"></i>${createdDate}</span></div><span class="expense-cost">${cost.additionalCostAmount.toFixed(2)} €</span></div>`;
        });
        html += `<div class="expense-total-card"><span class="expense-total-label"><i class="fas fa-calculator me-2"></i>Gesamte zusätzliche Kosten:</span><span class="expense-total-value">${totalCost.toFixed(2)} €</span></div>`;
        container.innerHTML = html;
    }

    document.getElementById('addProjectCostsModal')?.addEventListener('shown.bs.modal', async function() {
        projectCosts = [];
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=ReadProjectCosts&projectId=${PROJECT_ID}`);
            if (response.ok) {
                const data = await response.json();
                projectCosts = data.map(c => ({ id: c.projectAdditionalCostsId, name: c.additionalCostName, amount: c.additionalCostAmount, createdTimestamp: c.createdTimestamp, isExisting: true }));
            }
        } catch (err) { console.error(err); }
        updateProjectCostsTable();
        document.getElementById('newCostName').value = '';
        document.getElementById('newCostAmount').value = '';
    });

    document.getElementById('addProjectCostsModal')?.addEventListener('hidden.bs.modal', () => loadProjectCosts());

    document.getElementById('addCostBtn')?.addEventListener('click', function() {
        const nameInput = document.getElementById('newCostName');
        const amountInput = document.getElementById('newCostAmount');
        const name = nameInput.value.trim();
        const amount = parseFloat(amountInput.value) || 0;
        if (!name || amount <= 0) return;
        projectCosts.push({ id: null, name, amount, createdTimestamp: new Date().toISOString(), isExisting: false });
        updateProjectCostsTable();
        nameInput.value = '';
        amountInput.value = '';
    });

    document.addEventListener('click', function(e) {
        if (e.target.closest('.remove-cost-btn')) {
            const index = parseInt(e.target.closest('.remove-cost-btn').dataset.index);
            projectCosts.splice(index, 1);
            updateProjectCostsTable();
        }
    });

    document.addEventListener('input', function(e) {
        if (e.target.classList.contains('edit-cost-name')) {
            projectCosts[parseInt(e.target.dataset.index)].name = e.target.value.trim();
        } else if (e.target.classList.contains('edit-cost-amount')) {
            projectCosts[parseInt(e.target.dataset.index)].amount = parseFloat(e.target.value) || 0;
            updateProjectCostsTable();
        }
    });

    function updateProjectCostsTable() {
        const tableBody = document.getElementById('projectCostsTableBody');
        const hiddenContainer = document.getElementById('hiddenCostsContainer');
        if (!tableBody || !hiddenContainer) return;
        tableBody.innerHTML = '';
        hiddenContainer.innerHTML = '';
        let totalCost = 0;
        if (projectCosts.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="4" class="text-center text-muted"><i class="fas fa-info-circle me-2"></i>Keine Kosten vorhanden</td></tr>`;
        } else {
            projectCosts.forEach((cost, index) => {
                totalCost += cost.amount;
                const row = document.createElement('tr');
                row.innerHTML = `<td><input type="text" class="form-control edit-cost-name" value="${cost.name}" data-index="${index}" /></td><td><input type="number" class="form-control edit-cost-amount" value="${cost.amount}" step="0.01" min="0" data-index="${index}" /></td><td><small class="text-muted">${cost.createdTimestamp ? new Date(cost.createdTimestamp).toLocaleDateString('de-DE') : 'Neu'}</small></td><td><button type="button" class="btn btn-outline-danger btn-sm remove-cost-btn" data-index="${index}"><i class="fas fa-trash"></i></button></td>`;
                tableBody.appendChild(row);
                if (cost.id) {
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden'; idInput.name = `ProjectCosts[${index}].ProjectAdditionalCostsId`; idInput.value = cost.id;
                    hiddenContainer.appendChild(idInput);
                }
                ['AdditionalCostName', 'AdditionalCostAmount'].forEach((field, fi) => {
                    const inp = document.createElement('input');
                    inp.type = 'hidden'; inp.name = `ProjectCosts[${index}].${field}`; inp.value = fi === 0 ? cost.name : cost.amount;
                    hiddenContainer.appendChild(inp);
                });
            });
        }
        const totalEl = document.getElementById('totalProjectCost');
        if (totalEl) totalEl.textContent = totalCost.toFixed(2) + ' €';
    }

    // ====== EXCEL-LIKE BUDGET PLANNING ======
    // Flat list of rows: each row is either a 'group' header or a 'line' item
    let budgetRows = [];
    let cachedArticles = [];
    let cachedHRGs = [];
    let rowIdCounter = 0;

    async function initializeBudgetPlanning() {
        const container = document.getElementById('budgetRowsContainer');
        if (!container) return;

        // Load articles and HRGs for dropdowns
        try {
            const [articlesRes, hrgsRes] = await Promise.all([
                fetch(`/Projects/BudgetPlanning?handler=SearchArticles`),
                fetch(`/Projects/BudgetPlanning?handler=HourlyRateGroupsJson&projectId=${PROJECT_ID}`)
            ]);
            if (articlesRes.ok) cachedArticles = await articlesRes.json();
            if (hrgsRes.ok) cachedHRGs = await hrgsRes.json();
        } catch (err) { console.error('Error loading dropdown data:', err); }

        // Load existing budget groups and convert to flat rows
        const existingGroups = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExistingBudgetGroups));
        if (existingGroups && existingGroups.length > 0) {
            existingGroups.forEach(g => {
                // Only add group header row if it has a non-empty name (skip default/unnamed groups)
                const isDefaultGroup = !g.groupName || g.groupName.trim() === '';
                if (!isDefaultGroup) {
                    budgetRows.push({
                        rowType: 'group',
                        id: 'r_' + (rowIdCounter++),
                        dbId: g.budgetGroupId,
                        name: g.groupName
                    });
                }
                // Add line items
                g.lineItems.forEach(li => {
                    budgetRows.push({
                        rowType: 'line',
                        id: 'r_' + (rowIdCounter++),
                        dbId: li.budgetLineItemId,
                        lineType: li.lineItemType,
                        articleId: li.articleId,
                        hrgId: li.projectHourlyRateGroupId,
                        description: li.description,
                        quantity: li.quantity,
                        unitPrice: li.unitPrice,
                        adjustedPrice: li.adjustedPrice
                    });
                });
            });
        }

        // Wire up buttons
        document.getElementById('addRowBtn')?.addEventListener('click', () => { addLineRow(); renderBudgetRows(); });
        document.getElementById('addRowFooterBtn')?.addEventListener('click', () => { addLineRow(); renderBudgetRows(); });
        document.getElementById('addGroupBtn')?.addEventListener('click', () => { addGroupRow(); renderBudgetRows(); });
        document.getElementById('saveBudgetBtn')?.addEventListener('click', saveBudgetPlanning);

        renderBudgetRows();
    }

    function addLineRow(afterIndex) {
        const newRow = {
            rowType: 'line',
            id: 'r_' + (rowIdCounter++),
            dbId: null,
            lineType: 2, // FreeText default
            articleId: null,
            hrgId: null,
            description: '',
            quantity: 0,
            unitPrice: 0,
            adjustedPrice: null
        };
        if (afterIndex !== undefined && afterIndex >= 0) {
            budgetRows.splice(afterIndex + 1, 0, newRow);
        } else {
            budgetRows.push(newRow);
        }
        return newRow;
    }

    function addGroupRow(afterIndex) {
        const newRow = {
            rowType: 'group',
            id: 'r_' + (rowIdCounter++),
            dbId: null,
            name: 'Neue Gruppe'
        };
        if (afterIndex !== undefined && afterIndex >= 0) {
            budgetRows.splice(afterIndex + 1, 0, newRow);
        } else {
            budgetRows.push(newRow);
        }
        return newRow;
    }

    function deleteRow(rowId) {
        budgetRows = budgetRows.filter(r => r.id !== rowId);
    }

    function moveRow(rowId, direction) {
        const idx = budgetRows.findIndex(r => r.id === rowId);
        if (idx < 0) return;
        const newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= budgetRows.length) return;
        const temp = budgetRows[idx];
        budgetRows[idx] = budgetRows[newIdx];
        budgetRows[newIdx] = temp;
    }

    function getRowById(rowId) {
        return budgetRows.find(r => r.id === rowId);
    }

    // Calculate subtotal for a group (items between this group header and the next)
    function getGroupSubtotal(groupRowIndex) {
        let total = 0;
        for (let i = groupRowIndex + 1; i < budgetRows.length; i++) {
            if (budgetRows[i].rowType === 'group') break;
            if (budgetRows[i].rowType === 'line') {
                const item = budgetRows[i];
                const calcPrice = item.quantity * item.unitPrice;
                total += (item.adjustedPrice !== null && item.adjustedPrice !== undefined) ? item.adjustedPrice : calcPrice;
            }
        }
        return total;
    }

    function renderBudgetRows() {
        const container = document.getElementById('budgetRowsContainer');
        if (!container) return;

        if (budgetRows.length === 0) {
            container.innerHTML = `<tr><td colspan="8" class="text-center text-muted py-4">
                <i class="fas fa-info-circle me-2"></i>Noch keine Positionen angelegt. Klicken Sie auf "Zeile hinzufügen" oder drücken Sie <kbd>Tab</kbd>/<kbd>Enter</kbd> um zu beginnen.
            </td></tr>`;
            recalculateTotals();
            return;
        }

        let html = '';
        budgetRows.forEach((row, idx) => {
            if (row.rowType === 'group') {
                const subtotal = getGroupSubtotal(idx);
                html += `<tr class="budget-group-row" data-row-id="${row.id}">
                    <td class="budget-row-handle"><i class="fas fa-grip-vertical text-muted"></i></td>
                    <td colspan="5">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fas fa-layer-group text-primary"></i>
                            <input type="text" class="form-control form-control-sm budget-group-name fw-bold"
                                   value="${escapeHtml(row.name)}" data-row-id="${row.id}"
                                   placeholder="Gruppenname" />
                            <span class="badge bg-primary budget-group-subtotal">${formatCurrency(subtotal)}</span>
                        </div>
                    </td>
                    <td colspan="2" class="text-end">
                        <div class="d-flex gap-1 justify-content-end">
                            <button type="button" class="btn btn-outline-success btn-sm insert-row-after-btn" data-row-index="${idx}" title="Zeile danach einfügen">
                                <i class="fas fa-plus"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm move-up-btn" data-row-id="${row.id}" title="Nach oben">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm move-down-btn" data-row-id="${row.id}" title="Nach unten">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm delete-row-btn" data-row-id="${row.id}" title="Löschen">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>`;
            } else {
                // Line item row
                const item = row;
                const calcPrice = item.quantity * item.unitPrice;
                html += renderLineItemRow(item, calcPrice, idx);
            }
        });

        container.innerHTML = html;
        attachBudgetEventListeners();
        recalculateTotals();
    }

    function renderLineItemRow(item, calcPrice, rowIndex) {
        const typeOptions = [
            { value: 0, label: 'Material' },
            { value: 1, label: 'Ressource' },
            { value: 2, label: 'Freitext' }
        ];
        const typeSelect = typeOptions.map(opt =>
            `<option value="${opt.value}" ${item.lineType === opt.value ? 'selected' : ''}>${opt.label}</option>`
        ).join('');

        // Description field based on type
        let descriptionField = '';
        if (item.lineType === 0) {
            const articleOptions = cachedArticles.map(a =>
                `<option value="${a.articleId}" data-price="${a.price}" ${item.articleId === a.articleId ? 'selected' : ''}>${a.articleNumber} - ${escapeHtml(a.articleName)}</option>`
            ).join('');
            descriptionField = `<select class="form-select form-select-sm line-article-select" data-row-id="${item.id}">
                <option value="">-- Artikel wählen --</option>${articleOptions}</select>`;
        } else if (item.lineType === 1) {
            const hrgOptions = cachedHRGs.map(h =>
                `<option value="${h.projectHourlyRateGroupId}" data-rate="${h.hourlyRate}" ${item.hrgId === h.projectHourlyRateGroupId ? 'selected' : ''}>${escapeHtml(h.name)}</option>`
            ).join('');
            descriptionField = `<select class="form-select form-select-sm line-hrg-select" data-row-id="${item.id}">
                <option value="">-- Stundensatzgruppe wählen --</option>${hrgOptions}</select>`;
        } else {
            descriptionField = `<input type="text" class="form-control form-control-sm line-description" data-row-id="${item.id}" value="${escapeHtml(item.description)}" placeholder="Bezeichnung" />`;
        }

        // Unit price: editable for FreeText, read-only for Material/Resource
        const unitPriceField = item.lineType === 2
            ? `<input type="number" class="form-control form-control-sm line-unit-price" data-row-id="${item.id}" value="${item.unitPrice}" step="0.01" min="0" />`
            : `<span class="fw-bold text-success">${formatCurrency(item.unitPrice)}</span>`;

        return `<tr class="budget-line-row" data-row-id="${item.id}">
            <td class="budget-row-handle"><i class="fas fa-grip-vertical text-muted"></i></td>
            <td><select class="form-select form-select-sm line-type-select" data-row-id="${item.id}">${typeSelect}</select></td>
            <td>${descriptionField}</td>
            <td><input type="number" class="form-control form-control-sm line-quantity" data-row-id="${item.id}" value="${item.quantity}" step="0.01" min="0" /></td>
            <td>${unitPriceField}</td>
            <td><span class="fw-bold text-primary line-calc-price">${formatCurrency(calcPrice)}</span></td>
            <td><input type="number" class="form-control form-control-sm line-adjusted-price" data-row-id="${item.id}" value="${item.adjustedPrice !== null && item.adjustedPrice !== undefined ? item.adjustedPrice : ''}" step="0.01" min="0" placeholder="—" /></td>
            <td>
                <div class="d-flex gap-1">
                    <button type="button" class="btn btn-outline-success btn-sm insert-row-after-btn" data-row-index="${rowIndex}" title="Zeile danach einfügen">
                        <i class="fas fa-plus"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm delete-row-btn" data-row-id="${item.id}" title="Löschen">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </td>
        </tr>`;
    }

    function attachBudgetEventListeners() {
        // Delete row (works for both group headers and line items)
        document.querySelectorAll('.delete-row-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                deleteRow(e.currentTarget.dataset.rowId);
                renderBudgetRows();
            });
        });

        // Insert row after
        document.querySelectorAll('.insert-row-after-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                const idx = parseInt(e.currentTarget.dataset.rowIndex);
                addLineRow(idx);
                renderBudgetRows();
            });
        });

        // Move up/down
        document.querySelectorAll('.move-up-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                moveRow(e.currentTarget.dataset.rowId, -1);
                renderBudgetRows();
            });
        });
        document.querySelectorAll('.move-down-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                moveRow(e.currentTarget.dataset.rowId, 1);
                renderBudgetRows();
            });
        });

        // Group name change
        document.querySelectorAll('.budget-group-name').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (row) row.name = e.target.value;
            });
        });

        // Type change → re-render
        document.querySelectorAll('.line-type-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (row) {
                    row.lineType = parseInt(e.target.value);
                    row.articleId = null;
                    row.hrgId = null;
                    row.description = '';
                    row.unitPrice = 0;
                    row.adjustedPrice = null;
                }
                renderBudgetRows();
            });
        });

        // Article selection
        document.querySelectorAll('.line-article-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (!row) return;
                const selected = e.target.options[e.target.selectedIndex];
                row.articleId = e.target.value || null;
                row.description = selected?.text || '';
                row.unitPrice = parseFloat(selected?.dataset.price) || 0;
                recalculateAndUpdateUI();
            });
        });

        // HRG selection
        document.querySelectorAll('.line-hrg-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (!row) return;
                const selected = e.target.options[e.target.selectedIndex];
                row.hrgId = e.target.value || null;
                row.description = selected?.text || '';
                row.unitPrice = parseFloat(selected?.dataset.rate) || 0;
                recalculateAndUpdateUI();
            });
        });

        // FreeText description
        document.querySelectorAll('.line-description').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (row) row.description = e.target.value;
            });
        });

        // Quantity change
        document.querySelectorAll('.line-quantity').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (row) row.quantity = parseFloat(e.target.value) || 0;
                recalculateAndUpdateUI();
            });
        });

        // Unit price change (FreeText only)
        document.querySelectorAll('.line-unit-price').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (row) row.unitPrice = parseFloat(e.target.value) || 0;
                recalculateAndUpdateUI();
            });
        });

        // Adjusted price change
        document.querySelectorAll('.line-adjusted-price').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = getRowById(e.target.dataset.rowId);
                if (row) {
                    const val = e.target.value.trim();
                    row.adjustedPrice = val !== '' ? parseFloat(val) : null;
                }
                recalculateAndUpdateUI();
            });
        });

        // Tab/Enter on last input in last row → auto-add new row
        const lastRow = budgetRows[budgetRows.length - 1];
        if (lastRow && lastRow.rowType === 'line') {
            const lastTr = document.querySelector(`.budget-line-row[data-row-id="${lastRow.id}"]`);
            if (lastTr) {
                const lastInput = lastTr.querySelector('.line-adjusted-price');
                if (lastInput) {
                    lastInput.addEventListener('keydown', (e) => {
                        if (e.key === 'Tab' && !e.shiftKey) {
                            e.preventDefault();
                            addLineRow();
                            renderBudgetRows();
                            // Focus the first input of the new last row
                            setTimeout(() => {
                                const newLastRow = budgetRows[budgetRows.length - 1];
                                const newTr = document.querySelector(`.budget-line-row[data-row-id="${newLastRow.id}"]`);
                                if (newTr) {
                                    const firstInput = newTr.querySelector('select, input');
                                    if (firstInput) firstInput.focus();
                                }
                            }, 50);
                        }
                    });
                }
            }
        }
    }

    function recalculateAndUpdateUI() {
        // Update calculated prices and totals without full re-render
        budgetRows.forEach((row, idx) => {
            if (row.rowType === 'line') {
                const tr = document.querySelector(`.budget-line-row[data-row-id="${row.id}"]`);
                if (!tr) return;
                const calcPrice = row.quantity * row.unitPrice;
                const priceEl = tr.querySelector('.line-calc-price');
                if (priceEl) priceEl.textContent = formatCurrency(calcPrice);
            } else if (row.rowType === 'group') {
                const tr = document.querySelector(`.budget-group-row[data-row-id="${row.id}"]`);
                if (!tr) return;
                const subtotal = getGroupSubtotal(idx);
                const badge = tr.querySelector('.budget-group-subtotal');
                if (badge) badge.textContent = formatCurrency(subtotal);
            }
        });
        recalculateTotals();
    }

    function recalculateTotals() {
        let total = 0;
        budgetRows.forEach(row => {
            if (row.rowType === 'line') {
                const calcPrice = row.quantity * row.unitPrice;
                total += (row.adjustedPrice !== null && row.adjustedPrice !== undefined) ? row.adjustedPrice : calcPrice;
            }
        });
        const el = document.getElementById('totalBudgetDisplay');
        if (el) el.textContent = formatCurrency(total);
    }

    // Convert flat rows to grouped DTOs for saving
    function buildGroupedPayload() {
        const groups = [];
        let currentGroup = null;
        let ungroupedItems = [];

        budgetRows.forEach(row => {
            if (row.rowType === 'group') {
                // Start a new group
                currentGroup = {
                    budgetGroupId: row.dbId || null,
                    groupName: row.name || '',
                    sortOrder: groups.length,
                    lineItems: []
                };
                groups.push(currentGroup);
            } else if (row.rowType === 'line') {
                const lineItem = {
                    budgetLineItemId: row.dbId || null,
                    lineItemType: row.lineType,
                    articleId: row.articleId,
                    projectHourlyRateGroupId: row.hrgId,
                    description: row.description,
                    quantity: row.quantity,
                    unitPrice: row.unitPrice,
                    adjustedPrice: row.adjustedPrice,
                    sortOrder: currentGroup ? currentGroup.lineItems.length : ungroupedItems.length
                };
                if (currentGroup) {
                    currentGroup.lineItems.push(lineItem);
                } else {
                    ungroupedItems.push(lineItem);
                }
            }
        });

        // If there are ungrouped items, put them in a default group with empty name
        if (ungroupedItems.length > 0) {
            groups.unshift({
                budgetGroupId: null,
                groupName: '',
                sortOrder: 0,
                lineItems: ungroupedItems
            });
            // Re-number sort orders
            groups.forEach((g, idx) => g.sortOrder = idx);
        }

        return groups;
    }

    async function saveBudgetPlanning() {
        const btn = document.getElementById('saveBudgetBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Speichern...';

        const payload = buildGroupedPayload();

        try {
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = { 'Content-Type': 'application/json' };
            if (tokenEl) headers['RequestVerificationToken'] = tokenEl.value;

            const response = await fetch(`/Projects/BudgetPlanning?handler=SaveBudgetPlanning&projectId=${PROJECT_ID}`, {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (result.success) {
                showNotification('Budgetplanung erfolgreich gespeichert!', 'success');
                setTimeout(() => window.location.href = `/Projects/Details?id=${PROJECT_ID}`, 1500);
            } else {
                showNotification(result.message || 'Fehler beim Speichern', 'error');
            }
        } catch (err) {
            console.error('Save error:', err);
            showNotification('Fehler beim Speichern der Budgetplanung', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-2"></i>Budget als Auftragsvolumen erfassen';
        }
    }

    // ====== HELPERS ======
    function formatCurrency(value) {
        return (value || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    function showNotification(message, type = 'info') {
        document.querySelectorAll('.custom-notification').forEach(n => n.remove());
        const notification = document.createElement('div');
        notification.className = `custom-notification alert alert-${type === 'success' ? 'success' : type === 'warning' ? 'warning' : type === 'error' ? 'danger' : 'info'}`;
        notification.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;max-width:400px;box-shadow:var(--shadow-lg);border-radius:var(--border-radius);';
        notification.innerHTML = `${message}<button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>`;
        document.body.appendChild(notification);
        setTimeout(() => notification.parentNode && notification.remove(), 4000);
    }

    // ====== AUFTRAGSVOLUMEN TABLE (Dashboard View) ======
    let avBudgetRows = [];
    let avRowIdCounter = 0;
    let avInitialized = false;

    function toggleAuftragsvolumenTable() {
        const section = document.getElementById('auftragsvolumenTableSection');
        if (!section) return;

        if (section.style.display === 'none' || section.style.display === '') {
            section.style.display = 'block';
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
            if (!avInitialized) {
                initializeAuftragsvolumenTable();
            }
        } else {
            section.style.display = 'none';
        }
    }

    async function initializeAuftragsvolumenTable() {
        const container = document.getElementById('avBudgetRowsContainer');
        if (!container) return;

        // Load articles and HRGs for dropdowns (reuse cached if already loaded)
        try {
            if (cachedArticles.length === 0 || cachedHRGs.length === 0) {
                const [articlesRes, hrgsRes] = await Promise.all([
                    fetch(`/Projects/BudgetPlanning?handler=SearchArticles`),
                    fetch(`/Projects/BudgetPlanning?handler=HourlyRateGroupsJson&projectId=${PROJECT_ID}`)
                ]);
                if (articlesRes.ok && cachedArticles.length === 0) cachedArticles = await articlesRes.json();
                if (hrgsRes.ok && cachedHRGs.length === 0) cachedHRGs = await hrgsRes.json();
            }
        } catch (err) { console.error('Error loading dropdown data for AV:', err); }

        // Load existing budget groups via AJAX
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=BudgetGroupsJson&projectId=${PROJECT_ID}`);
            if (response.ok) {
                const existingGroups = await response.json();
                avBudgetRows = [];
                avRowIdCounter = 0;
                if (existingGroups && existingGroups.length > 0) {
                    existingGroups.forEach(g => {
                        const isDefaultGroup = !g.groupName || g.groupName.trim() === '';
                        if (!isDefaultGroup) {
                            avBudgetRows.push({
                                rowType: 'group',
                                id: 'av_' + (avRowIdCounter++),
                                dbId: g.budgetGroupId,
                                name: g.groupName
                            });
                        }
                        g.lineItems.forEach(li => {
                            avBudgetRows.push({
                                rowType: 'line',
                                id: 'av_' + (avRowIdCounter++),
                                dbId: li.budgetLineItemId,
                                lineType: li.lineItemType,
                                articleId: li.articleId,
                                hrgId: li.projectHourlyRateGroupId,
                                description: li.description,
                                quantity: li.quantity,
                                unitPrice: li.unitPrice,
                                adjustedPrice: li.adjustedPrice
                            });
                        });
                    });
                }
            }
        } catch (err) { console.error('Error loading budget groups for AV:', err); }

        // Wire up buttons
        document.getElementById('avAddRowBtn')?.addEventListener('click', () => { avAddLineRow(); avRenderBudgetRows(); });
        document.getElementById('avAddRowFooterBtn')?.addEventListener('click', () => { avAddLineRow(); avRenderBudgetRows(); });
        document.getElementById('avAddGroupBtn')?.addEventListener('click', () => { avAddGroupRow(); avRenderBudgetRows(); });
        document.getElementById('avSaveBudgetBtn')?.addEventListener('click', avSaveBudgetPlanning);

        avInitialized = true;
        avRenderBudgetRows();
    }

    function avAddLineRow(afterIndex) {
        const newRow = {
            rowType: 'line',
            id: 'av_' + (avRowIdCounter++),
            dbId: null,
            lineType: 2,
            articleId: null,
            hrgId: null,
            description: '',
            quantity: 0,
            unitPrice: 0,
            adjustedPrice: null
        };
        if (afterIndex !== undefined && afterIndex >= 0) {
            avBudgetRows.splice(afterIndex + 1, 0, newRow);
        } else {
            avBudgetRows.push(newRow);
        }
        return newRow;
    }

    function avAddGroupRow(afterIndex) {
        const newRow = {
            rowType: 'group',
            id: 'av_' + (avRowIdCounter++),
            dbId: null,
            name: 'Neue Gruppe'
        };
        if (afterIndex !== undefined && afterIndex >= 0) {
            avBudgetRows.splice(afterIndex + 1, 0, newRow);
        } else {
            avBudgetRows.push(newRow);
        }
        return newRow;
    }

    function avDeleteRow(rowId) {
        avBudgetRows = avBudgetRows.filter(r => r.id !== rowId);
    }

    function avMoveRow(rowId, direction) {
        const idx = avBudgetRows.findIndex(r => r.id === rowId);
        if (idx < 0) return;
        const newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= avBudgetRows.length) return;
        const temp = avBudgetRows[idx];
        avBudgetRows[idx] = avBudgetRows[newIdx];
        avBudgetRows[newIdx] = temp;
    }

    function avGetRowById(rowId) {
        return avBudgetRows.find(r => r.id === rowId);
    }

    function avGetGroupSubtotal(groupRowIndex) {
        let total = 0;
        for (let i = groupRowIndex + 1; i < avBudgetRows.length; i++) {
            if (avBudgetRows[i].rowType === 'group') break;
            if (avBudgetRows[i].rowType === 'line') {
                const item = avBudgetRows[i];
                const calcPrice = item.quantity * item.unitPrice;
                total += (item.adjustedPrice !== null && item.adjustedPrice !== undefined) ? item.adjustedPrice : calcPrice;
            }
        }
        return total;
    }

    function avRenderBudgetRows() {
        const container = document.getElementById('avBudgetRowsContainer');
        if (!container) return;

        if (avBudgetRows.length === 0) {
            container.innerHTML = `<tr><td colspan="8" class="text-center text-muted py-4">
                <i class="fas fa-info-circle me-2"></i>Noch keine Positionen angelegt. Klicken Sie auf "Zeile hinzufügen" um zu beginnen.
            </td></tr>`;
            avRecalculateTotals();
            return;
        }

        let html = '';
        avBudgetRows.forEach((row, idx) => {
            if (row.rowType === 'group') {
                const subtotal = avGetGroupSubtotal(idx);
                html += `<tr class="budget-group-row av-budget-group-row" data-row-id="${row.id}">
                    <td class="budget-row-handle"><i class="fas fa-grip-vertical text-muted"></i></td>
                    <td colspan="5">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fas fa-layer-group text-primary"></i>
                            <input type="text" class="form-control form-control-sm av-budget-group-name fw-bold"
                                   value="${escapeHtml(row.name)}" data-row-id="${row.id}"
                                   placeholder="Gruppenname" />
                            <span class="badge bg-primary av-budget-group-subtotal">${formatCurrency(subtotal)}</span>
                        </div>
                    </td>
                    <td colspan="2" class="text-end">
                        <div class="d-flex gap-1 justify-content-end">
                            <button type="button" class="btn btn-outline-success btn-sm av-insert-row-after-btn" data-row-index="${idx}" title="Zeile danach einfügen">
                                <i class="fas fa-plus"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm av-move-up-btn" data-row-id="${row.id}" title="Nach oben">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm av-move-down-btn" data-row-id="${row.id}" title="Nach unten">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm av-delete-row-btn" data-row-id="${row.id}" title="Löschen">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>`;
            } else {
                const item = row;
                const calcPrice = item.quantity * item.unitPrice;
                html += avRenderLineItemRow(item, calcPrice, idx);
            }
        });

        container.innerHTML = html;
        avAttachEventListeners();
        avRecalculateTotals();
    }

    function avRenderLineItemRow(item, calcPrice, rowIndex) {
        const typeOptions = [
            { value: 0, label: 'Material' },
            { value: 1, label: 'Ressource' },
            { value: 2, label: 'Freitext' }
        ];
        const typeSelect = typeOptions.map(opt =>
            `<option value="${opt.value}" ${item.lineType === opt.value ? 'selected' : ''}>${opt.label}</option>`
        ).join('');

        let descriptionField = '';
        if (item.lineType === 0) {
            const articleOptions = cachedArticles.map(a =>
                `<option value="${a.articleId}" data-price="${a.price}" ${item.articleId === a.articleId ? 'selected' : ''}>${a.articleNumber} - ${escapeHtml(a.articleName)}</option>`
            ).join('');
            descriptionField = `<select class="form-select form-select-sm av-line-article-select" data-row-id="${item.id}">
                <option value="">-- Artikel wählen --</option>${articleOptions}</select>`;
        } else if (item.lineType === 1) {
            const hrgOptions = cachedHRGs.map(h =>
                `<option value="${h.projectHourlyRateGroupId}" data-rate="${h.hourlyRate}" ${item.hrgId === h.projectHourlyRateGroupId ? 'selected' : ''}>${escapeHtml(h.name)}</option>`
            ).join('');
            descriptionField = `<select class="form-select form-select-sm av-line-hrg-select" data-row-id="${item.id}">
                <option value="">-- Stundensatzgruppe wählen --</option>${hrgOptions}</select>`;
        } else {
            descriptionField = `<input type="text" class="form-control form-control-sm av-line-description" data-row-id="${item.id}" value="${escapeHtml(item.description)}" placeholder="Bezeichnung" />`;
        }

        const unitPriceField = item.lineType === 2
            ? `<input type="number" class="form-control form-control-sm av-line-unit-price" data-row-id="${item.id}" value="${item.unitPrice}" step="0.01" min="0" />`
            : `<span class="fw-bold text-success">${formatCurrency(item.unitPrice)}</span>`;

        return `<tr class="budget-line-row av-budget-line-row" data-row-id="${item.id}">
            <td class="budget-row-handle"><i class="fas fa-grip-vertical text-muted"></i></td>
            <td><select class="form-select form-select-sm av-line-type-select" data-row-id="${item.id}">${typeSelect}</select></td>
            <td>${descriptionField}</td>
            <td><input type="number" class="form-control form-control-sm av-line-quantity" data-row-id="${item.id}" value="${item.quantity}" step="0.01" min="0" /></td>
            <td>${unitPriceField}</td>
            <td><span class="fw-bold text-primary av-line-calc-price">${formatCurrency(calcPrice)}</span></td>
            <td><input type="number" class="form-control form-control-sm av-line-adjusted-price" data-row-id="${item.id}" value="${item.adjustedPrice !== null && item.adjustedPrice !== undefined ? item.adjustedPrice : ''}" step="0.01" min="0" placeholder="—" /></td>
            <td>
                <div class="d-flex gap-1">
                    <button type="button" class="btn btn-outline-success btn-sm av-insert-row-after-btn" data-row-index="${rowIndex}" title="Zeile danach einfügen">
                        <i class="fas fa-plus"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm av-delete-row-btn" data-row-id="${item.id}" title="Löschen">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </td>
        </tr>`;
    }

    function avAttachEventListeners() {
        document.querySelectorAll('.av-delete-row-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                avDeleteRow(e.currentTarget.dataset.rowId);
                avRenderBudgetRows();
            });
        });

        document.querySelectorAll('.av-insert-row-after-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                const idx = parseInt(e.currentTarget.dataset.rowIndex);
                avAddLineRow(idx);
                avRenderBudgetRows();
            });
        });

        document.querySelectorAll('.av-move-up-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                avMoveRow(e.currentTarget.dataset.rowId, -1);
                avRenderBudgetRows();
            });
        });
        document.querySelectorAll('.av-move-down-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                avMoveRow(e.currentTarget.dataset.rowId, 1);
                avRenderBudgetRows();
            });
        });

        document.querySelectorAll('.av-budget-group-name').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (row) row.name = e.target.value;
            });
        });

        document.querySelectorAll('.av-line-type-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (row) {
                    row.lineType = parseInt(e.target.value);
                    row.articleId = null;
                    row.hrgId = null;
                    row.description = '';
                    row.unitPrice = 0;
                    row.adjustedPrice = null;
                }
                avRenderBudgetRows();
            });
        });

        document.querySelectorAll('.av-line-article-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (!row) return;
                const selected = e.target.options[e.target.selectedIndex];
                row.articleId = e.target.value ? e.target.value : null;
                row.description = selected?.text || '';
                row.unitPrice = parseFloat(selected?.dataset.price) || 0;
                avRecalculateAndUpdateUI();
            });
        });

        document.querySelectorAll('.av-line-hrg-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (!row) return;
                const selected = e.target.options[e.target.selectedIndex];
                row.hrgId = e.target.value ? e.target.value : null;
                row.description = selected?.text || '';
                row.unitPrice = parseFloat(selected?.dataset.rate) || 0;
                avRecalculateAndUpdateUI();
            });
        });

        document.querySelectorAll('.av-line-description').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (row) row.description = e.target.value;
            });
        });

        document.querySelectorAll('.av-line-quantity').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (row) row.quantity = parseFloat(e.target.value) || 0;
                avRecalculateAndUpdateUI();
            });
        });

        document.querySelectorAll('.av-line-unit-price').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (row) row.unitPrice = parseFloat(e.target.value) || 0;
                avRecalculateAndUpdateUI();
            });
        });

        document.querySelectorAll('.av-line-adjusted-price').forEach(el => {
            el.addEventListener('input', (e) => {
                const row = avGetRowById(e.target.dataset.rowId);
                if (row) {
                    const val = e.target.value.trim();
                    row.adjustedPrice = val !== '' ? parseFloat(val) : null;
                }
                avRecalculateAndUpdateUI();
            });
        });

        // Tab/Enter on last input in last row → auto-add new row
        const lastRow = avBudgetRows[avBudgetRows.length - 1];
        if (lastRow && lastRow.rowType === 'line') {
            const lastTr = document.querySelector(`.av-budget-line-row[data-row-id="${lastRow.id}"]`);
            if (lastTr) {
                const lastInput = lastTr.querySelector('.av-line-adjusted-price');
                if (lastInput) {
                    lastInput.addEventListener('keydown', (e) => {
                        if (e.key === 'Tab' && !e.shiftKey) {
                            e.preventDefault();
                            avAddLineRow();
                            avRenderBudgetRows();
                            setTimeout(() => {
                                const newLastRow = avBudgetRows[avBudgetRows.length - 1];
                                const newTr = document.querySelector(`.av-budget-line-row[data-row-id="${newLastRow.id}"]`);
                                if (newTr) {
                                    const firstInput = newTr.querySelector('select, input');
                                    if (firstInput) firstInput.focus();
                                }
                            }, 50);
                        }
                    });
                }
            }
        }
    }

    function avRecalculateAndUpdateUI() {
        avBudgetRows.forEach((row, idx) => {
            if (row.rowType === 'line') {
                const tr = document.querySelector(`.av-budget-line-row[data-row-id="${row.id}"]`);
                if (!tr) return;
                const calcPrice = row.quantity * row.unitPrice;
                const priceEl = tr.querySelector('.av-line-calc-price');
                if (priceEl) priceEl.textContent = formatCurrency(calcPrice);
            } else if (row.rowType === 'group') {
                const tr = document.querySelector(`.av-budget-group-row[data-row-id="${row.id}"]`);
                if (!tr) return;
                const subtotal = avGetGroupSubtotal(idx);
                const badge = tr.querySelector('.av-budget-group-subtotal');
                if (badge) badge.textContent = formatCurrency(subtotal);
            }
        });
        avRecalculateTotals();
    }

    function avRecalculateTotals() {
        let total = 0;
        avBudgetRows.forEach(row => {
            if (row.rowType === 'line') {
                const calcPrice = row.quantity * row.unitPrice;
                total += (row.adjustedPrice !== null && row.adjustedPrice !== undefined) ? row.adjustedPrice : calcPrice;
            }
        });
        const el = document.getElementById('avTotalBudgetDisplay');
        if (el) el.textContent = formatCurrency(total);
    }

    function avBuildGroupedPayload() {
        const groups = [];
        let currentGroup = null;
        let ungroupedItems = [];

        avBudgetRows.forEach(row => {
            if (row.rowType === 'group') {
                currentGroup = {
                    budgetGroupId: row.dbId || null,
                    groupName: row.name || '',
                    sortOrder: groups.length,
                    lineItems: []
                };
                groups.push(currentGroup);
            } else if (row.rowType === 'line') {
                const lineItem = {
                    budgetLineItemId: row.dbId || null,
                    lineItemType: row.lineType,
                    articleId: row.articleId,
                    projectHourlyRateGroupId: row.hrgId,
                    description: row.description,
                    quantity: row.quantity,
                    unitPrice: row.unitPrice,
                    adjustedPrice: row.adjustedPrice,
                    sortOrder: currentGroup ? currentGroup.lineItems.length : ungroupedItems.length
                };
                if (currentGroup) {
                    currentGroup.lineItems.push(lineItem);
                } else {
                    ungroupedItems.push(lineItem);
                }
            }
        });

        if (ungroupedItems.length > 0) {
            groups.unshift({
                budgetGroupId: null,
                groupName: '',
                sortOrder: 0,
                lineItems: ungroupedItems
            });
            groups.forEach((g, idx) => g.sortOrder = idx);
        }

        return groups;
    }

    async function avSaveBudgetPlanning() {
        const btn = document.getElementById('avSaveBudgetBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Speichern...';

        const payload = avBuildGroupedPayload();

        try {
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = { 'Content-Type': 'application/json' };
            if (tokenEl) headers['RequestVerificationToken'] = tokenEl.value;

            const response = await fetch(`/Projects/BudgetPlanning?handler=SaveBudgetPlanning&projectId=${PROJECT_ID}`, {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (result.success) {
                showNotification('Auftragsvolumen erfolgreich gespeichert!', 'success');
                // Reload to update the Auftragsvolumen card and dashboard values
                setTimeout(() => window.location.reload(), 1500);
            } else {
                showNotification(result.message || 'Fehler beim Speichern', 'error');
            }
        } catch (err) {
            console.error('Save error:', err);
            showNotification('Fehler beim Speichern des Auftragsvolumens', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-2"></i>Auftragsvolumen speichern';
        }
    }
</script>