<!-- Modal: Zusätzliche Projektkosten -->
<div class="modal fade" id="addProjectCostsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveProjectCosts">
                <input type="hidden" name="projectId" value="@Model.Project.ProjectId" />
                <div class="modal-header" style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);">
                    <h5 class="modal-title">
                        <i class="fas fa-receipt me-2"></i>
                        Zusätzliche Projektkosten verwalten
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Erfassen Sie hier projektbezogene Kosten, die nicht über Zeitbuchungen abgedeckt werden (z.B. Material, Lizenzen, Reisekosten).
                    </p>
                    <div class="mb-4">
                        <h6 class="text-primary mb-3"><i class="fas fa-list me-2"></i>Erfasste Kosten</h6>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%); color: white;">
                                    <tr>
                                        <th style="width: 45%;">Bezeichnung</th>
                                        <th style="width: 25%;">Kosten (€)</th>
                                        <th style="width: 20%;">Erstellt am</th>
                                        <th style="width: 10%;">Aktion</th>
                                    </tr>
                                </thead>
                                <tbody id="projectCostsTableBody">
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">
                                            <i class="fas fa-info-circle me-2"></i>Keine Kosten vorhanden
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot style="background: var(--light-bg);">
                                    <tr>
                                        <th class="text-end">Gesamtsumme:</th>
                                        <th id="totalProjectCost" colspan="3">0.00 €</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-12">
                            <h6 class="text-primary mb-3"><i class="fas fa-plus-circle me-2"></i>Neue Kosten hinzufügen</h6>
                        </div>
                        <div class="col-md-6">
                            <label for="newCostName" class="form-label">Bezeichnung</label>
                            <input type="text" class="form-control" id="newCostName" placeholder="z.B. Materialkosten">
                        </div>
                        <div class="col-md-4">
                            <label for="newCostAmount" class="form-label">Kosten (€)</label>
                            <input type="number" class="form-control" id="newCostAmount" step="0.01" min="0" placeholder="0.00">
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="modern-btn success w-100" id="addCostBtn">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <div id="hiddenCostsContainer"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Abbrechen
                    </button>
                    <button type="submit" class="modern-btn info">
                        <i class="fas fa-save me-1"></i>Kosten speichern
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>



@functions {
    private void RenderSections(IEnumerable<ProjectSection> sections, int level)
    {
        if (sections == null || !sections.Any()) return;

        foreach (var ps in sections)
        {
            bool hasChildren = (ps.SubSections != null && ps.SubSections.Any()) ||
                               (ps.ProjectTasks != null && ps.ProjectTasks.Any());

            <tr class="section-row">
                <td>
                    @if (hasChildren)
                    {
                        <span class="toggle-icon" onclick="toggleRow('row-@ps.ProjectSectionId', this)" style="margin-left:@(level * 20)px;">
                            <i class="fas fa-plus"></i>
                        </span>
                    }
                    else
                    {
                        <span style="display:inline-block; margin-left:@((level * 20) + 32)px;"></span>
                    }
                    <strong>@ps.ProjectSectionName</strong>
                </td>
                @{
                    var allTasks = GetAllTasks(ps);
                    DateOnly? sectionStart = allTasks.Any() ? allTasks.Min(t => t.StartDate) : null;
                    DateOnly? sectionEnd = allTasks.Any() ? allTasks.Max(t => t.EndDate) : null;
                    int? sectionDuration = (sectionStart.HasValue && sectionEnd.HasValue)
                    ? (sectionEnd.Value.DayNumber - sectionStart.Value.DayNumber + 1) : null;
                }
                <td><i class="fas fa-calendar-alt me-1 text-muted"></i>@(sectionStart?.ToString("dd.MM.yyyy") ?? "Nicht verfügbar")</td>
                <td><i class="fas fa-calendar-check me-1 text-muted"></i>@(sectionEnd?.ToString("dd.MM.yyyy") ?? "Nicht verfügbar")</td>
                <td><i class="fas fa-clock me-1 text-muted"></i>@(sectionDuration?.ToString() ?? "Nicht verfügbar")</td>
                <td>
                    <div class="status-badge" style="background-color:@ps.State?.Color;">
                        @(ps.State?.StateName ?? "Kein Status")
                    </div>
                </td>
            </tr>

            if (hasChildren)
            {
                <tr id="row-@ps.ProjectSectionId" style="display:none">
                    <td colspan="5">
                        <div class="nested-content">
                            @if (ps.ProjectTasks != null && ps.ProjectTasks.Any())
                            {
                                <div class="task-table">
                                    <table class="table table-sm mb-0">
                                        <thead>
                                            <tr>
                                                <th><i class="fas fa-tasks me-1"></i>Aufgabe</th>
                                                <th><i class="fas fa-calendar-alt me-1"></i>Start</th>
                                                <th><i class="fas fa-calendar-check me-1"></i>Ende</th>
                                                <th><i class="fas fa-clock me-1"></i>Dauer</th>
                                                <th><i class="fas fa-clock me-1"></i>AT</th>
                                                <th><i class="fas fa-clock me-1"></i>AS</th>
                                                <th><i class="fas fa-tasks me-1"></i>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var task in ps.ProjectTasks)
                                            {
                                                int? dauer = null;
                                                if (task.StartDate.HasValue && task.EndDate.HasValue)
                                                {
                                                    var start = task.StartDate.Value.ToDateTime(TimeOnly.MinValue);
                                                    var end = task.EndDate.Value.ToDateTime(TimeOnly.MinValue);
                                                    dauer = (end - start).Days + 1;
                                                }
                                                <tr>
                                                    <td><strong>@task.ProjectTaskName</strong></td>
                                                    <td>@task.StartDate?.ToString("dd.MM.yyyy")</td>
                                                    <td>@task.EndDate?.ToString("dd.MM.yyyy")</td>
                                                    <td>@(dauer.HasValue ? dauer.ToString() : "N/A") d</td>
                                                    <td>@task.DurationInDays AT</td>
                                                    <td>@task.DurationInHours Std.</td>
                                                    <td>
                                                        @if (task.State != null)
                                                        {
                                                            <div class="status-badge" style="background-color: @task.State.Color;">@task.State.StateName</div>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted"><em>Kein Status</em></span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted py-3">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <em>Keine Aufgaben vorhanden</em>
                                </div>
                            }

                            @if (ps.SubSections != null && ps.SubSections.Any())
                            {
                                <div class="mt-3">
                                    <div class="modern-table">
                                        <table class="table">
                                            <tbody>
                                                @{
                                                    RenderSections(ps.SubSections, level + 1);
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
    }

    private List<ProjectTask> GetAllTasks(ProjectSection section)
    {
        var tasks = new List<ProjectTask>();
        if (section.ProjectTasks != null) tasks.AddRange(section.ProjectTasks);
        if (section.SubSections != null)
            foreach (var sub in section.SubSections)
                tasks.AddRange(GetAllTasks(sub));
        return tasks;
    }
}

<script>
    // ====== CONFIGURATION ======
    const PROJECT_ID = '@Model.Project.ProjectId';

    // ====== BUDGET STATISTIKEN ======
    document.addEventListener('DOMContentLoaded', loadBudgetStatistics);
    document.addEventListener('DOMContentLoaded', loadProjectCosts);
    document.addEventListener('DOMContentLoaded', initializeBudgetPlanning);

    async function loadBudgetStatistics() {
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=BudgetStatistics&projectId=${PROJECT_ID}`);
            const statistics = await response.json();
            updateDashboard(statistics);
        } catch (error) {
            console.error('Fehler beim Laden der Budget-Statistiken:', error);
        }
    }

    function updateDashboard(stats) {
        if (!stats) return;
        const el = id => document.getElementById(id);
        if (el('projectName')) el('projectName').textContent = stats.projectName;
        updateBudgetCards(stats);
        updateTaskStatistics(stats);
        updateTopSections(stats.topCostSections);

        const recalculationBtn = el('recalculationBtn');
        if (recalculationBtn) {
            recalculationBtn.style.display = stats.recalculationNeeded ? 'block' : 'none';
        }
    }

    function updateBudgetCards(stats) {
        const cards = document.querySelectorAll('.budget-card-value');
        if (cards.length >= 3) {
            cards[1].textContent = '€' + stats.usedBudget.toLocaleString('de-DE', { minimumFractionDigits: 2 });
            cards[2].textContent = '€' + stats.remainingBudget.toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }

        const statusBadge = document.getElementById('project_budget_state');
        if (statusBadge) {
            const statusMap = {
                0: { text: "Unbekannt", cls: "on-track", icon: "fa-check-circle" },
                1: { text: "Ausreichend", cls: "on-track", icon: "fa-check-circle" },
                2: { text: "Warnung", cls: "warning", icon: "fa-exclamation-triangle" },
                3: { text: "Kritisch", cls: "critical", icon: "fa-times-circle" },
                4: { text: "Überschritten", cls: "exceeded", icon: "fa-ban" }
            };
            const status = statusMap[stats.budgetStatus] || statusMap[0];
            statusBadge.className = `status-badge ${status.cls}`;
            statusBadge.innerHTML = `<i class="fas ${status.icon}"></i> ${status.text}`;
        }

        const progressBar = document.querySelector('.budget-progress-bar.success');
        const progressText = document.querySelector('.budget-progress-text');
        if (progressBar && progressText) {
            progressBar.style.width = stats.utilizationPercentage + '%';
            progressText.textContent = stats.utilizationPercentage.toFixed(2) + '%';
        }

        const timeEntryCostsValue = document.getElementById('timeEntryCostsValue');
        const timeEntryCostsSubtitle = document.getElementById('timeEntryCostsSubtitle');
        const timeEntryCostsProgressBar = document.getElementById('timeEntryCostsProgressBar');
        if (timeEntryCostsValue) {
            timeEntryCostsValue.textContent = '€' + (stats.usedBudgetFromTimeEntries || 0).toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }
        if (timeEntryCostsSubtitle) timeEntryCostsSubtitle.textContent = 'Aus Zeitbuchungen';
        if (timeEntryCostsProgressBar && stats.initialBudget > 0) {
            const pct = ((stats.usedBudgetFromTimeEntries || 0) / stats.initialBudget) * 100;
            timeEntryCostsProgressBar.style.width = pct.toFixed(2) + '%';
        }

        loadTimeTrackingBreakdown();

        const additionalCostsValue = document.getElementById('additionalCostsValue');
        const additionalCostsSubtitle = document.getElementById('additionalCostsSubtitle');
        const additionalCostsProgressBar = document.getElementById('additionalCostsProgressBar');
        if (additionalCostsValue) {
            additionalCostsValue.textContent = '€' + stats.additionalCosts.toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }
        if (additionalCostsSubtitle && stats.additionalCostBreakdown) {
            const count = stats.additionalCostBreakdown.itemCount;
            additionalCostsSubtitle.textContent = count > 0 ? `${count} Position${count !== 1 ? 'en' : ''} erfasst` : 'Material & Sonstiges';
        }
        if (additionalCostsProgressBar && stats.initialBudget > 0) {
            const pct = (stats.additionalCosts / stats.initialBudget) * 100;
            additionalCostsProgressBar.style.width = pct.toFixed(2) + '%';
        }
    }

    async function loadTimeTrackingBreakdown() {
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=TimeTrackingBreakdown&projectId=${PROJECT_ID}`);
            if (!response.ok) return;
            const breakdown = await response.json();
            renderTimeTrackingBreakdown(breakdown);
        } catch (err) {
            console.error('Fehler beim Laden der Zeitbuchungsaufschlüsselung:', err);
        }
    }

    function renderTimeTrackingBreakdown(breakdown) {
        const container = document.getElementById('timeEntryBreakdownList');
        const itemsContainer = document.getElementById('timeEntryBreakdownItems');
        if (!container || !itemsContainer) return;
        if (!breakdown || breakdown.length === 0) { container.style.display = 'none'; return; }
        const totalCosts = breakdown.reduce((sum, b) => sum + b.totalCosts, 0);
        itemsContainer.innerHTML = breakdown.map(item => {
            const pct = totalCosts > 0 ? (item.totalCosts / totalCosts) * 100 : 0;
            return `<div style="margin-bottom:0.6rem;">
                <div style="display:flex;justify-content:space-between;align-items:center;font-size:0.8rem;margin-bottom:0.2rem;">
                    <span style="color:var(--text-primary);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:55%;" title="${item.hourlyRateGroupName}">${item.hourlyRateGroupName}</span>
                    <span style="color:#8e44ad;font-weight:600;white-space:nowrap;">€${item.totalCosts.toLocaleString('de-DE',{minimumFractionDigits:2})}</span>
                </div>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                    <div style="flex:1;height:4px;background:var(--border-color);border-radius:2px;overflow:hidden;">
                        <div style="height:100%;width:${pct.toFixed(1)}%;background:linear-gradient(135deg,#9b59b6 0%,#8e44ad 100%);border-radius:2px;"></div>
                    </div>
                    <span style="font-size:0.7rem;color:var(--text-secondary);white-space:nowrap;min-width:60px;text-align:right;">${item.totalWorkingHours.toLocaleString('de-DE',{minimumFractionDigits:1})} h</span>
                </div></div>`;
        }).join('');
        container.style.display = 'block';
    }

    function updateTaskStatistics(stats) {
        const el = (id) => document.getElementById(id);
        if (el('statTotalTasks')) el('statTotalTasks').textContent = stats.totalTasks ?? '-';
        if (el('statTasksWithDates')) el('statTasksWithDates').textContent = stats.tasksWithDates ?? '-';
        if (el('statTasksWithoutDates')) el('statTasksWithoutDates').textContent = stats.tasksWithoutDates ?? '-';
        if (el('statTimeEntryCosts')) {
            el('statTimeEntryCosts').textContent = '€' + (stats.usedBudgetFromTimeEntries || 0).toLocaleString('de-DE', { minimumFractionDigits: 2 });
        }
    }

    function updateTopSections(topSections) {
        const container = document.getElementById('topSectionsList');
        if (!container) return;
        container.innerHTML = '';
        if (!topSections || topSections.length === 0) {
            container.innerHTML = '<div class="section-item">Keine Daten vorhanden</div>';
            return;
        }
        topSections.forEach(section => {
            container.innerHTML += `<div class="section-item"><div class="section-name">${section.sectionName}</div><div class="section-stats"><span class="section-tasks">${section.taskCount} Tasks</span></div></div>`;
        });
    }

    // ====== TOGGLE ======
    window.toggleRow = function(rowId, iconElem) {
        const row = document.getElementById(rowId);
        if (!row) return;
        const icon = iconElem.querySelector('i');
        if (row.style.display === "none" || row.style.display === "") {
            row.style.display = "table-row";
            icon.className = "fas fa-minus";
        } else {
            row.style.display = "none";
            icon.className = "fas fa-plus";
        }
    };

    // ====== PROJEKTKOSTEN MODAL ======
    let projectCosts = [];

    async function loadProjectCosts() {
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=ReadProjectCosts&projectId=${PROJECT_ID}`);
            if (!response.ok) return;
            const data = await response.json();
            displayProjectCosts(data);
        } catch (err) { console.error(err); }
    }

    function displayProjectCosts(costs) {
        const container = document.getElementById('projectCostsDisplay');
        if (!container) return;
        if (!costs || costs.length === 0) {
            container.innerHTML = `<div class="no-expenses"><i class="fas fa-info-circle me-2"></i><em>Keine zusätzlichen Projektkosten erfasst</em></div>`;
            return;
        }
        let totalCost = 0;
        let html = '';
        costs.forEach(cost => {
            totalCost += cost.additionalCostAmount;
            const createdDate = cost.createdTimestamp ? new Date(cost.createdTimestamp).toLocaleDateString('de-DE') : 'Unbekannt';
            html += `<div class="expense-item"><div class="expense-item-content"><span class="expense-name"><i class="fas fa-tag me-2"></i>${cost.additionalCostName}</span><span class="expense-meta"><i class="fas fa-calendar me-1"></i>${createdDate}</span></div><span class="expense-cost">${cost.additionalCostAmount.toFixed(2)} €</span></div>`;
        });
        html += `<div class="expense-total-card"><span class="expense-total-label"><i class="fas fa-calculator me-2"></i>Gesamte zusätzliche Kosten:</span><span class="expense-total-value">${totalCost.toFixed(2)} €</span></div>`;
        container.innerHTML = html;
    }

    document.getElementById('addProjectCostsModal')?.addEventListener('shown.bs.modal', async function() {
        projectCosts = [];
        try {
            const response = await fetch(`/Projects/BudgetPlanning?handler=ReadProjectCosts&projectId=${PROJECT_ID}`);
            if (response.ok) {
                const data = await response.json();
                projectCosts = data.map(c => ({ id: c.projectAdditionalCostsId, name: c.additionalCostName, amount: c.additionalCostAmount, createdTimestamp: c.createdTimestamp, isExisting: true }));
            }
        } catch (err) { console.error(err); }
        updateProjectCostsTable();
        document.getElementById('newCostName').value = '';
        document.getElementById('newCostAmount').value = '';
    });

    document.getElementById('addProjectCostsModal')?.addEventListener('hidden.bs.modal', () => loadProjectCosts());

    document.getElementById('addCostBtn')?.addEventListener('click', function() {
        const nameInput = document.getElementById('newCostName');
        const amountInput = document.getElementById('newCostAmount');
        const name = nameInput.value.trim();
        const amount = parseFloat(amountInput.value) || 0;
        if (!name || amount <= 0) return;
        projectCosts.push({ id: null, name, amount, createdTimestamp: new Date().toISOString(), isExisting: false });
        updateProjectCostsTable();
        nameInput.value = '';
        amountInput.value = '';
    });

    document.addEventListener('click', function(e) {
        if (e.target.closest('.remove-cost-btn')) {
            const index = parseInt(e.target.closest('.remove-cost-btn').dataset.index);
            projectCosts.splice(index, 1);
            updateProjectCostsTable();
        }
    });

    document.addEventListener('input', function(e) {
        if (e.target.classList.contains('edit-cost-name')) {
            projectCosts[parseInt(e.target.dataset.index)].name = e.target.value.trim();
        } else if (e.target.classList.contains('edit-cost-amount')) {
            projectCosts[parseInt(e.target.dataset.index)].amount = parseFloat(e.target.value) || 0;
            updateProjectCostsTable();
        }
    });

    function updateProjectCostsTable() {
        const tableBody = document.getElementById('projectCostsTableBody');
        const hiddenContainer = document.getElementById('hiddenCostsContainer');
        if (!tableBody || !hiddenContainer) return;
        tableBody.innerHTML = '';
        hiddenContainer.innerHTML = '';
        let totalCost = 0;
        if (projectCosts.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="4" class="text-center text-muted"><i class="fas fa-info-circle me-2"></i>Keine Kosten vorhanden</td></tr>`;
        } else {
            projectCosts.forEach((cost, index) => {
                totalCost += cost.amount;
                const row = document.createElement('tr');
                row.innerHTML = `<td><input type="text" class="form-control edit-cost-name" value="${cost.name}" data-index="${index}" /></td><td><input type="number" class="form-control edit-cost-amount" value="${cost.amount}" step="0.01" min="0" data-index="${index}" /></td><td><small class="text-muted">${cost.createdTimestamp ? new Date(cost.createdTimestamp).toLocaleDateString('de-DE') : 'Neu'}</small></td><td><button type="button" class="btn btn-outline-danger btn-sm remove-cost-btn" data-index="${index}"><i class="fas fa-trash"></i></button></td>`;
                tableBody.appendChild(row);
                if (cost.id) {
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden'; idInput.name = `ProjectCosts[${index}].ProjectAdditionalCostsId`; idInput.value = cost.id;
                    hiddenContainer.appendChild(idInput);
                }
                ['AdditionalCostName', 'AdditionalCostAmount'].forEach((field, fi) => {
                    const inp = document.createElement('input');
                    inp.type = 'hidden'; inp.name = `ProjectCosts[${index}].${field}`; inp.value = fi === 0 ? cost.name : cost.amount;
                    hiddenContainer.appendChild(inp);
                });
            });
        }
        const totalEl = document.getElementById('totalProjectCost');
        if (totalEl) totalEl.textContent = totalCost.toFixed(2) + ' €';
    }

    // ====== NEW TABULAR BUDGET PLANNING ======
    let budgetGroups = [];
    let cachedArticles = [];
    let cachedHRGs = [];
    let groupIdCounter = 0;
    let lineIdCounter = 0;

    async function initializeBudgetPlanning() {
        const container = document.getElementById('budgetGroupsContainer');
        if (!container) return;

        // Load articles and HRGs for dropdowns
        try {
            const [articlesRes, hrgsRes] = await Promise.all([
                fetch(`/Projects/BudgetPlanning?handler=SearchArticles`),
                fetch(`/Projects/BudgetPlanning?handler=HourlyRateGroupsJson&projectId=${PROJECT_ID}`)
            ]);
            if (articlesRes.ok) cachedArticles = await articlesRes.json();
            if (hrgsRes.ok) cachedHRGs = await hrgsRes.json();
        } catch (err) { console.error('Error loading dropdown data:', err); }

        // Load existing budget groups or create initial data from server
        const existingGroups = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExistingBudgetGroups));
        if (existingGroups && existingGroups.length > 0) {
            budgetGroups = existingGroups.map(g => ({
                id: 'g_' + (groupIdCounter++),
                dbId: g.budgetGroupId,
                name: g.groupName,
                sortOrder: g.sortOrder,
                items: g.lineItems.map(li => ({
                    id: 'li_' + (lineIdCounter++),
                    dbId: li.budgetLineItemId,
                    type: li.lineItemType,
                    articleId: li.articleId,
                    hrgId: li.projectHourlyRateGroupId,
                    description: li.description,
                    quantity: li.quantity,
                    unitPrice: li.unitPrice,
                    adjustedPrice: li.adjustedPrice
                }))
            }));
        }

        // Wire up add group button
        document.getElementById('addGroupBtn')?.addEventListener('click', () => {
            addGroup();
            renderBudgetGroups();
        });

        // Wire up save button
        document.getElementById('saveBudgetBtn')?.addEventListener('click', saveBudgetPlanning);

        renderBudgetGroups();
    }

    function addGroup(name) {
        budgetGroups.push({
            id: 'g_' + (groupIdCounter++),
            dbId: null,
            name: name || 'Neue Gruppe',
            sortOrder: budgetGroups.length,
            items: []
        });
    }

    function addLineItem(groupId) {
        const group = budgetGroups.find(g => g.id === groupId);
        if (!group) return;
        group.items.push({
            id: 'li_' + (lineIdCounter++),
            dbId: null,
            type: 2, // FreeText default
            articleId: null,
            hrgId: null,
            description: '',
            quantity: 0,
            unitPrice: 0,
            adjustedPrice: null
        });
    }

    function deleteLineItem(groupId, lineId) {
        const group = budgetGroups.find(g => g.id === groupId);
        if (!group) return;
        group.items = group.items.filter(i => i.id !== lineId);
    }

    function deleteGroup(groupId) {
        budgetGroups = budgetGroups.filter(g => g.id !== groupId);
    }

    function renderBudgetGroups() {
        const container = document.getElementById('budgetGroupsContainer');
        if (!container) return;

        if (budgetGroups.length === 0) {
            container.innerHTML = `<div class="text-center text-muted py-4"><i class="fas fa-info-circle me-2"></i>Noch keine Budgetgruppen angelegt. Klicken Sie auf "Gruppe hinzufügen" um zu beginnen.</div>`;
            recalculateTotals();
            return;
        }

        let html = '';
        budgetGroups.forEach((group, gIdx) => {
            const groupTotal = calculateGroupTotal(group);
            html += `
            <div class="budget-group-card mb-4" data-group-id="${group.id}">
                <div class="budget-group-header">
                    <div class="d-flex align-items-center flex-grow-1 gap-2">
                        <i class="fas fa-layer-group text-primary"></i>
                        <input type="text" class="form-control form-control-sm budget-group-name"
                               value="${escapeHtml(group.name)}" data-group-id="${group.id}"
                               placeholder="Gruppenname" style="max-width: 300px; font-weight: 600;" />
                        <span class="badge bg-primary ms-2 budget-group-total">${formatCurrency(groupTotal)}</span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-success btn-sm add-line-btn" data-group-id="${group.id}">
                            <i class="fas fa-plus me-1"></i>Zeile
                        </button>
                        <button type="button" class="btn btn-outline-danger btn-sm delete-group-btn" data-group-id="${group.id}">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0 budget-lines-table">
                        <thead>
                            <tr>
                                <th style="width:14%;">Auswahl</th>
                                <th style="width:24%;">Bezeichnung</th>
                                <th style="width:12%;">Anzahl</th>
                                <th style="width:14%;">Preis/Stck</th>
                                <th style="width:14%;">Preis</th>
                                <th style="width:14%;">Preis angepasst</th>
                                <th style="width:8%;">Aktion</th>
                            </tr>
                        </thead>
                        <tbody>`;

            if (group.items.length === 0) {
                html += `<tr><td colspan="7" class="text-center text-muted py-2"><em>Keine Positionen – Klicken Sie auf "+ Zeile"</em></td></tr>`;
            } else {
                group.items.forEach((item, iIdx) => {
                    const calcPrice = item.quantity * item.unitPrice;
                    const effectivePrice = item.adjustedPrice !== null && item.adjustedPrice !== undefined ? item.adjustedPrice : calcPrice;
                    html += renderLineItemRow(group.id, item, calcPrice, effectivePrice);
                });
            }

            html += `</tbody>
                        <tfoot style="background: var(--light-bg);">
                            <tr>
                                <th colspan="4" class="text-end">Gruppensumme:</th>
                                <th colspan="3">${formatCurrency(groupTotal)}</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>`;
        });

        container.innerHTML = html;
        attachBudgetEventListeners();
        recalculateTotals();
    }

    function renderLineItemRow(groupId, item, calcPrice, effectivePrice) {
        // Type selector
        const typeOptions = [
            { value: 0, label: 'Material' },
            { value: 1, label: 'Ressource' },
            { value: 2, label: 'Freitext' }
        ];
        const typeSelect = typeOptions.map(opt =>
            `<option value="${opt.value}" ${item.type === opt.value ? 'selected' : ''}>${opt.label}</option>`
        ).join('');

        // Description field based on type
        let descriptionField = '';
        if (item.type === 0) {
            // Material: Article dropdown
            const articleOptions = cachedArticles.map(a =>
                `<option value="${a.articleId}" data-price="${a.price}" ${item.articleId === a.articleId ? 'selected' : ''}>${a.articleNumber} - ${escapeHtml(a.articleName)}</option>`
            ).join('');
            descriptionField = `<select class="form-select form-select-sm line-article-select" data-group-id="${groupId}" data-line-id="${item.id}">
                <option value="">-- Artikel wählen --</option>${articleOptions}</select>`;
        } else if (item.type === 1) {
            // Resource: HRG dropdown
            const hrgOptions = cachedHRGs.map(h =>
                `<option value="${h.projectHourlyRateGroupId}" data-rate="${h.hourlyRate}" ${item.hrgId === h.projectHourlyRateGroupId ? 'selected' : ''}>${escapeHtml(h.name)}</option>`
            ).join('');
            descriptionField = `<select class="form-select form-select-sm line-hrg-select" data-group-id="${groupId}" data-line-id="${item.id}">
                <option value="">-- Stundensatzgruppe wählen --</option>${hrgOptions}</select>`;
        } else {
            // FreeText
            descriptionField = `<input type="text" class="form-control form-control-sm line-description" data-group-id="${groupId}" data-line-id="${item.id}" value="${escapeHtml(item.description)}" placeholder="Bezeichnung" />`;
        }

        // Unit price: editable for FreeText, read-only for Material/Resource
        const unitPriceField = item.type === 2
            ? `<input type="number" class="form-control form-control-sm line-unit-price" data-group-id="${groupId}" data-line-id="${item.id}" value="${item.unitPrice}" step="0.01" min="0" />`
            : `<span class="fw-bold text-success">${formatCurrency(item.unitPrice)}</span>`;

        return `<tr class="budget-line-row" data-group-id="${groupId}" data-line-id="${item.id}">
            <td><select class="form-select form-select-sm line-type-select" data-group-id="${groupId}" data-line-id="${item.id}">${typeSelect}</select></td>
            <td>${descriptionField}</td>
            <td><input type="number" class="form-control form-control-sm line-quantity" data-group-id="${groupId}" data-line-id="${item.id}" value="${item.quantity}" step="0.01" min="0" /></td>
            <td>${unitPriceField}</td>
            <td><span class="fw-bold text-primary line-calc-price">${formatCurrency(calcPrice)}</span></td>
            <td><input type="number" class="form-control form-control-sm line-adjusted-price" data-group-id="${groupId}" data-line-id="${item.id}" value="${item.adjustedPrice !== null && item.adjustedPrice !== undefined ? item.adjustedPrice : ''}" step="0.01" min="0" placeholder="—" /></td>
            <td><button type="button" class="btn btn-outline-danger btn-sm delete-line-btn" data-group-id="${groupId}" data-line-id="${item.id}"><i class="fas fa-trash-alt"></i></button></td>
        </tr>`;
    }

    function attachBudgetEventListeners() {
        // Group name change
        document.querySelectorAll('.budget-group-name').forEach(el => {
            el.addEventListener('input', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                if (group) group.name = e.target.value;
            });
        });

        // Add line item
        document.querySelectorAll('.add-line-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                addLineItem(e.currentTarget.dataset.groupId);
                renderBudgetGroups();
            });
        });

        // Delete group
        document.querySelectorAll('.delete-group-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                deleteGroup(e.currentTarget.dataset.groupId);
                renderBudgetGroups();
            });
        });

        // Delete line item
        document.querySelectorAll('.delete-line-btn').forEach(el => {
            el.addEventListener('click', (e) => {
                const btn = e.currentTarget;
                deleteLineItem(btn.dataset.groupId, btn.dataset.lineId);
                renderBudgetGroups();
            });
        });

        // Type change → re-render
        document.querySelectorAll('.line-type-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const groupId = e.target.dataset.groupId;
                const lineId = e.target.dataset.lineId;
                const group = budgetGroups.find(g => g.id === groupId);
                const item = group?.items.find(i => i.id === lineId);
                if (item) {
                    item.type = parseInt(e.target.value);
                    item.articleId = null;
                    item.hrgId = null;
                    item.description = '';
                    item.unitPrice = 0;
                    item.adjustedPrice = null;
                }
                renderBudgetGroups();
            });
        });

        // Article selection
        document.querySelectorAll('.line-article-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                const item = group?.items.find(i => i.id === e.target.dataset.lineId);
                if (!item) return;
                const selected = e.target.options[e.target.selectedIndex];
                item.articleId = e.target.value || null;
                item.description = selected?.text || '';
                item.unitPrice = parseFloat(selected?.dataset.price) || 0;
                recalculateAndUpdateUI();
            });
        });

        // HRG selection
        document.querySelectorAll('.line-hrg-select').forEach(el => {
            el.addEventListener('change', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                const item = group?.items.find(i => i.id === e.target.dataset.lineId);
                if (!item) return;
                const selected = e.target.options[e.target.selectedIndex];
                item.hrgId = e.target.value || null;
                item.description = selected?.text || '';
                item.unitPrice = parseFloat(selected?.dataset.rate) || 0;
                recalculateAndUpdateUI();
            });
        });

        // FreeText description
        document.querySelectorAll('.line-description').forEach(el => {
            el.addEventListener('input', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                const item = group?.items.find(i => i.id === e.target.dataset.lineId);
                if (item) item.description = e.target.value;
            });
        });

        // Quantity change
        document.querySelectorAll('.line-quantity').forEach(el => {
            el.addEventListener('input', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                const item = group?.items.find(i => i.id === e.target.dataset.lineId);
                if (item) item.quantity = parseFloat(e.target.value) || 0;
                recalculateAndUpdateUI();
            });
        });

        // Unit price change (FreeText only)
        document.querySelectorAll('.line-unit-price').forEach(el => {
            el.addEventListener('input', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                const item = group?.items.find(i => i.id === e.target.dataset.lineId);
                if (item) item.unitPrice = parseFloat(e.target.value) || 0;
                recalculateAndUpdateUI();
            });
        });

        // Adjusted price change
        document.querySelectorAll('.line-adjusted-price').forEach(el => {
            el.addEventListener('input', (e) => {
                const group = budgetGroups.find(g => g.id === e.target.dataset.groupId);
                const item = group?.items.find(i => i.id === e.target.dataset.lineId);
                if (item) {
                    const val = e.target.value.trim();
                    item.adjustedPrice = val !== '' ? parseFloat(val) : null;
                }
                recalculateAndUpdateUI();
            });
        });
    }

    function recalculateAndUpdateUI() {
        // Update calculated prices and totals without full re-render
        budgetGroups.forEach(group => {
            group.items.forEach(item => {
                const row = document.querySelector(`.budget-line-row[data-group-id="${group.id}"][data-line-id="${item.id}"]`);
                if (!row) return;
                const calcPrice = item.quantity * item.unitPrice;
                row.querySelector('.line-calc-price').textContent = formatCurrency(calcPrice);
            });
            // Update group total badge
            const groupCard = document.querySelector(`.budget-group-card[data-group-id="${group.id}"]`);
            if (groupCard) {
                const totalBadge = groupCard.querySelector('.budget-group-total');
                const footerTh = groupCard.querySelector('tfoot th:last-child');
                const total = calculateGroupTotal(group);
                if (totalBadge) totalBadge.textContent = formatCurrency(total);
                if (footerTh) footerTh.textContent = formatCurrency(total);
            }
        });
        recalculateTotals();
    }

    function calculateGroupTotal(group) {
        return group.items.reduce((sum, item) => {
            const calcPrice = item.quantity * item.unitPrice;
            return sum + (item.adjustedPrice !== null && item.adjustedPrice !== undefined ? item.adjustedPrice : calcPrice);
        }, 0);
    }

    function recalculateTotals() {
        const total = budgetGroups.reduce((sum, g) => sum + calculateGroupTotal(g), 0);
        const el = document.getElementById('totalBudgetDisplay');
        if (el) el.textContent = formatCurrency(total);
    }

    async function saveBudgetPlanning() {
        const btn = document.getElementById('saveBudgetBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Speichern...';

        const payload = budgetGroups.map((g, gIdx) => ({
            budgetGroupId: g.dbId,
            groupName: g.name,
            sortOrder: gIdx,
            lineItems: g.items.map((item, iIdx) => ({
                budgetLineItemId: item.dbId,
                lineItemType: item.type,
                articleId: item.articleId,
                projectHourlyRateGroupId: item.hrgId,
                description: item.description,
                quantity: item.quantity,
                unitPrice: item.unitPrice,
                adjustedPrice: item.adjustedPrice,
                sortOrder: iIdx
            }))
        }));

        try {
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = { 'Content-Type': 'application/json' };
            if (tokenEl) headers['RequestVerificationToken'] = tokenEl.value;

            const response = await fetch(`/Projects/BudgetPlanning?handler=SaveBudgetPlanning&projectId=${PROJECT_ID}`, {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (result.success) {
                showNotification('Budgetplanung erfolgreich gespeichert!', 'success');
                setTimeout(() => window.location.href = `/Projects/Details?id=${PROJECT_ID}`, 1500);
            } else {
                showNotification(result.message || 'Fehler beim Speichern', 'error');
            }
        } catch (err) {
            console.error('Save error:', err);
            showNotification('Fehler beim Speichern der Budgetplanung', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-2"></i>Budget als Auftragsvolumen erfassen';
        }
    }

    // ====== HELPERS ======
    function formatCurrency(value) {
        return (value || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    function showNotification(message, type = 'info') {
        document.querySelectorAll('.custom-notification').forEach(n => n.remove());
        const notification = document.createElement('div');
        notification.className = `custom-notification alert alert-${type === 'success' ? 'success' : type === 'warning' ? 'warning' : type === 'error' ? 'danger' : 'info'}`;
        notification.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;max-width:400px;box-shadow:var(--shadow-lg);border-radius:var(--border-radius);';
        notification.innerHTML = `${message}<button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>`;
        document.body.appendChild(notification);
        setTimeout(() => notification.parentNode && notification.remove(), 4000);
    }
</script>