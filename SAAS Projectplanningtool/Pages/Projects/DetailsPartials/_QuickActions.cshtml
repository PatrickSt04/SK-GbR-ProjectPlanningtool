@using SAAS_Projectplanningtool.Pages.Projects
@model SAAS_Projectplanningtool.Pages.Projects.DetailsModel

<!-- Quick Actions Section -->
<section class="quick-actions-section">
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-bolt me-2"></i>Schnelle Aktionen</h2>
        </div>
        <div class="card-body">
            <div class="action-buttons">
                <button type="button" class="btn btn-primary" onclick="showAddSectionModal()">
                    <i class="fas fa-plus me-1"></i>
                    Abschnitt hinzufügen
                </button>
                <button type="button" class="btn btn-secondary" onclick="showAddTaskModal()">
                    <i class="fas fa-tasks me-1"></i>
                    Aufgabe hinzufügen
                </button>
                <button type="button" class="btn btn-secondary" onclick="showAddMileStoneModal()">
                    <i class="fas fa-flag me-1"></i>
                    Meilenstein hinzufügen
                </button>
                <a asp-page="Edit" asp-route-id="@Model.Project.ProjectId" class="btn btn-secondary">
                    <i class="fas fa-edit me-1"></i>
                    Projekt bearbeiten
                </a>
                <a asp-page="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>
                    Zurück zur Übersicht
                </a>
            </div>
        </div>
    </div>
</section>
