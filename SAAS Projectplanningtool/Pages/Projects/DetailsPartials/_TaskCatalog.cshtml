@using SAAS_Projectplanningtool.Pages.Projects
@model SAAS_Projectplanningtool.Pages.Projects.DetailsModel

<!-- Task Catalog Section -->
<section class="tasks-section">
    <div class="card">
        <div class="card-body">
            <!-- Aufgabenkatalog Header -->
            <div class="task-catalog-header">
                <h2><i class="fas fa-tasks me-2"></i>Aufgabenkatalog</h2>
            </div>

            <!-- Action Buttons -->
            <div class="task-catalog-actions">
                @{
                    bool showCompleted = Model.showCompleted;
                }
                <form method="get" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Project.ProjectId" />
                    <input type="hidden" asp-for="showCompleted" value="@(!Model.showCompleted)" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fas @(showCompleted ? "fa-eye-slash" : "fa-eye") me-1"></i>
                        @(showCompleted ? "Abgeschlossene ausblenden" : "Abgeschlossene anzeigen")
                    </button>
                </form>

                <button type="button" class="btn btn-primary" onclick="showAddTaskCatalogModal()">
                    <i class="fas fa-plus me-1"></i>Aufgabe hinzufügen
                </button>
            </div>

            <!-- Task List -->
            <div class="tasks-main-container">
                <div class="task-list-container">
                    @if (Model.TaskCatalog != null && Model.TaskCatalog.Any())
                    {
                       
                            var visibleTasks = Model.TaskCatalog.Take(5).ToList();
                            var hiddenTasks = Model.TaskCatalog.Skip(5).ToList();
                            int hiddenTasksCount = hiddenTasks.Count;

                        <div class="task-list">
                            <!-- Visible Tasks -->
                            @foreach (var task in visibleTasks)
                            {
                                @await Html.PartialAsync("~/Pages/Projects/DetailsPartials/_TaskCatalogItem.cshtml", task)
                            }

                            <!-- Hidden Tasks (Show More) -->
                            @if (hiddenTasks.Any())
                            {
                                <div id="hiddenTasks" style="display: none;">
                                    @foreach (var task in hiddenTasks)
                                    {
                                        @await Html.PartialAsync("~/Pages/Projects/DetailsPartials/_TaskCatalogItem.cshtml", task)
                                    }
                                </div>
                            }
                        </div>

                        <!-- Show More Button -->
                        @if (hiddenTasksCount > 0)
                        {
                            <div class="show-more-container">
                                <button type="button" class="btn btn-outline-secondary" id="showMoreBtn" onclick="toggleMoreTasks()">
                                    <i class="fas fa-chevron-down me-1"></i>
                                    <span id="showMoreText">@hiddenTasksCount weitere Aufgaben anzeigen</span>
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-clipboard-list fa-3x mb-3"></i>
                            <p>Noch keine Aufgaben vorhanden</p>
                            <button type="button" class="btn btn-primary" onclick="showAddTaskCatalogModal()">
                                <i class="fas fa-plus me-1"></i>Erste Aufgabe hinzufügen
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function toggleMoreTasks() {
        const hiddenTasks = document.getElementById('hiddenTasks');
        const showMoreBtn = document.getElementById('showMoreBtn');
        const showMoreText = document.getElementById('showMoreText');
        const icon = showMoreBtn.querySelector('i');

        if (hiddenTasks.style.display === 'none') {
            hiddenTasks.style.display = 'block';
            showMoreText.textContent = 'Weniger anzeigen';
            icon.className = 'fas fa-chevron-up me-1';
        } else {
            hiddenTasks.style.display = 'none';
            const matches = showMoreText.textContent.match(/(\d+)/);
            const count = matches ? matches[1] : '0';
            showMoreText.textContent = count + ' weitere Aufgaben anzeigen';
            icon.className = 'fas fa-chevron-down me-1';
        }
    }
</script>
