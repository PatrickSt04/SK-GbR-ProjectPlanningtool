@using SAAS_Projectplanningtool.Pages.Projects
@model SAAS_Projectplanningtool.Pages.Projects.DetailsModel

<!-- Project Structure Section -->
<section>
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-sitemap me-2"></i>Projektstruktur</h2>
            <div class="card-actions">
                <button type="button" class="btn btn-primary btn-sm" onclick="showAddSectionModal()">
                    <i class="fas fa-plus me-2"></i>Abschnitt hinzufügen
                </button>
                <div type="button"
                     class=" @(Model.Project?.ProjectBudget?.InitialBudget == null || Model.Project?.ProjectBudget?.InitialBudget == 0 ? "disabled" : "")"
                     @(Model.Project?.ProjectBudget?.InitialBudget == null || Model.Project?.ProjectBudget?.InitialBudget == 0 ? "disabled" : "")
                     style="@(Model.Project?.ProjectBudget?.InitialBudget == null || Model.Project?.ProjectBudget?.InitialBudget == 0 ? "pointer-events: none;" : "")">
                    @if (Model.Project?.ProjectBudget?.InitialBudget != null && Model.Project?.ProjectBudget?.InitialBudget > 0)
                    {
                        <a asp-page="/Projects/Scheduling" asp-route-id="@Model.Project.ProjectId" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-calendar me-1"></i>Terminplanung
                        </a>
                    }
                    else
                    {
                        <span>
                            <i class="fas fa-calendar me-1"></i>Terminplanung
                        </span>
                    }
                </div>
                <a asp-page="/Projects/BudgetPlanning" asp-route-id="@Model.Project.ProjectId" class="">
                    <button type="button" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-users me-1"></i>Budgetplanung
                    </button>
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Project?.ProjectSections != null && Model.Project.ProjectSections.Any())
            {
                <div class="project-structure-tree">
                    <!-- Project Root -->
                    <div class="structure-item structure-project">
                        <div class="structure-header">
                            <div class="structure-toggle">
                                <i class="fas fa-project-diagram"></i>
                            </div>
                            <div class="structure-content">
                                <span class="structure-name">@Model.Project.ProjectName</span>
                                <span class="structure-meta">@Model.Project.ProjectSections.Count Section(s)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Project Sections -->
                    @foreach (var section in Model.Project.ProjectSections.Where(s => s.ParentSectionId == null))
                    {
                        @await Html.PartialAsync("~/Pages/Projects/PartialViews/_ProjectSectionTreeItem.cshtml", section)
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-folder-open fa-3x mb-3 text-muted"></i>
                    <p class="text-muted">Noch keine Projektstruktur vorhanden</p>
                    <button type="button" class="btn btn-primary" onclick="showAddSectionModal()">
                        <i class="fas fa-plus me-2"></i>Ersten Abschnitt hinzufügen
                    </button>
                </div>
            }
        </div>
    </div>
</section>
