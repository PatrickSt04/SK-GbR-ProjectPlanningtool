@using SAAS_Projectplanningtool.Pages.Projects
@model SAAS_Projectplanningtool.Pages.Projects.DetailsModel

@*
    Partial View: _EditProjectDescriptionModal.cshtml
    Zweck:        Bearbeitungs-Modal für die Projektbeschreibungs-Kachel auf der Details-Seite.
    Handler:      OnPostEditProjectDescriptionAsync (Details.cshtml.cs)
*@

<div class="modal fade" id="editProjectDescriptionModal" tabindex="-1" aria-labelledby="editProjectDescriptionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditProjectDescription">

                <input type="hidden" name="projectId" value="@Model.Project.ProjectId" />

                <div class="modal-header">
                    <h5 class="modal-title" id="editProjectDescriptionModalLabel">
                        <i class="fas fa-align-left me-2"></i>Projektbeschreibung bearbeiten
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                </div>

                <div class="modal-body">
                    <label for="editProjectDescription" class="form-label modal-section-title">
                        <i class="fas fa-file-alt me-1"></i>Beschreibung
                    </label>
                    <textarea id="editProjectDescription"
                              name="projectDescription"
                              class="form-control"
                              rows="8"
                              placeholder="Projektbeschreibung eingeben …">@Model.Project?.ProjectDescription</textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Abbrechen
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Speichern
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
