@model SAAS_Projectplanningtool.Pages.Projects.ProjectsModel
@using SAAS_Projectplanningtool.Models.Budgetplanning
@using SAAS_Projectplanningtool.Pages.Projects

<!-- Projects Card View -->
<div id="cardViewContent" class="projects-grid">
    @if (Model.Projects.Any())
    {
        <div class="row g-4">
            @foreach (var project in Model.Projects)
            {
                var progressPercentage = ProjectsModel.CalculateProgress(project.Project);
                var statusClass = ProjectsModel.GetStatusClass(project.Project.State?.StateName);
                var priorityClass = ProjectsModel.GetPriorityClass(project.Project);

                <div class="col-lg-4 col-md-6">
                    <div class="project-card @priorityClass">
                        <div class="project-header">
                            <div class="project-title">
                                <h5>
                                    <a asp-page="Details" asp-route-id="@project.Project.ProjectId"
                                           class="text-decoration-none">
                                        @project.Project.ProjectName
                                    </a>
                                </h5>
                                <span class="project-status @statusClass">
                                    @project.Project.State?.StateName
                                </span>
                            </div>
                            <div class="project-actions">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" asp-page="Details" asp-route-id="@project.Project.ProjectId">
                                                <i class="fas fa-eye me-2"></i>Details
                                            </a>
                                        </li>
                                        @if (Model.CanEditProjects)
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-page="Edit" asp-route-id="@project.Project.ProjectId">
                                                    <i class="fas fa-edit me-2"></i>Bearbeiten
                                                </a>
                                            </li>
                                        }
                                        <li>
                                            <a class="dropdown-item" href="#" onclick="duplicateProject('@project.Project.ProjectId')">
                                                <i class="fas fa-copy me-2"></i>Duplizieren
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        @if (project.Project.IsArchived != true)
                                        {
                                            <li>
                                                <a class="dropdown-item text-warning" href="#"
                                                       onclick="archiveProject('@project.Project.ProjectId')">
                                                    <i class="fas fa-archive me-2"></i>Archivieren
                                                </a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <a class="dropdown-item text-success" href="#"
                                                       onclick="unarchiveProject('@project.Project.ProjectId')">
                                                    <i class="fas fa-box-open me-2"></i>Reaktivieren
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="project-content">
                            <p class="project-description">@project.Project.ProjectDescription</p>

                            <div class="project-meta-info">
                                <div class="meta-item">
                                    <i class="fas fa-user text-muted me-1"></i>
                                    <span>@project.Project.Customer?.CustomerName</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-user-tie text-muted me-1"></i>
                                    <span>@project.Project.ProjectLead?.EmployeeDisplayName</span>
                                </div>
                            </div>

                            <div class="project-dates">
                                <div class="date-item">
                                    <small class="text-muted">Start:</small>
                                    <span>@(project.Project.StartDate?.ToString("dd.MM.yyyy") ?? "Nicht gesetzt")</span>
                                </div>
                                <div class="date-item">
                                    <small class="text-muted">Ende:</small>
                                    <span>@(project.Project.EndDate?.ToString("dd.MM.yyyy") ?? "Nicht gesetzt")</span>
                                </div>
                            </div>

                            @if (project.Project.ProjectBudget != null)
                            {
                                var budgetPercentage = project.Project.ProjectBudget.InitialBudget > 0
                                    ? (project.UsedBudget / project.Project.ProjectBudget.InitialBudget) * 100
                                    : 0;

                                <div class="project-budget">
                                    <div class="budget-header">
                                        <small class="text-muted">Budget</small>
                                        <small class="budget-percentage">@budgetPercentage.ToString("F1")%</small>
                                    </div>
                                    <div class="progress progress-sm">
                                        <div class="progress-bar @ProjectsModel.GetBudgetClass(budgetPercentage)"
                                             style="width: @budgetPercentage%"></div>
                                    </div>
                                    <div class="budget-details">
                                        <small>@project.UsedBudget.ToString("C") / @project.Project.ProjectBudget.InitialBudget.ToString("C")</small>
                                    </div>
                                </div>
                            }

                            <div class="project-progress">
                                <div class="progress-header">
                                    <small class="text-muted">Fortschritt</small>
                                    <small>@progressPercentage%</small>
                                </div>
                                <div class="progress progress-sm">
                                    <div class="progress-bar bg-success" style="width: @progressPercentage%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-project-diagram"></i>
            </div>
            <h3>Keine Projekte gefunden</h3>
            <p class="text-muted">
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <span>Keine Projekte entsprechen Ihren Suchkriterien.</span>
                }
                else
                {
                    <span>Erstellen Sie Ihr erstes Projekt, um loszulegen.</span>
                }
            </p>
            @if (Model.CanCreateProjects)
            {
                <a asp-page="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Erstes Projekt erstellen
                </a>
            }
        </div>
    }
</div>

<!-- Projects Table View -->
<div id="tableViewContent" class="projects-table" style="display: none;">
    @if (Model.Projects.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>
                            <a asp-page="Index" asp-route-sortBy="ProjectName"
                                   asp-route-sortDirection="@(Model.SortBy == "ProjectName" && Model.SortDirection == "asc" ? "desc" : "asc")"
                                   class="text-decoration-none">
                                Projektname
                                @if (Model.SortBy == "ProjectName")
                                {
                                    <i class="fas fa-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i>
                                }
                            </a>
                        </th>
                        <th>Kunde</th>
                        <th>Status</th>
                        <th>Projektleiter</th>
                        <th>
                            <a asp-page="Index" asp-route-sortBy="StartDate"
                                   asp-route-sortDirection="@(Model.SortBy == "StartDate" && Model.SortDirection == "asc" ? "desc" : "asc")"
                                   class="text-decoration-none">
                                Startdatum
                                @if (Model.SortBy == "StartDate")
                                {
                                    <i class="fas fa-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="Index" asp-route-sortBy="EndDate"
                                   asp-route-sortDirection="@(Model.SortBy == "EndDate" && Model.SortDirection == "asc" ? "desc" : "asc")"
                                   class="text-decoration-none">
                                Enddatum
                                @if (Model.SortBy == "EndDate")
                                {
                                    <i class="fas fa-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i>
                                }
                            </a>
                        </th>
                        <th>Budget</th>
                        <th>Fortschritt</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var project in Model.Projects)
                    {
                        var progressPercentage = ProjectsModel.CalculateProgress(project.Project);
                        var statusClass = ProjectsModel.GetStatusClass(project.Project.State?.StateName);

                        <tr>
                            <td class="project-name-cell">
                                <strong>
                                    <a asp-page="Details" asp-route-id="@project.Project.ProjectId"
                                           class="text-decoration-none">
                                        @project.Project.ProjectName
                                    </a>
                                </strong>
                            </td>
                            <td>@project.Project.Customer?.CustomerName</td>
                            <td>
                                <span class="badge @statusClass">@project.Project.State?.StateName</span>
                            </td>
                            <td>@project.Project.ProjectLead?.EmployeeDisplayName</td>
                            <td>@(project.Project.StartDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td>@(project.Project.EndDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td class="budget-cell">
                                @if (project.Project.ProjectBudget != null)
                                {
                                    var budgetPct = project.Project.ProjectBudget.InitialBudget > 0
                                        ? (project.UsedBudget / project.Project.ProjectBudget.InitialBudget) * 100
                                        : 0;
                                    <div class="progress progress-sm">
                                        <div class="progress-bar @ProjectsModel.GetBudgetClass(budgetPct)"
                                             style="width: @budgetPct%"></div>
                                    </div>
                                    <small>@budgetPct.ToString("F1")%</small>
                                }
                            </td>
                            <td class="progress-cell">
                                <div class="progress progress-sm">
                                    <div class="progress-bar bg-success" style="width: @progressPercentage%"></div>
                                </div>
                                <small>@progressPercentage%</small>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="Details" asp-route-id="@project.Project.ProjectId"
                                           class="btn btn-outline-primary btn-sm" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (Model.CanEditProjects)
                                    {
                                        <a asp-page="Edit" asp-route-id="@project.Project.ProjectId"
                                               class="btn btn-outline-secondary btn-sm" title="Bearbeiten">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle dropdown-toggle-split"
                                            data-bs-toggle="dropdown">
                                        <span class="visually-hidden">Mehr Aktionen</span>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" href="#" onclick="duplicateProject('@project.Project.ProjectId')">
                                                <i class="fas fa-copy me-2"></i>Duplizieren
                                            </a>
                                        </li>
                                        @if (project.Project.IsArchived != true)
                                        {
                                            <li>
                                                <a class="dropdown-item text-warning" href="#"
                                                       onclick="archiveProject('@project.Project.ProjectId')">
                                                    <i class="fas fa-archive me-2"></i>Archivieren
                                                </a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <a class="dropdown-item text-success" href="#"
                                                       onclick="unarchiveProject('@project.Project.ProjectId')">
                                                    <i class="fas fa-box-open me-2"></i>Reaktivieren
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Seitennummerierung" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-page="Index" asp-route-page="@(Model.CurrentPage - 1)"
                           asp-all-route-data="@Model.GetRouteData()">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
            }

            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-page="Index" asp-route-page="@i"
                           asp-all-route-data="@Model.GetRouteData()">
                        @i
                    </a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-page="Index" asp-route-page="@(Model.CurrentPage + 1)"
                           asp-all-route-data="@Model.GetRouteData()">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // View Toggle
        const cardViewBtn = document.getElementById('cardView');
        const tableViewBtn = document.getElementById('tableView');
        const cardViewContent = document.getElementById('cardViewContent');
        const tableViewContent = document.getElementById('tableViewContent');

        cardViewBtn.addEventListener('change', function() {
            if (this.checked) {
                cardViewContent.style.display = 'block';
                tableViewContent.style.display = 'none';
                localStorage.setItem('projectsViewType', 'card');
            }
        });

        tableViewBtn.addEventListener('change', function() {
            if (this.checked) {
                cardViewContent.style.display = 'none';
                tableViewContent.style.display = 'block';
                localStorage.setItem('projectsViewType', 'table');
            }
        });

        // Restore saved view type
        const savedViewType = localStorage.getItem('projectsViewType');
        if (savedViewType === 'table') {
            tableViewBtn.checked = true;
            tableViewBtn.dispatchEvent(new Event('change'));
        }

        // Auto-submit filter form on select change
        document.querySelectorAll('select[name="statusFilter"], select[name="customerFilter"], select[name="managerFilter"], select[name="dateFilter"]').forEach(select => {
            select.addEventListener('change', function() {
                this.closest('form').submit();
            });
        });

        // Search on Enter key
        const searchInput = document.querySelector('input[name="searchTerm"]');
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    this.closest('form').submit();
                }
            });
        }
    });

    // Project Actions
    function archiveProject(projectId) {
        if (confirm('Möchten Sie dieses Projekt wirklich archivieren?')) {
            fetch('/Projects/Archive', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify({ projectId: projectId })
            })
            .then(response => {
                if (response.ok) {
                    showNotification('Projekt wurde erfolgreich archiviert.', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification('Fehler beim Archivieren des Projekts.', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showNotification('Ein Fehler ist aufgetreten.', 'error');
            });
        }
    }

    function unarchiveProject(projectId) {
        if (confirm('Möchten Sie dieses Projekt reaktivieren?')) {
            fetch('/Projects/Unarchive', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify({ projectId: projectId })
            })
            .then(response => {
                if (response.ok) {
                    showNotification('Projekt wurde erfolgreich reaktiviert.', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification('Fehler beim Reaktivieren des Projekts.', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showNotification('Ein Fehler ist aufgetreten.', 'error');
            });
        }
    }

    function duplicateProject(projectId) {
        if (confirm('Möchten Sie dieses Projekt duplizieren?')) {
            window.location.href = `/Projects/Duplicate/${projectId}`;
        }
    }

    function exportProjects(format) {
        const params = new URLSearchParams(window.location.search);
        params.set('export', format);
        window.location.href = `/Projects/Export?${params.toString()}`;
    }

    function changePageSize(pageSize) {
        const params = new URLSearchParams(window.location.search);
        params.set('pageSize', pageSize);
        params.delete('page');
        window.location.href = `${window.location.pathname}?${params.toString()}`;
    }

    // Notification System
    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show position-fixed`;
        notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        notification.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(notification);
        setTimeout(() => {
            if (notification.parentNode) {
                notification.remove();
            }
        }, 5000);
    }

    // Keyboard Shortcuts
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'n') {
            e.preventDefault();
            const newProjectBtn = document.querySelector('a[asp-page="Create"]');
            if (newProjectBtn) newProjectBtn.click();
        }
        if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
            e.preventDefault();
            const searchInput = document.querySelector('input[name="searchTerm"]');
            if (searchInput) {
                searchInput.focus();
                searchInput.select();
            }
        }
        if (e.key === 'Escape') {
            const filterForm = document.querySelector('.filter-form');
            if (filterForm) {
                filterForm.reset();
                filterForm.submit();
            }
        }
    });

    // Tooltips
    document.addEventListener('DOMContentLoaded', function() {
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
        tooltipTriggerList.map(function(tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
</script>
