                        </a>
                        <ul class="nav-submenu">
                            <li><a href="/CustomerManagement/Index" class="nav-link">Alle Kunden</a></li>
                            <li><a href="/CustomerManagement/Create" class="nav-link">Neuer Kunde</a></li>
                        </ul>
