                    </a>
                    <ul class="nav-submenu">
                        <li><a href="/Reports/Projects" class="nav-link">Projekt-Berichte</a></li>
                        <li><a href="/Reports/Budget" class="nav-link">Budget-Analyse</a></li>
                        <li><a href="/Reports/Resources" class="nav-link">Ressourcen-Auslastung</a></li>
                        <li><a href="/Reports/Timeline" class="nav-link">Zeiterfassung</a></li>
