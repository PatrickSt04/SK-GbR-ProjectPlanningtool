@page
@model SAAS_Projectplanningtool.Pages.CustomerManagement.IndexModel
@{
    ViewData["Title"] = "Kundenverwaltung";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1>Kundenverwaltung</h1>
            <p class="header-subtitle">Alle Kunden &amp; Interessenten Ihres Unternehmens</p>
        </div>
        <div class="header-actions">
            <a asp-page="Create" class="btn btn-outline-light">
                Neuen Eintrag anlegen
            </a>
        </div>
    </div>
</div>

<div class="card" style="padding: 0; overflow: hidden;">
    <div style="padding: 18px 24px 14px;">
        <div class="cm-toolbar">
            <div class="cm-search-wrap">
                <input type="text" id="searchInput" class="cm-input cm-search" placeholder="Name oder Adresse suchen…" oninput="filterTable()">
            </div>
            <select id="typeFilter" class="cm-input cm-select" style="width:auto;" onchange="filterTable()">
                <option value="">Alle Typen</option>
                <option value="Interessent">Interessenten</option>
                <option value="Kunde">Kunden</option>
            </select>
            <select id="statusFilter" class="cm-input cm-select" style="width:auto;" onchange="filterTable()">
                <option value="aktiv">Aktive</option>
                <option value="">Alle</option>
                <option value="gesperrt">Gesperrte</option>
            </select>
        </div>
    </div>

    <table class="cm-table" id="customerTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Typ</th>
                <th>Adresse</th>
                <th>Kontakt</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Customer)
            {
                var isLocked = item.DeleteFlag;
                var isKunde = item.CustomerType == SAAS_Projectplanningtool.Models.CRM.CustomerType.Kunde;
                <tr data-name="@item.CustomerName.ToLower()"
                    data-type="@(isKunde ? "Kunde" : "Interessent")"
                    data-status="@(isLocked ? "gesperrt" : "aktiv")">
                    <td>
                        <a class="td-link" asp-page="Details" asp-route-id="@item.CustomerId">
                            @item.CustomerName
                        </a>
                    </td>
                    <td>
                        <span class="badge-type @(isKunde ? "badge-kunde" : "badge-interessent")">
                            @(isKunde ? "Kunde" : "Interessent")
                        </span>
                    </td>
                    <td style="color:var(--text-muted); font-size:.85rem;">
                        @if (item.Address != null)
                        {
                            @item.Address.PostalCode @item.Address.City
                            @if (!string.IsNullOrEmpty(item.Address.Country))
                            {
                                <span style="opacity:.5; margin: 0 3px;">·</span>
                                @item.Address.Country
                            }
                        }
                        else
                        {
                            <span style="opacity:.4;">–</span>
                        }
                    </td>
                    <td style="font-size:.85rem;">
                        @if (!string.IsNullOrEmpty(item.ContactPhone))
                        {
                            <div>@item.ContactPhone</div>
                        }
                        @if (!string.IsNullOrEmpty(item.ContactEmail))
                        {
                            <div>@item.ContactEmail</div>
                        }
                    </td>
                    <td>
                        @if (isLocked)
                        {
                            <span class="badge-type badge-locked">Gesperrt</span>
                        }
                        else
                        {
                            <span style="color:var(--success); font-size:.8rem; font-weight:600;">
                                Aktiv
                            </span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Customer.Any())
    {
        <div class="cm-empty">
            <div class="cm-empty-icon"><i class="bi bi-people"></i></div>
            Noch keine Einträge vorhanden.
        </div>
    }

    <div style="padding: 12px 24px; border-top: 1px solid var(--border); font-size: .78rem; color: var(--text-muted);">
        <span id="rowCount">@Model.Customer.Count</span> Einträge
    </div>
</div>

<script>
    function filterTable() {
        const q      = document.getElementById('searchInput').value.toLowerCase();
        const type   = document.getElementById('typeFilter').value;
        const status = document.getElementById('statusFilter').value;
        const rows   = document.querySelectorAll('#customerTable tbody tr');
        let visible  = 0;
        rows.forEach(r => {
            const name    = r.dataset.name    || '';
            const rType   = r.dataset.type    || '';
            const rStatus = r.dataset.status  || '';
            const show =
                (!q      || name.includes(q))       &&
                (!type   || rType   === type)         &&
                (!status || rStatus === status);
            r.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('rowCount').textContent = visible;
    }
    // default: show only active
    filterTable();
</script>
