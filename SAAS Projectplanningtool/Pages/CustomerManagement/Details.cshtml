@page
@model SAAS_Projectplanningtool.Pages.CustomerManagement.DetailsModel
@using SAAS_Projectplanningtool.Models
@using SAAS_Projectplanningtool.Models.CRM
@{
    ViewData["Title"] = Model.Customer.CustomerName;
    bool isKunde = Model.Customer.CustomerType == CustomerType.Kunde;
    bool isLocked = Model.Customer.DeleteFlag;
    var msgOpen = Model.Customer.CustomerMessages.Count(m => m.Status != MessageStatus.Geschlossen);
}

@await Html.PartialAsync("_CustomerStyles")

<!-- ── Page Header ── -->
<div class="cm-header" style="flex-wrap:wrap; gap:12px;">
    <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
        <div style="width:52px; height:52px; border-radius:14px; background:var(--accent-light);
                    display:flex; align-items:center; justify-content:center;
                    font-size:1.4rem; color:var(--accent); flex-shrink:0;">
            <i class="bi @(isKunde ? "bi-building" : "bi-person-badge")"></i>
        </div>
        <div>
            <div style="display:flex; align-items:center; gap:10px;">
                <h1 style="margin:0; font-size:1.6rem;">@Model.Customer.CustomerName</h1>
                <span class="badge-type @(isKunde ? "badge-kunde" : "badge-interessent")">
                    <i class="bi @(isKunde ? "bi-building-check" : "bi-person-badge")"></i>
                    @(isKunde ? "Kunde" : "Interessent")
                </span>
                @if (isLocked)
                {
                    <span class="badge-type badge-locked"><i class="bi bi-lock-fill"></i> Gesperrt</span>
                }
            </div>
            <div style="font-size:.78rem; color:var(--text-muted); margin-top:3px;">
                Erstellt von @(Model.Customer.CreatedByEmployee?.EmployeeDisplayName ?? "Unbekannt")
                @if (Model.Customer.CreatedTimestamp.HasValue)
                {
                    <span>· @Model.Customer.CreatedTimestamp.Value.ToString("dd.MM.yyyy")</span>
                }
            </div>
        </div>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
        @if (!isKunde)
        {
            <form method="post" asp-page-handler="UpgradeToKunde" asp-route-id="@Model.Customer.CustomerId" style="display:inline;">
                <button type="submit" class="btn-cm btn-cm-success">
                    <i class="bi bi-arrow-up-circle"></i> Zu Kunde aufwerten
                </button>
            </form>
        }
        <a asp-page="./Edit" asp-route-id="@Model.Customer.CustomerId" class="btn-cm btn-cm-ghost">
            <i class="bi bi-pencil"></i> Bearbeiten
        </a>
        @if (!isLocked)
        {
            <form method="post" asp-page-handler="SetDeleteFlag" asp-route-id="@Model.Customer.CustomerId" style="display:inline;">
                <button type="submit" class="btn-cm btn-cm-danger btn-cm-sm">
                    <i class="bi bi-lock"></i> Sperren
                </button>
            </form>
        }
        else
        {
            <form method="post" asp-page-handler="UndoDeleteFlag" asp-route-id="@Model.Customer.CustomerId" style="display:inline;">
                <button type="submit" class="btn-cm btn-cm-success btn-cm-sm">
                    <i class="bi bi-unlock"></i> Entsperren
                </button>
            </form>
        }
    </div>
</div>

<!-- ── Top info strip ── -->
<div style="display:flex; gap:20px; margin-bottom:22px; flex-wrap:wrap;">
    @if (!string.IsNullOrEmpty(Model.Customer.ContactPhone))
    {
        <div style="display:flex; align-items:center; gap:7px; font-size:.875rem;">
            <i class="bi bi-telephone-fill" style="color:var(--accent);"></i>
            <span>@Model.Customer.ContactPhone</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.Customer.ContactEmail))
    {
        <div style="display:flex; align-items:center; gap:7px; font-size:.875rem;">
            <i class="bi bi-envelope-fill" style="color:var(--accent);"></i>
            <a href="mailto:@Model.Customer.ContactEmail" style="color:inherit;">@Model.Customer.ContactEmail</a>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.Customer.Website))
    {
        <div style="display:flex; align-items:center; gap:7px; font-size:.875rem;">
            <i class="bi bi-globe" style="color:var(--accent);"></i>
            <a href="@Model.Customer.Website" target="_blank" rel="noopener" style="color:inherit;">@Model.Customer.Website</a>
        </div>
    }
</div>

<!-- ── Tabs ── -->
<div class="cm-tabs">
    <button class="cm-tab active" onclick="switchTab('stammdaten', this)">
        <i class="bi bi-card-list"></i> Stammdaten
    </button>
    <button class="cm-tab" onclick="switchTab('ansprechpartner', this)">
        <i class="bi bi-people"></i> Ansprechpartner
        @if (Model.Customer.ContactPersons.Any())
        {
            <span class="cm-tab-count">@Model.Customer.ContactPersons.Count</span>
        }
    </button>
    <button class="cm-tab" onclick="switchTab('projekte', this)">
        <i class="bi bi-kanban"></i> Projekte
        @if (Model.Customer.Projects?.Any() == true)
        {
            <span class="cm-tab-count">@Model.Customer.Projects.Count()</span>
        }
    </button>
    <button class="cm-tab" onclick="switchTab('zuschlaege', this)">
        <i class="bi bi-percent"></i> Zuschlagsätze
        @if (Model.Customer.MaterialSurcharges.Any())
        {
            <span class="cm-tab-count">@Model.Customer.MaterialSurcharges.Count</span>
        }
    </button>
    <button class="cm-tab" onclick="switchTab('nachrichten', this)">
        <i class="bi bi-chat-dots"></i> Nachrichten
        @if (msgOpen > 0)
        {
            <span class="cm-tab-count">@msgOpen</span>
        }
    </button>
    <button class="cm-tab" onclick="switchTab('historie', this)">
        <i class="bi bi-clock-history"></i> Kontakt-Historie
        @if (Model.Customer.ContactHistoryEntries.Any())
        {
            <span class="cm-tab-count">@Model.Customer.ContactHistoryEntries.Count</span>
        }
    </button>
</div>

<!-- ═══════════════════════════════════════════════════════
     TAB: STAMMDATEN
═══════════════════════════════════════════════════════ -->
<div id="tab-stammdaten" class="cm-tab-panel active">
    <div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">
        <div>
            <div class="cm-card">
                <div class="cm-card-title">Adresse</div>
                <div class="cm-info-grid">
                    @{
                        var addr = Model.Customer.Address;
                    }
                    <div class="cm-info-item">
                        <label>Straße / Nr.</label>
                        <span>@(addr?.Street ?? "–") @addr?.HouseNumber</span>
                    </div>
                    <div class="cm-info-item">
                        <label>PLZ / Stadt</label>
                        <span>@(addr?.PostalCode ?? "–") @addr?.City</span>
                    </div>
                    <div class="cm-info-item">
                        <label>Land</label>
                        <span>@(addr?.Country ?? "–")</span>
                    </div>
                    <div class="cm-info-item">
                        <label>Region</label>
                        <span>@(string.IsNullOrEmpty(addr?.Region) ? "–" : addr.Region)</span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Customer.Notes))
            {
                <div class="cm-card">
                    <div class="cm-card-title">Notizen</div>
                    <p style="margin:0; font-size:.875rem; white-space: pre-wrap;">@Model.Customer.Notes</p>
                </div>
            }
        </div>

        <div>
            <div class="cm-card">
                <div class="cm-card-title">Letzte Änderung</div>
                <div style="font-size:.85rem;">
                    <div style="margin-bottom:8px;">
                        <div style="color:var(--text-muted); font-size:.75rem;">Bearbeiter</div>
                        <div>@(Model.Customer.LatestModifier?.EmployeeDisplayName ?? "–")</div>
                    </div>
                    <div style="margin-bottom:8px;">
                        <div style="color:var(--text-muted); font-size:.75rem;">Zeitpunkt</div>
                        <div>@(Model.Customer.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</div>
                    </div>
                    <div>
                        <div style="color:var(--text-muted); font-size:.75rem;">Beschreibung</div>
                        <div>@(string.IsNullOrWhiteSpace(Model.Customer.LatestModificationText) ? "–" : Model.Customer.LatestModificationText)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     TAB: ANSPRECHPARTNER
═══════════════════════════════════════════════════════ -->
<div id="tab-ansprechpartner" class="cm-tab-panel">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div style="padding:16px 24px; display:flex; justify-content:space-between; align-items:center;">
            <div class="cm-card-title" style="margin:0;">Ansprechpartner</div>
            <button class="btn-cm btn-cm-primary btn-cm-sm" onclick="togglePanel('addContactPanel')">
                <i class="bi bi-plus-lg"></i> Hinzufügen
            </button>
        </div>

        <div id="addContactPanel" class="cm-add-panel" style="margin:0 20px 16px; display:none;">
            <div class="cm-add-panel-title">Neuer Ansprechpartner</div>
            <form method="post" asp-page-handler="AddContactPerson" asp-route-id="@Model.Customer.CustomerId">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div class="cm-form-group">
                        <label>Name *</label>
                        <input name="cpName" class="cm-input" required placeholder="Max Mustermann" />
                    </div>
                    <div class="cm-form-group">
                        <label>Funktion / Rolle</label>
                        <input name="cpRole" class="cm-input" placeholder="z.B. Einkauf" />
                    </div>
                    <div class="cm-form-group">
                        <label>Telefon</label>
                        <input name="cpPhone" class="cm-input" placeholder="+49 000 000000" />
                    </div>
                    <div class="cm-form-group">
                        <label>E-Mail</label>
                        <input name="cpEmail" class="cm-input" type="email" placeholder="max@firma.de" />
                    </div>
                </div>
                <div class="cm-form-group">
                    <label>Notiz</label>
                    <input name="cpNotes" class="cm-input" placeholder="Interne Notiz" />
                </div>
                <div style="display:flex; align-items:center; gap:10px; margin-top:4px;">
                    <label style="display:flex; align-items:center; gap:6px; font-size:.85rem; font-weight:500; cursor:pointer;">
                        <input type="checkbox" name="cpIsPrimary" value="true" />
                        Primärer Ansprechpartner
                    </label>
                    <div style="flex:1;"></div>
                    <button type="button" class="btn-cm btn-cm-ghost btn-cm-sm" onclick="togglePanel('addContactPanel')">Abbrechen</button>
                    <button type="submit" class="btn-cm btn-cm-primary btn-cm-sm"><i class="bi bi-check-lg"></i> Speichern</button>
                </div>
            </form>
        </div>

        @if (Model.Customer.ContactPersons.Any())
        {
            <table class="cm-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Funktion</th>
                        <th>Telefon</th>
                        <th>E-Mail</th>
                        <th>Notiz</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cp in Model.Customer.ContactPersons.OrderByDescending(c => c.IsPrimary))
                    {
                        <tr>
                            <td>
                                @cp.Name
                                @if (cp.IsPrimary)
                                {
                                    <span class="badge-type" style="background:#ede9fe;color:#6d28d9; margin-left:6px;">
                                        <i class="bi bi-star-fill"></i> Primär
                                    </span>
                                }
                            </td>
                            <td style="color:var(--text-muted);">@(cp.Role ?? "–")</td>
                            <td>@(cp.Phone ?? "–")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(cp.Email))
                                {
                                    <a href="mailto:@cp.Email" style="color:var(--accent);">@cp.Email</a>
                                }
                                else
                                {

                                    <span>–</span>
                                }
                            </td>
                            <td style="color:var(--text-muted); font-size:.82rem;">@(cp.Notes ?? "–")</td>
                            <td>
                                <form method="post" asp-page-handler="DeleteContactPerson"
                                      asp-route-id="@Model.Customer.CustomerId"
                                      asp-route-cpId="@cp.ContactPersonId"
                                      onsubmit="return confirm('Ansprechpartner löschen?');">
                                    <button type="submit" class="btn-cm btn-cm-danger btn-cm-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="cm-empty">
                <div class="cm-empty-icon"><i class="bi bi-person-x"></i></div>
                Keine Ansprechpartner gepflegt.
            </div>
        }
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     TAB: PROJEKTE
═══════════════════════════════════════════════════════ -->
<div id="tab-projekte" class="cm-tab-panel">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div style="padding:16px 24px;">
            <div class="cm-card-title" style="margin:0;">Projekthistorie</div>
        </div>
        @if (Model.Customer.Projects?.Any() == true)
        {
            <table class="cm-table">
                <thead>
                    <tr>
                        <th>Projektname</th>
                        <th>Status</th>
                        <th>Start</th>
                        <th>Ende</th>
                        <th>Dauer</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proj in Model.Customer.Projects!.OrderByDescending(p => p.StartDate))
                    {
                        var dur = (proj.StartDate.HasValue && proj.EndDate.HasValue)
                        ? ((proj.EndDate.Value.DayNumber - proj.StartDate.Value.DayNumber) + " Tage")
                        : "–";
                        <tr>
                            <td style="font-weight:600;">@proj.ProjectName</td>
                            <td>
                                @if (proj.State != null)
                                {
                                    <span style="display:inline-flex; align-items:center; gap:5px; font-size:.82rem;">
                                        <span class="state-dot" style="background:@proj.State.Color;"></span>
                                        @proj.State.StateName
                                    </span>
                                }
                                else
                                {

                                    <span style="color:var(--text-muted);">–</span>
                                }
                            </td>
                            <td style="color:var(--text-muted);">@(proj.StartDate?.ToString("dd.MM.yyyy") ?? "–")</td>
                            <td style="color:var(--text-muted);">@(proj.EndDate?.ToString("dd.MM.yyyy") ?? "–")</td>
                            <td style="color:var(--text-muted); font-size:.82rem;">@dur</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="cm-empty">
                <div class="cm-empty-icon"><i class="bi bi-kanban"></i></div>
                Noch keine Projekte vorhanden.
            </div>
        }
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     TAB: ZUSCHLAGSÄTZE
═══════════════════════════════════════════════════════ -->
<div id="tab-zuschlaege" class="cm-tab-panel">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div style="padding:16px 24px; display:flex; justify-content:space-between; align-items:center;">
            <div class="cm-card-title" style="margin:0;">Materialzuschläge</div>
            <button class="btn-cm btn-cm-primary btn-cm-sm" onclick="togglePanel('addSurchargePanel')">
                <i class="bi bi-plus-lg"></i> Hinzufügen
            </button>
        </div>

        <div id="addSurchargePanel" class="cm-add-panel" style="margin:0 20px 16px; display:none;">
            <div class="cm-add-panel-title">Neuer Zuschlag</div>
            <form method="post" asp-page-handler="AddSurcharge" asp-route-id="@Model.Customer.CustomerId">
                <div style="display:grid; grid-template-columns:2fr 2fr 1fr; gap:12px; align-items:end;">
                    <div class="cm-form-group" style="margin:0;">
                        <label>Materialkategorie *</label>
                        <input name="surCategory" class="cm-input" required placeholder="z.B. Stahl, Holz, Elektronik" />
                    </div>
                    <div class="cm-form-group" style="margin:0;">
                        <label>Beschreibung</label>
                        <input name="surDescription" class="cm-input" placeholder="Optionale Beschreibung" />
                    </div>
                    <div class="cm-form-group" style="margin:0;">
                        <label>Zuschlag %</label>
                        <input name="surPercent" class="cm-input" type="number" step="0.01" min="0" max="1000" required placeholder="0.00" />
                    </div>
                </div>
                <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:12px;">
                    <button type="button" class="btn-cm btn-cm-ghost btn-cm-sm" onclick="togglePanel('addSurchargePanel')">Abbrechen</button>
                    <button type="submit" class="btn-cm btn-cm-primary btn-cm-sm"><i class="bi bi-check-lg"></i> Speichern</button>
                </div>
            </form>
        </div>

        @if (Model.Customer.MaterialSurcharges.Any())
        {
            <table class="cm-table">
                <thead>
                    <tr>
                        <th>Kategorie</th>
                        <th>Beschreibung</th>
                        <th style="text-align:right;">Zuschlag</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sur in Model.Customer.MaterialSurcharges.OrderBy(s => s.MaterialCategory))
                    {
                        <tr>
                            <td style="font-weight:600;">@sur.MaterialCategory</td>
                            <td style="color:var(--text-muted);">@(sur.Description ?? "–")</td>
                            <td style="text-align:right; font-weight:700; color:var(--accent);">
                                @sur.SurchargePercent.ToString("0.##") %
                            </td>
                            <td>
                                <form method="post" asp-page-handler="DeleteSurcharge"
                                      asp-route-id="@Model.Customer.CustomerId"
                                      asp-route-surId="@sur.SurchargeId"
                                      onsubmit="return confirm('Zuschlag löschen?');">
                                    <button type="submit" class="btn-cm btn-cm-danger btn-cm-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="cm-empty">
                <div class="cm-empty-icon"><i class="bi bi-percent"></i></div>
                Keine Zuschlagsätze definiert.
            </div>
        }
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     TAB: NACHRICHTEN / TICKETING
═══════════════════════════════════════════════════════ -->
<div id="tab-nachrichten" class="cm-tab-panel">
    <div class="cm-card" style="padding:0; overflow:hidden;">
        <div style="padding:16px 24px; display:flex; justify-content:space-between; align-items:center;">
            <div class="cm-card-title" style="margin:0;">Kundenanfragen & Nachrichten</div>
            <button class="btn-cm btn-cm-primary btn-cm-sm" onclick="togglePanel('addMessagePanel')">
                <i class="bi bi-plus-lg"></i> Neue Nachricht
            </button>
        </div>

        <div id="addMessagePanel" class="cm-add-panel" style="margin:0 20px 16px; display:none;">
            <div class="cm-add-panel-title">Neue Kundenanfrage / Customer Message</div>
            <form method="post" asp-page-handler="AddMessage" asp-route-id="@Model.Customer.CustomerId"
                  enctype="multipart/form-data">
                <div class="cm-form-group">
                    <label>Betreff *</label>
                    <input name="msgSubject" class="cm-input" required placeholder="Kurzer Betreff der Anfrage" />
                </div>
                <div class="cm-form-group">
                    <label>Inhalt / Beschreibung</label>
                    <textarea name="msgContent" class="cm-input" rows="4" style="resize:vertical;"
                              placeholder="Details zur Kundenanfrage…"></textarea>
                </div>
                <div class="cm-form-group">
                    <label>Anhang (optional)</label>
                    <input name="msgAttachment" type="file" class="cm-input" style="padding:6px;" />
                </div>
                <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:4px;">
                    <button type="button" class="btn-cm btn-cm-ghost btn-cm-sm" onclick="togglePanel('addMessagePanel')">Abbrechen</button>
                    <button type="submit" class="btn-cm btn-cm-primary btn-cm-sm"><i class="bi bi-check-lg"></i> Erstellen</button>
                </div>
            </form>
        </div>

        @if (Model.Customer.CustomerMessages.Any())
        {
            <table class="cm-table">
                <thead>
                    <tr>
                        <th>Betreff</th>
                        <th>Status</th>
                        <th>Erstellt von</th>
                        <th>Datum</th>
                        <th>Anhang</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model.Customer.CustomerMessages.OrderByDescending(m => m.CreatedTimestamp))
                    {
                        string statusClass = msg.Status switch
                        {
                            MessageStatus.Offen => "badge-offen",
                            MessageStatus.InBearbeitung => "badge-inbearbeitung",
                            MessageStatus.Geschlossen => "badge-geschlossen",
                            _ => ""
                        };
                        string statusLabel = msg.Status switch
                        {
                            MessageStatus.Offen => "Offen",
                            MessageStatus.InBearbeitung => "In Bearbeitung",
                            MessageStatus.Geschlossen => "Geschlossen",
                            _ => ""
                        };
                        <tr>
                            <td>
                                <div style="font-weight:600;">@msg.Subject</div>
                                @if (!string.IsNullOrEmpty(msg.Content))
                                {
                                    <div style="font-size:.78rem; color:var(--text-muted); max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @msg.Content
                                    </div>
                                }
                            </td>
                            <td><span class="badge-status @statusClass">@statusLabel</span></td>
                            <td style="font-size:.82rem; color:var(--text-muted);">
                                @(msg.CreatedByEmployee?.EmployeeDisplayName ?? "–")
                            </td>
                            <td style="font-size:.82rem; color:var(--text-muted);">
                                @msg.CreatedTimestamp.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(msg.AttachmentFileName))
                                {
                                    <a href="/uploads/messages/@msg.AttachmentPath" target="_blank"
                                       style="color:var(--accent); font-size:.82rem;">
                                        <i class="bi bi-paperclip"></i> @msg.AttachmentFileName
                                    </a>
                                }
                                else
                                {

                                    <span style="color:var(--text-muted);">–</span>
                                }
                            </td>
                            <td>
                                @if (msg.Status != MessageStatus.Geschlossen)
                                {
                                    <form method="post" asp-page-handler="CloseMessage"
                                          asp-route-id="@Model.Customer.CustomerId"
                                          asp-route-msgId="@msg.MessageId" style="display:inline;">
                                        <button type="submit" class="btn-cm btn-cm-ghost btn-cm-sm" title="Schließen">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="cm-empty">
                <div class="cm-empty-icon"><i class="bi bi-chat-dots"></i></div>
                Noch keine Nachrichten vorhanden.
            </div>
        }
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     TAB: KONTAKT-HISTORIE
═══════════════════════════════════════════════════════ -->
<div id="tab-historie" class="cm-tab-panel">
    <div style="display:grid; grid-template-columns:1fr 340px; gap:20px; align-items:start;">
        <div class="cm-card" style="padding:0; overflow:hidden;">
            <div style="padding:16px 24px;">
                <div class="cm-card-title" style="margin:0;">Verlauf</div>
            </div>

            @if (Model.Customer.ContactHistoryEntries.Any())
            {
                <ul class="cm-timeline" style="padding:0 20px 10px;">
                    @foreach (var entry in Model.Customer.ContactHistoryEntries.OrderByDescending(e => e.ContactDate))
                    {
                        string iconClass = entry.ContactType switch
                        {
                            ContactType.Telefonat => "bi-telephone-fill",
                            ContactType.Email => "bi-envelope-fill",
                            ContactType.Chat => "bi-chat-fill",
                            ContactType.Meeting => "bi-people-fill",
                            _ => "bi-three-dots"
                        };
                        string ctClass = entry.ContactType switch
                        {
                            ContactType.Telefonat => "ct-telefonat",
                            ContactType.Email => "ct-email",
                            ContactType.Chat => "ct-chat",
                            ContactType.Meeting => "ct-meeting",
                            _ => "ct-sonstiges"
                        };
                        string typeLabel = entry.ContactType switch
                        {
                            ContactType.Telefonat => "Telefonat",
                            ContactType.Email => "E-Mail",
                            ContactType.Chat => "Chat",
                            ContactType.Meeting => "Meeting",
                            _ => "Sonstiges"
                        };
                        <li class="cm-timeline-item">
                            <div class="cm-timeline-icon @ctClass">
                                <i class="bi @iconClass"></i>
                            </div>
                            <div class="cm-timeline-body">
                                <div class="tl-note">@entry.Note</div>
                                <div class="tl-meta">
                                    <span style="font-weight:600;">@typeLabel</span>
                                    · @entry.ContactDate.ToString("dd.MM.yyyy HH:mm")
                                    @if (entry.CreatedByEmployee != null)
                                    {
                                        <span>· @entry.CreatedByEmployee.EmployeeDisplayName</span>
                                    }
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="cm-empty">
                    <div class="cm-empty-icon"><i class="bi bi-clock-history"></i></div>
                    Noch keine Kontakte erfasst.
                </div>
            }
        </div>

        <!-- Quick-Add form -->
        <div class="cm-card">
            <div class="cm-card-title">Kontakt erfassen</div>
            <form method="post" asp-page-handler="AddContactHistory" asp-route-id="@Model.Customer.CustomerId">
                <div class="cm-form-group">
                    <label>Art des Kontakts</label>
                    <select name="ctType" class="cm-input cm-select">
                        <option value="0">📞 Telefonat</option>
                        <option value="1">✉️ E-Mail</option>
                        <option value="2">💬 Chat</option>
                        <option value="3">🤝 Meeting</option>
                        <option value="4">📝 Sonstiges</option>
                    </select>
                </div>
                <div class="cm-form-group">
                    <label>Datum & Uhrzeit</label>
                    <input name="ctDate" type="datetime-local" class="cm-input"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="cm-form-group">
                    <label>Notiz / Zusammenfassung *</label>
                    <textarea name="ctNote" class="cm-input" rows="4" required style="resize:vertical;"
                              placeholder="z.B. Telefonat mit Hr. Müller – Interesse an Produkt X bekundet…"></textarea>
                </div>
                <button type="submit" class="btn-cm btn-cm-primary" style="width:100%;">
                    <i class="bi bi-plus-circle"></i> Eintragen
                </button>
            </form>
        </div>
    </div>
</div>

<!-- ── Tab + panel JS ── -->
<script>
    function switchTab(name, el) {
      document.querySelectorAll('.cm-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.cm-tab-panel').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('tab-' + name).classList.add('active');
    }
    function togglePanel(id) {
      const el = document.getElementById(id);
      el.style.display = el.style.display === 'none' ? 'block' : 'none';
    }

    // Re-open tab if anchor is present
    const hash = window.location.hash?.substring(1);
    if (hash) {
      const tab = document.querySelector(`[onclick*="'${hash}'"]`);
      if (tab) tab.click();
    }
</script>
