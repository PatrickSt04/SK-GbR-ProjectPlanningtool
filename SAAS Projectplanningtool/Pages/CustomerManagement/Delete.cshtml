@page
@model SAAS_Projectplanningtool.Pages.CustomerManagement.DeleteModel

@{
    ViewData["Title"] = "Kunde löschen";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-header">
    <div class="header-content">
        <div class="header-left">
            <h1><i class="bi bi-trash me-2"></i>Kunde löschen</h1>
            <p class="header-subtitle">@Model.Customer.CustomerName</p>
        </div>
        <div class="header-actions">
            <a asp-page="./Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>Zurück
            </a>
        </div>
    </div>
</div>

<div class="cm-form-container">
    <div class="cm-alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Sind Sie sicher, dass Sie diesen Kunden endgültig löschen möchten?
    </div>

    <div class="card">
        <div class="cm-colorbar-danger"></div>
        <div class="card-header">
            <h5><i class="bi bi-person-x me-2"></i>@Model.Customer.CustomerName</h5>
        </div>
        <div class="card-body">
            <div class="cm-info-grid">
                <div class="cm-info-item">
                    <label><i class="bi bi-person"></i> Name</label>
                    <span>@Model.Customer.CustomerName</span>
                </div>
                <div class="cm-info-item">
                    <label><i class="bi bi-clock"></i> Erstellt</label>
                    <span>@(Model.Customer.CreatedTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</span>
                </div>
                <div class="cm-info-item">
                    <label><i class="bi bi-pencil"></i> Letzte Änderung</label>
                    <span>@(Model.Customer.LatestModificationTimestamp?.ToString("dd.MM.yyyy HH:mm") ?? "–")</span>
                </div>
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Customer.CustomerId" />
        <div class="cm-form-actions">
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i>Endgültig löschen
            </button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Abbrechen</a>
        </div>
    </form>
</div>
